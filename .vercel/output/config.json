			"dest": "_render"
		},
		{
			"src": "^/api/admin/incidentes/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/metrics/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/register/?$",
			"dest": "_render"
