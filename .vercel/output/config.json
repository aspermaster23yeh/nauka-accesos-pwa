{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/bitacora/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/detalle-movimiento/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/validar-qr/?$",
			"dest": "_render"
		},
		{
			"src": "^/guardia/acceso-denegado/?$",
			"dest": "_render"
		},
		{
			"src": "^/guardia/escaner/?$",
			"dest": "_render"
		},
		{
			"src": "^/residente/inicio/?$",
			"dest": "_render"
		},
		{
			"src": "^/residente/nuevo-pase/?$",
			"dest": "_render"
		}
	]
}