---
import AppLayout from "../../layouts/AppLayout.astro";
import { residentNav } from "../../lib/nav";
---

<AppLayout
  title="Inicio Residente - Nauka Nayarit"
  topBar={{ title: "Nauka Nayarit", leftIcon: "location_on", leftHref: "#", rightIcon: "person", rightHref: "#" }}
  pageTitle="Lote A-22"
  navItems={residentNav}
  activeNav="dashboard"
>
  <p class="-mt-5 mb-10 text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Panel de Residente</p>

  <a
    href="/residente/nuevo-pase"
    class="mb-10 flex h-24 w-full items-center justify-center gap-3 rounded-[14px] bg-gradient-to-b from-[#213138] to-[#37474f] px-5 text-3xl font-semibold text-white shadow-[0_14px_28px_rgba(26,28,28,0.18)]"
  >
    <span class="material-symbols-outlined text-4xl">add</span>
    <span class="text-3xl">Crear Nuevo Pase de Acceso</span>
  </a>

  <section class="space-y-4">
    <h2 class="text-5xl font-bold tracking-[-0.02em] text-[#213138]">Pases Activos</h2>

    <article class="relative rounded-[14px] bg-white p-5 shadow-[0_8px_24px_rgba(26,28,28,0.06)]">
      <span class="absolute left-0 top-0 h-full w-1 rounded-l-[14px] bg-[#0a8d4f]"></span>
      <div class="flex items-start gap-4 pl-1">
        <div class="grid h-12 w-12 place-items-center rounded-full bg-[#83fba5]/25 text-[#006d36]">
          <span class="material-symbols-outlined">directions_car</span>
        </div>
        <div class="flex-1">
          <p class="text-4xl font-semibold text-[#213138]">Mariana Sosa</p>
          <p class="mt-1 text-xl text-[#5f6368]">Hoy, 16:00 · VISITA</p>
          <div class="mt-4 flex gap-3">
            <a href="/admin/detalle-movimiento" class="flex-1 rounded-xl bg-[#eeeeee] px-4 py-3 text-center text-2xl font-semibold text-[#213138]">Ver QR</a>
            <button class="grid w-12 place-items-center rounded-xl bg-[#25D366]/10 text-[#075E54]">
              <span class="material-symbols-outlined">chat</span>
            </button>
          </div>
        </div>
      </div>
    </article>

    <article class="rounded-[14px] bg-white p-5 shadow-[0_8px_24px_rgba(26,28,28,0.06)]">
      <div class="flex items-start gap-4">
        <div class="grid h-12 w-12 place-items-center rounded-full bg-[#eeeeee] text-[#5f6368]">
          <span class="material-symbols-outlined">local_shipping</span>
        </div>
        <div class="flex-1">
          <p class="text-4xl font-semibold text-[#213138]">Amazon Delivery</p>
          <p class="mt-1 text-xl text-[#5f6368]">Hoy, Abierto · PROVEEDOR</p>
          <div class="mt-4 flex gap-3">
            <a href="/admin/detalle-movimiento" class="flex-1 rounded-xl bg-[#eeeeee] px-4 py-3 text-center text-2xl font-semibold text-[#213138]">Ver QR</a>
            <button class="grid w-12 place-items-center rounded-xl bg-[#25D366]/10 text-[#075E54]">
              <span class="material-symbols-outlined">chat</span>
            </button>
          </div>
        </div>
      </div>
    </article>
  </section>
</AppLayout>
