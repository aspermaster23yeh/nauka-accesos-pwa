---
import StatusChip from "./StatusChip.astro";

interface Props {
  status: "authorized" | "denied";
  title: string;
  message: string;
  secondary?: string;
}

const { status, title, message, secondary } = Astro.props;
const containerClass =
  status === "authorized"
    ? "bg-emerald-100 text-emerald-950"
    : "bg-red-700 text-white min-h-[45vh] flex flex-col justify-center";
---

<section class={`rounded-3xl px-6 py-8 shadow-sm ${containerClass}`}>
  <div class="mb-4">
    <StatusChip status={status === "authorized" ? "authorized" : "denied"} />
  </div>
  <h2 class="text-3xl font-extrabold sm:text-4xl">{title}</h2>
  <p class="mt-3 text-xl font-semibold">{message}</p>
  {secondary && <p class="mt-2 text-lg opacity-90">{secondary}</p>}
</section>
