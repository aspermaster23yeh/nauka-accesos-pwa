---
/**
 * Área suave tipo "plano arquitectónico" — métricas normalizadas a una sola curva.
 */
interface Props {
  movimientos: number;
  autorizados: number;
  rechazados: number;
  incidentes: number;
}

const { movimientos, autorizados, rechazados, incidentes } = Astro.props;
const raw = [movimientos, autorizados, rechazados, incidentes, movimientos * 0.85];
const max = Math.max(...raw, 1);
const w = 400;
const h = 112;
const pad = 8;
const pts = raw.map((v, i) => {
  const x = pad + (i * (w - 2 * pad)) / (raw.length - 1);
  const y = h - pad - (v / max) * (h - 2 * pad);
  return { x, y };
});
const lineD = pts.map((p, i) => `${i === 0 ? "M" : "L"} ${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(" ");
const areaD = `${lineD} L ${pts[pts.length - 1].x} ${h - pad} L ${pts[0].x} ${h - pad} Z`;
---

<div class="nauka-card-aero relative overflow-hidden p-5 md:p-6">
  <p class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-[#5c6569]">Flujo silencioso · 24 h</p>
  <p class="font-display mt-1 text-xl text-[#213138] md:text-2xl">Actividad operativa</p>
  <svg class="mt-4 w-full" viewBox={`0 0 ${w} ${h}`} preserveAspectRatio="none" aria-hidden="true">
    <defs>
      <linearGradient id="nauka-area-fill" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#213138" stop-opacity="0.09"></stop>
        <stop offset="100%" stop-color="#213138" stop-opacity="0"></stop>
      </linearGradient>
      <linearGradient id="nauka-line-stroke" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#213138" stop-opacity="0.35"></stop>
        <stop offset="50%" stop-color="#213138" stop-opacity="0.65"></stop>
        <stop offset="100%" stop-color="#213138" stop-opacity="0.4"></stop>
      </linearGradient>
    </defs>
    <path d={areaD} fill="url(#nauka-area-fill)" class="transition-[d] duration-[400ms] ease-in-out"></path>
    <path
      d={lineD}
      fill="none"
      stroke="url(#nauka-line-stroke)"
      stroke-width="1.25"
      stroke-linecap="round"
      stroke-linejoin="round"
      vector-effect="non-scaling-stroke"
      class="transition-[d] duration-[400ms] ease-in-out"
    >
    </path>
  </svg>
  <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-[#5c6569]">
    <span>Mov. {movimientos}</span>
    <span>Autorizados {autorizados}</span>
    <span>Rechazados {rechazados}</span>
    <span>Incidentes {incidentes}</span>
  </div>
</div>
