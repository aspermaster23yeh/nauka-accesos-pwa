---
/**
 * Línea de tiempo tipo sismógrafo — trazo fino Oxford, sin relleno tipo Excel.
 */
interface Props {
  movimientos: number;
  autorizados: number;
  rechazados: number;
  incidentes: number;
}

const { movimientos, autorizados, rechazados, incidentes } = Astro.props;

const series = [
  { v: movimientos, label: "Movimientos" },
  { v: autorizados, label: "Autorizados" },
  { v: rechazados, label: "Rechazados" },
  { v: incidentes, label: "Incidentes" }
] as const;

const raw = series.map((s) => s.v);
const max = Math.max(...raw, 1);
const w = 560;
const h = 108;
const padX = 20;
const padY = 18;
const baseline = h * 0.58;
const amplitude = (h - 2 * padY) * 0.38;

const pts = series.map((s, i) => {
  const x = padX + (i * (w - 2 * padX)) / (series.length - 1);
  const ratio = s.v / max;
  const y = baseline - (ratio - 0.5) * 2 * amplitude;
  return { x, y, ...s };
});

const lineD = pts.map((p, i) => `${i === 0 ? "M" : "L"} ${p.x.toFixed(2)} ${p.y.toFixed(2)}`).join(" ");
---

<div class="nauka-glass-editorial px-5 py-6 md:px-8 md:py-8">
  <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
    <p class="text-[0.6rem] font-semibold uppercase tracking-[0.26em] text-[#5c6569]">Flujo silencioso</p>
    <p class="nauka-ui-display text-xs font-medium text-[#213138]/55">Trazo de precisión · ventana 24 h</p>
  </div>

  <svg class="nauka-ui-display mt-5 w-full text-[#213138]" viewBox={`0 0 ${w} ${h}`} preserveAspectRatio="xMidYMid meet" aria-hidden="true">
    <line x1={padX} y1={baseline} x2={w - padX} y2={baseline} stroke="currentColor" stroke-opacity="0.14" stroke-width="1" vector-effect="non-scaling-stroke">
    </line>
    <path
      d={lineD}
      fill="none"
      stroke="currentColor"
      stroke-opacity="0.42"
      stroke-width="1"
      stroke-linecap="round"
      stroke-linejoin="round"
      vector-effect="non-scaling-stroke"
    >
    </path>
    {
      pts.map((p) => (
        <circle cx={p.x} cy={p.y} r="2.75" fill="currentColor" fill-opacity="0.32" stroke="currentColor" stroke-opacity="0.45" stroke-width="0.75">
        </circle>
      ))
    }
  </svg>

  <div class="nauka-ui-display mt-4 grid grid-cols-2 gap-x-6 gap-y-2 text-[0.7rem] text-[#5c6569] sm:grid-cols-4">
    {
      pts.map((p) => (
        <div class="flex flex-col border-t border-[#213138]/[0.08] pt-2">
          <span class="font-medium text-[#213138]/80">{p.label}</span>
          <span class="tabular-nums text-[#213138]">{p.v}</span>
        </div>
      ))
    }
  </div>
</div>
