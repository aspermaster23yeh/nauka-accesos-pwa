---
interface Props {
  complejoId: string;
}

const { complejoId } = Astro.props;
---

<section class="space-y-4" data-complejo-id={complejoId}>
  <div class="lens-section rounded-2xl p-4">
    <p class="text-sm font-semibold uppercase tracking-wide sunlight-subtext">Complejo activo</p>
    <p class="text-xl font-bold">{complejoId}</p>
  </div>

  <video id="scanner-video" class="w-full rounded-3xl bg-slate-900" playsinline muted></video>

  <div id="scanner-result" class="lens-section-muted rounded-2xl p-5">
    <p class="text-lg font-semibold">Apunta la cámara al QR del visitante.</p>
  </div>
</section>

<script>
  import { BrowserMultiFormatReader } from "@zxing/browser";

  const rootElement = document.querySelector("[data-complejo-id]");
  const videoElement = document.getElementById("scanner-video");
  const resultElement = document.getElementById("scanner-result");
  const complejoId = rootElement?.getAttribute("data-complejo-id") ?? "complejo-1";
  const codeReader = new BrowserMultiFormatReader();
  let stopped = false;

  if (!videoElement || !resultElement) {
    console.error("Scanner UI elements are missing.");
  }
  const resultPane = resultElement as HTMLDivElement | null;

  const renderAuthorized = (payload: { visitanteNombre?: string; solicitanteNombre?: string }) => {
    if (!resultPane) return;
    resultPane.className = "rounded-3xl bg-emerald-100 p-6 text-emerald-950";
    resultPane.innerHTML = `
      <p class="text-3xl font-extrabold">Visitante Autorizado</p>
      <p class="mt-2 text-xl font-semibold">${payload.visitanteNombre ?? "Visitante"}</p>
      <p class="mt-2 text-base">Solicitante: ${payload.solicitanteNombre ?? "No definido"}</p>
    `;
  };

  const renderDenied = (payload: { razon?: string }) => {
    if (!resultPane) return;
    resultPane.className = "rounded-3xl bg-red-700 p-8 text-white min-h-[45vh] flex flex-col justify-center";
    const detalle = payload.razon ? `<p class="mt-4 text-xl font-semibold">${payload.razon}</p>` : "";
    resultPane.innerHTML = `
      <p class="text-5xl font-black tracking-tight">ACCESO NO AUTORIZADO</p>
      ${detalle}
      <p class="mt-4 text-lg font-medium opacity-90">Verifica el pase o contacta a administración.</p>
    `;
  };

  const extractToken = (rawValue: string) => {
    const trimmed = String(rawValue ?? "").trim();
    if (!trimmed) return "";
    if (!trimmed.startsWith("http://") && !trimmed.startsWith("https://")) return trimmed;
    try {
      const parsed = new URL(trimmed);
      const queryCode = parsed.searchParams.get("code");
      if (queryCode) return queryCode;
      const parts = parsed.pathname.split("/").filter(Boolean);
      if (parts.length >= 2 && parts[0] === "pase") return decodeURIComponent(parts[1]);
      return "";
    } catch {
      return "";
    }
  };

  const validateToken = async (token: string) => {
    const response = await fetch("/api/validar-qr", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ token, complejoId })
    });
    return response.json();
  };

  async function startScanner() {
    if (!videoElement || !resultPane) {
      return;
    }
    try {
      const devices = await BrowserMultiFormatReader.listVideoInputDevices();
      const camera = devices.find((d) => /back|rear|environment/i.test(d.label)) ?? devices[0];
      if (!camera) {
        throw new Error("No camera available");
      }

      await codeReader.decodeFromVideoDevice(camera.deviceId, videoElement as HTMLVideoElement, async (result, error) => {
        if (stopped || !result) {
          return;
        }
        stopped = true;
        const token = extractToken(result.getText());
        const outcome = token ? await validateToken(token) : { status: "not_found" as const, razon: "Sin token" };
        if (outcome.status === "authorized") {
          renderAuthorized(outcome);
        } else {
          renderDenied({ razon: outcome.razon });
        }
        (codeReader as { reset?: () => void }).reset?.();
      });
    } catch {
      resultPane.className = "rounded-2xl bg-red-100 p-6 text-red-900";
      resultPane.innerHTML = `
        <p class="text-2xl font-bold">No se pudo iniciar la cámara</p>
        <p class="mt-2 text-base">Revisa permisos del navegador y vuelve a intentar.</p>
      `;
    }
  }

  startScanner();
</script>
