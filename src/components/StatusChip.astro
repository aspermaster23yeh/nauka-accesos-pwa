---
interface Props {
  status: "authorized" | "denied" | "pending";
  label?: string;
}

const { status, label } = Astro.props;

const chipClass = {
  authorized: "nauka-chip-ok",
  denied: "nauka-chip-warn",
  pending: "nauka-chip-neutral"
}[status];

const computedLabel =
  label ??
  {
    authorized: "Autorizado",
    denied: "Denegado",
    pending: "Pendiente"
  }[status];
---

<span
  class:list={[
    "inline-flex items-center rounded-full px-4 py-2 text-xs font-semibold tracking-wide transition duration-[400ms] ease-in-out",
    chipClass
  ]}
>
  {computedLabel}
</span>
