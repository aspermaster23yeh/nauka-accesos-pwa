---
interface Props {
  status: "authorized" | "denied" | "pending";
  label?: string;
}

const { status, label } = Astro.props;

const styles = {
  authorized: "bg-emerald-700 text-white",
  denied: "bg-red-700 text-white",
  pending: "bg-slate-700 text-white"
}[status];

const computedLabel =
  label ??
  {
    authorized: "Autorizado",
    denied: "Denegado",
    pending: "Pendiente"
  }[status];
---

<span class={`inline-flex items-center rounded-full px-4 py-2 text-sm font-bold ${styles}`}>
  {computedLabel}
</span>
