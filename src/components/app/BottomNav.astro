---
export interface BottomNavItem {
  id: string;
  label: string;
  icon: string;
  href: string;
}

interface Props {
  items: BottomNavItem[];
  activeId?: string;
  /** Misma anchura que AppLayout wide en escritorio */
  wide?: boolean;
}

const { items, activeId, wide = false } = Astro.props;
const navMax = wide ? "max-w-[430px] md:max-w-6xl lg:max-w-7xl" : "max-w-[430px]";
---

<nav
  class:list={[
    "fixed bottom-0 left-1/2 z-50 flex h-20 w-full -translate-x-1/2 items-center justify-around border-t border-white/70 bg-white/90 px-2 backdrop-blur-xl",
    navMax
  ]}
>
  {
    items.map((item) => {
      const isActive = item.id === activeId;
      return (
        <a
          href={item.href}
          class={`flex w-20 flex-col items-center justify-center rounded-xl px-2 py-2 text-[10px] font-bold uppercase tracking-[0.08em] transition ${
            isActive ? "bg-[#eeeeee] text-[#213138]" : "text-[#7a7e82] hover:text-[#213138]"
          }`}
        >
          <span class="material-symbols-outlined mb-1">{item.icon}</span>
          <span>{item.label}</span>
        </a>
      );
    })
  }
</nav>
