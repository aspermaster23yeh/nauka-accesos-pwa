---
export interface BottomNavItem {
  id: string;
  label: string;
  icon: string;
  href: string;
}

interface Props {
  items: BottomNavItem[];
  activeId?: string;
  /** Misma anchura que AppLayout wide en escritorio */
  wide?: boolean;
}

const { items, activeId, wide = false } = Astro.props;
const navMax = wide ? "max-w-[430px] md:max-w-6xl lg:max-w-7xl" : "max-w-[430px]";
---

<nav
  class:list={[
    "nauka-glass-dock fixed bottom-0 left-1/2 z-50 flex h-[4.75rem] w-full max-w-full -translate-x-1/2 items-center justify-start gap-0 overflow-x-auto overflow-y-hidden overscroll-x-contain px-1",
    navMax
  ]}
>
  {
    items.map((item) => {
      const isActive = item.id === activeId;
      return (
        <a
          href={item.href}
          class:list={[
            "flex min-w-[3.5rem] shrink-0 flex-col items-center justify-center rounded-2xl px-1.5 py-2 text-[10px] font-bold uppercase tracking-[0.08em] transition duration-[400ms] ease-in-out sm:min-w-[4.25rem] sm:px-2",
            isActive ? "bg-[#213138]/[0.08] text-[#213138]" : "text-[#5c6569] hover:text-[#213138]"
          ]}
        >
          <span class="material-symbols-outlined mb-0.5 text-[20px] sm:text-[22px]">{item.icon}</span>
          <span class="max-w-[4.25rem] truncate text-center leading-tight">{item.label}</span>
        </a>
      );
    })
  }
</nav>
