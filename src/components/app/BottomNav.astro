---
export interface BottomNavItem {
  id: string;
  label: string;
  icon: string;
  href: string;
}

interface Props {
  items: BottomNavItem[];
  activeId?: string;
  /** Misma anchura que AppLayout wide en escritorio */
  wide?: boolean;
}

const { items, activeId, wide = false } = Astro.props;
const navMax = wide ? "max-w-[430px] md:max-w-6xl lg:max-w-7xl" : "max-w-[430px]";
---

<nav
  class:list={[
    "nauka-glass-dock fixed bottom-0 left-1/2 z-50 flex h-[4.75rem] w-full -translate-x-1/2 items-center justify-around px-2",
    navMax
  ]}
>
  {
    items.map((item) => {
      const isActive = item.id === activeId;
      return (
        <a
          href={item.href}
          class:list={[
            "flex w-[4.5rem] flex-col items-center justify-center rounded-2xl px-2 py-2 text-[10px] font-bold uppercase tracking-[0.1em] transition duration-[400ms] ease-in-out",
            isActive ? "bg-[#213138]/[0.08] text-[#213138]" : "text-[#5c6569] hover:text-[#213138]"
          ]}
        >
          <span class="material-symbols-outlined mb-1 text-[22px]">{item.icon}</span>
          <span>{item.label}</span>
        </a>
      );
    })
  }
</nav>
