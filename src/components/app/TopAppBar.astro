---
interface Props {
  title: string;
  /** `nav-toggle`: botón menú (móvil) para el drawer de app; `link`: enlace izquierdo clásico */
  leftKind?: "link" | "nav-toggle";
  leftIcon?: string;
  leftHref?: string;
  rightIcon?: string;
  rightHref?: string;
  rightButtonId?: string;
}

const {
  title,
  leftKind = "link",
  leftIcon = "arrow_back",
  leftHref = "#",
  rightIcon,
  rightHref = "#",
  rightButtonId
} = Astro.props;
---

<header class="nauka-glass-nav sticky top-0 z-[60] grid grid-cols-[2.5rem_1fr_2.5rem] items-center gap-2 px-4 py-3">
  <div class="flex items-center justify-start">
    {
      leftKind === "nav-toggle" ? (
        <>
          <button
            type="button"
            id="app-nav-open"
            class="grid h-10 w-10 place-items-center rounded-full text-[#213138] transition hover:bg-[#213138]/[0.06] md:hidden"
            aria-label="Abrir menú de navegación"
            aria-expanded="false"
            aria-controls="app-nav-sidebar"
          >
            <span class="material-symbols-outlined">menu</span>
          </button>
          <span class="hidden h-10 w-10 md:block" aria-hidden="true" />
        </>
      ) : (
        <a
          href={leftHref}
          class="grid h-10 w-10 place-items-center rounded-full text-[#213138] transition hover:bg-[#213138]/[0.06]"
        >
          <span class="material-symbols-outlined">{leftIcon}</span>
        </a>
      )
    }
  </div>
  <h2 class="min-w-0 truncate text-center text-base font-semibold tracking-wide text-[#213138]">{title}</h2>
  <div class="flex items-center justify-end">
    {
      rightIcon ? (
        rightButtonId ? (
          <button
            id={rightButtonId}
            type="button"
            aria-label="Abrir menú de cuenta"
            aria-expanded="false"
            aria-controls="sidebar-panel"
            class="grid h-10 w-10 place-items-center rounded-full text-[#213138] transition hover:bg-[#213138]/[0.06]"
          >
            <span class="material-symbols-outlined">{rightIcon}</span>
          </button>
        ) : (
          <a href={rightHref} class="grid h-10 w-10 place-items-center rounded-full text-[#213138] transition hover:bg-[#213138]/[0.06]">
            <span class="material-symbols-outlined">{rightIcon}</span>
          </a>
        )
      ) : (
        <span class="h-10 w-10" />
      )
    }
  </div>
</header>
