---
interface Props {
  title: string;
  leftIcon?: string;
  leftHref?: string;
  rightIcon?: string;
  rightHref?: string;
  rightButtonId?: string;
}

const { title, leftIcon = "arrow_back", leftHref = "#", rightIcon, rightHref = "#", rightButtonId } = Astro.props;
---

<header class="nauka-glass-nav sticky top-0 z-[60] flex items-center justify-between px-4 py-3">
  <a
    href={leftHref}
    class="grid h-10 w-10 place-items-center rounded-full text-[#213138] transition hover:bg-[#213138]/[0.06]"
  >
    <span class="material-symbols-outlined">{leftIcon}</span>
  </a>
  <h2 class="text-base font-semibold tracking-wide text-[#213138]">{title}</h2>
  {
    rightIcon ? (
      rightButtonId ? (
        <button
          id={rightButtonId}
          type="button"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="sidebar-panel"
          class="grid h-10 w-10 place-items-center rounded-full text-[#213138] transition hover:bg-[#213138]/[0.06]"
        >
          <span class="material-symbols-outlined">{rightIcon}</span>
        </button>
      ) : (
        <a href={rightHref} class="grid h-10 w-10 place-items-center rounded-full text-[#213138] transition hover:bg-[#213138]/[0.06]">
          <span class="material-symbols-outlined">{rightIcon}</span>
        </a>
      )
    ) : (
      <span class="h-10 w-10" />
    )
  }
</header>
