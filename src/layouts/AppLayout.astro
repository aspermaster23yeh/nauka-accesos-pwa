---
import "../styles/global.css";
import TopAppBar from "../components/app/TopAppBar.astro";
import BottomNav, { type BottomNavItem } from "../components/app/BottomNav.astro";

interface Props {
  title: string;
  pageTitle?: string;
  topBar?: {
    title: string;
    leftIcon?: string;
    leftHref?: string;
    rightIcon?: string;
    rightHref?: string;
  };
  navItems?: BottomNavItem[];
  activeNav?: string;
  bodyClass?: string;
}

const { title, pageTitle, topBar, navItems = [], activeNav, bodyClass = "bg-[#f9f9f9] text-[#1a1c1c]" } = Astro.props;
const currentPath = Astro.url.pathname;
const inferredActiveNav =
  activeNav ??
  navItems.find((item) => currentPath === item.href || currentPath.startsWith(`${item.href}/`))?.id;
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#f9f9f9" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,500,0,0"
      rel="stylesheet"
    />
  </head>
  <body class={`min-h-screen ${bodyClass}`}>
    <div class="mx-auto flex min-h-[100dvh] w-full max-w-[430px] flex-col bg-[#f9f9f9]">
      {topBar && <TopAppBar {...topBar} />}
      <main class={`flex-1 px-4 ${navItems.length > 0 ? "pb-24" : "pb-6"} ${pageTitle ? "pt-6" : "pt-4"}`}>
        {pageTitle && <h1 class="mb-6 text-[2.6rem] font-extrabold leading-tight tracking-[-0.02em] text-[#213138]">{pageTitle}</h1>}
        <slot />
      </main>
      {navItems.length > 0 && <BottomNav items={navItems} activeId={inferredActiveNav} />}
    </div>
  </body>
</html>
