---
import "../styles/global.css";
import TopAppBar from "../components/app/TopAppBar.astro";
import BottomNav, { type BottomNavItem } from "../components/app/BottomNav.astro";

interface Props {
  title: string;
  /** Ancho extra en md+ (panel admin / web) */
  wide?: boolean;
  pageTitle?: string;
  topBar?: {
    title: string;
    leftIcon?: string;
    leftHref?: string;
    rightIcon?: string;
    rightHref?: string;
    rightButtonId?: string;
  };
  navItems?: BottomNavItem[];
  activeNav?: string;
  bodyClass?: string;
}

const { title, wide = false, pageTitle, topBar, navItems = [], activeNav, bodyClass = "bg-[#f9f9f9] text-[#1a1c1c]" } = Astro.props;
const shellMax = wide ? "max-w-[430px] md:max-w-6xl lg:max-w-7xl" : "max-w-[430px]";
const currentPath = Astro.url.pathname;
const inferredActiveNav =
  activeNav ??
  navItems.find((item) => currentPath === item.href || currentPath.startsWith(`${item.href}/`))?.id;
const profile = Astro.locals.profile;
const user = Astro.locals.user;
const isAuthenticated = Boolean(profile && user);
const roleLabel =
  profile?.role === "admin"
    ? "Administrador"
    : profile?.role === "super_admin"
      ? "Super administrador"
      : profile?.role === "guardia"
        ? "Guardia"
        : "Solicitante";
const userName = profile?.full_name ?? user?.email ?? "Usuario";
const roleHome =
  profile?.role === "admin"
    ? "/admin/dashboard"
    : profile?.role === "super_admin"
      ? "/super-admin/dashboard"
      : profile?.role === "guardia"
        ? "/guardia/escaner"
        : "/solicitante/inicio";
const resolvedTopBar =
  topBar && isAuthenticated
    ? {
        ...topBar,
        rightIcon: "menu",
        rightHref: "#",
        rightButtonId: "sidebar-open"
      }
    : topBar;
const roleLinks =
  profile?.role === "admin" || profile?.role === "super_admin"
    ? profile?.role === "super_admin"
      ? [
          { href: "/super-admin/dashboard", label: "Usuarios" },
          { href: "/super-admin/bitacora", label: "Bitácora global" }
        ]
      : [
          { href: "/admin/dashboard", label: "Dashboard" },
          { href: "/admin/bitacora", label: "Bitacora" }
        ]
    : profile?.role === "guardia"
      ? [
          { href: "/guardia/escaner", label: "Escaner QR" },
          { href: "/guardia/acceso-denegado", label: "Accesos denegados" }
        ]
      : [
          { href: "/solicitante/inicio", label: "Inicio" },
          { href: "/solicitante/nuevo-pase", label: "Nuevo pase" }
        ];
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#f9f9f9" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,500,0,0"
      rel="stylesheet"
    />
  </head>
  <body class={`min-h-screen ${bodyClass}`}>
    <div class:list={["mx-auto flex min-h-[100dvh] w-full flex-col bg-[#f9f9f9]", shellMax]}>
      {resolvedTopBar && <TopAppBar {...resolvedTopBar} />}
      {
        isAuthenticated && (
          <>
            <div id="sidebar-overlay" class="pointer-events-none fixed inset-0 z-[70] bg-black/35 opacity-0 transition-opacity"></div>
            <aside
              id="sidebar-panel"
              class="fixed right-0 top-0 z-[80] flex h-full w-[84%] max-w-[330px] translate-x-full flex-col bg-white p-5 shadow-[-12px_0_24px_rgba(26,28,28,0.2)] transition-transform"
            >
              <div class="mb-5 flex items-start justify-between">
                <div>
                  <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">{roleLabel}</p>
                  <p class="mt-1 text-lg font-semibold text-[#213138]">{userName}</p>
                </div>
                <button id="sidebar-close" class="grid h-9 w-9 place-items-center rounded-full bg-[#f2f2f2] text-[#213138]" aria-label="Cerrar menu">
                  <span class="material-symbols-outlined">close</span>
                </button>
              </div>

              <nav class="space-y-2">
                <a href={roleHome} class="flex items-center gap-2 rounded-xl bg-[#213138] px-4 py-3 text-sm font-semibold text-white">
                  <span class="material-symbols-outlined text-base">home</span>
                  <span>Ir a mi inicio</span>
                </a>
                {roleLinks.map((item) => (
                  <a href={item.href} class="block rounded-xl bg-[#f4f4f4] px-4 py-3 text-sm font-semibold text-[#213138]">
                    {item.label}
                  </a>
                ))}
              </nav>

              <div class="mt-auto border-t border-[#ececec] pt-4">
                <form method="post" action="/api/auth/logout">
                  <button type="submit" class="flex h-11 w-full items-center justify-center gap-2 rounded-xl bg-[#ba1a1a] text-sm font-semibold text-white">
                    <span class="material-symbols-outlined text-base">logout</span>
                    <span>Cerrar sesion</span>
                  </button>
                </form>
              </div>
            </aside>
          </>
        )
      }
      <main
        class:list={[
          "flex-1 px-4",
          wide && "md:px-8",
          navItems.length > 0 ? "pb-24" : "pb-6",
          pageTitle ? "pt-6" : "pt-4"
        ]}
      >
        {
          pageTitle && (
            <h1 class="mb-6 text-3xl font-extrabold leading-tight tracking-[-0.02em] text-[#213138] md:text-[2.6rem]">{pageTitle}</h1>
          )
        }
        <slot />
      </main>
      {navItems.length > 0 && <BottomNav items={navItems} activeId={inferredActiveNav} wide={wide} />}
    </div>
    {
      isAuthenticated && (
        <script is:inline>
          {`(() => {
            const openButton = document.getElementById("sidebar-open");
            const closeButton = document.getElementById("sidebar-close");
            const panel = document.getElementById("sidebar-panel");
            const overlay = document.getElementById("sidebar-overlay");
            if (!openButton || !closeButton || !panel || !overlay) return;

            const openSidebar = () => {
              panel.classList.remove("translate-x-full");
              overlay.classList.remove("opacity-0", "pointer-events-none");
            };

            const closeSidebar = () => {
              panel.classList.add("translate-x-full");
              overlay.classList.add("opacity-0", "pointer-events-none");
            };

            openButton.addEventListener("click", openSidebar);
            closeButton.addEventListener("click", closeSidebar);
            overlay.addEventListener("click", closeSidebar);
            window.addEventListener("keydown", (event) => {
              if (event.key === "Escape") closeSidebar();
            });
          })();`}
        </script>
      )
    }
  </body>
</html>
