---
import AppLayout from "../../layouts/AppLayout.astro";
import { adminNav } from "../../lib/nav";
import { getAdminMetrics } from "../../lib/access";
import BlurText from "../../components/react/BlurText.jsx";

const accessToken = Astro.locals.accessToken as string;
const profile = Astro.locals.profile;
const user = Astro.locals.user;
const adminRole = profile?.role === "super_admin" ? "super_admin" : "admin";

const defaultMetrics = {
  totalMovimientos: 0,
  totalAutorizados: 0,
  totalRechazados: 0,
  incidentesAbiertos: 0
};

let metrics = defaultMetrics;
try {
  metrics = await getAdminMetrics({
    accessToken,
    userId: user!.id,
    role: adminRole,
    complejoId: profile?.complejo_id ?? "complejo-1",
    lotNumber: profile?.lot_number
  });
} catch (e) {
  console.error("[admin/dashboard] getAdminMetrics:", e);
}

const cards = [
  {
    id: "analitica",
    href: "/admin/analitica",
    title: "Analítica",
    desc: "Entradas por hora, día, semana o mes. Rankings de guardias y de solicitantes con más pases.",
    icon: "analytics",
    accent: "text-[#3d5c4a]"
  },
  {
    id: "actividad",
    href: "/admin/actividad",
    title: "Actividad en vivo",
    desc: "Tablero de movimientos en caseta, alertas y KPI por lote (actualización automática).",
    icon: "timeline",
    accent: "text-[#3d5c4a]"
  },
  {
    id: "bitacora",
    href: "/admin/bitacora",
    title: "Bitácora",
    desc: "Historial completo de accesos y validaciones en todos los complejos.",
    icon: "history",
    accent: "text-[#213138]"
  },
  {
    id: "operaciones",
    href: "/admin/operaciones",
    title: "Altas y lotes",
    desc: "Solicitantes, invitaciones de personal, catálogo de lotes y aprobación de perfiles.",
    icon: "group_add",
    accent: "text-[#9a6b5c]"
  },
  {
    id: "incidentes",
    href: "/admin/incidentes",
    title: "Incidentes",
    desc: "Listado y seguimiento de incidentes abiertos o cerrados.",
    icon: "warning",
    accent: "text-[#9a6b5c]"
  }
] as const;
---

<AppLayout
  wide
  title="Dashboard Admin - Nauka Nayarit"
  topBar={{ title: "Resumen", leftIcon: "shield", leftHref: "#", rightIcon: "menu", rightHref: "#" }}
  navItems={adminNav}
  activeNav="dashboard"
  pageTitle="Resumen"
  bodyClass="bg-[#F9F8F6] text-[#213138]"
  shellCanvasClass="nauka-soul-canvas"
>
  <BlurText
    client:visible
    text="Métricas rápidas de las últimas 24 h y accesos a cada área del panel."
    animateBy="words"
    direction="top"
    delay={100}
    stepDuration={0.32}
    className="-mt-3 mb-8 max-w-2xl text-sm leading-relaxed text-[#5c6569]"
  />

  <section class="mb-10 grid grid-cols-2 gap-3 sm:grid-cols-4" aria-label="Indicadores 24 h">
    <article class="rounded-2xl border border-[#213138]/[0.06] bg-white p-4 shadow-sm">
      <p class="text-[0.6rem] font-semibold uppercase tracking-[0.18em] text-[#5c6569]">Movimientos</p>
      <p class="mt-2 font-display text-2xl font-medium tabular-nums text-[#213138]">{metrics.totalMovimientos}</p>
    </article>
    <article class="rounded-2xl border border-[#213138]/[0.06] bg-white p-4 shadow-sm">
      <p class="text-[0.6rem] font-semibold uppercase tracking-[0.18em] text-[#5c6569]">Autorizados</p>
      <p class="mt-2 font-display text-2xl font-medium tabular-nums text-[#3d5c4a]">{metrics.totalAutorizados}</p>
    </article>
    <article class="rounded-2xl border border-[#213138]/[0.06] bg-white p-4 shadow-sm">
      <p class="text-[0.6rem] font-semibold uppercase tracking-[0.18em] text-[#5c6569]">Rechazados</p>
      <p class="mt-2 font-display text-2xl font-medium tabular-nums text-[#9a6b5c]">{metrics.totalRechazados}</p>
    </article>
    <article class="rounded-2xl border border-[#213138]/[0.06] bg-white p-4 shadow-sm">
      <p class="text-[0.6rem] font-semibold uppercase tracking-[0.18em] text-[#5c6569]">Incidentes</p>
      <p class="mt-2 font-display text-2xl font-medium tabular-nums text-[#213138]">{metrics.incidentesAbiertos}</p>
    </article>
  </section>

  <section class="grid grid-cols-1 gap-4 md:grid-cols-2" aria-label="Accesos al panel">
    {
      cards.map((c) => (
        <a
          href={c.href}
          class="group flex flex-col rounded-2xl border border-[#213138]/[0.06] bg-white p-5 shadow-sm transition hover:border-[#213138]/12 hover:shadow-md"
          aria-label={`${c.title}. ${c.desc}`}
        >
          <div class="flex items-start justify-between gap-3">
            <span class:list={["material-symbols-outlined text-2xl", c.accent]}>{c.icon}</span>
            <span class="text-xs font-bold uppercase tracking-wider text-[#7a7e82] opacity-0 transition group-hover:opacity-100">Abrir →</span>
          </div>
          <BlurText
            client:visible
            text={c.title}
            animateBy="words"
            direction="top"
            delay={70}
            stepDuration={0.28}
            className="mt-3 font-display text-xl tracking-tight text-[#213138]"
          />
          <p class="mt-2 flex-1 text-sm leading-relaxed text-[#5c6569]">{c.desc}</p>
          <span class:list={["mt-4 inline-flex items-center gap-1 text-sm font-semibold", c.accent]}>
            Ir a la sección
            <span class="material-symbols-outlined text-base transition group-hover:translate-x-0.5">arrow_forward</span>
          </span>
        </a>
      ))
    }
  </section>
</AppLayout>
