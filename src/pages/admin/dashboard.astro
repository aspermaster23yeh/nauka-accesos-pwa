---
import AppLayout from "../../layouts/AppLayout.astro";
import AdminFlowChart from "../../components/AdminFlowChart.astro";
import { adminNav } from "../../lib/nav";
import {
  getAdminMetrics,
  getBitacoraScope,
  getComplejosList,
  getLotesWithResponsables,
  getRecentPassesForComplejo,
  getSolicitantesForSelect,
  getSuperAdminActivityEnriched,
  type SuperAdminMovementRow,
  type LoteKpiRow,
  type LoteCatalogRow
} from "../../lib/access";
import { getSupabaseServiceClient } from "../../lib/supabase";

const accessToken = Astro.locals.accessToken as string;
const profile = Astro.locals.profile;
const user = Astro.locals.user;
const adminRole = profile?.role === "super_admin" ? "super_admin" : "admin";

const defaultMetrics = {
  totalMovimientos: 0,
  totalAutorizados: 0,
  totalRechazados: 0,
  incidentesAbiertos: 0
};

async function withTimeout<T>(promise: Promise<T>, ms: number, fallback: T): Promise<T> {
  let timeoutId: ReturnType<typeof setTimeout> | undefined;
  const timeoutPromise = new Promise<T>((resolve) => {
    timeoutId = setTimeout(() => resolve(fallback), ms);
  });
  const result = await Promise.race([promise, timeoutPromise]);
  if (timeoutId) clearTimeout(timeoutId);
  return result;
}

const metrics = await withTimeout(
  getAdminMetrics({
    accessToken,
    userId: user!.id,
    role: adminRole,
    complejoId: profile?.complejo_id ?? "complejo-1",
    lotNumber: profile?.lot_number
  }),
  1200,
  defaultMetrics
);

const pasesRecientes = await withTimeout(
  (async () => {
    try {
      return await getRecentPassesForComplejo(null, 12);
    } catch {
      return [] as Awaited<ReturnType<typeof getRecentPassesForComplejo>>;
    }
  })(),
  2000,
  []
);

const movimientos = await withTimeout(
  (async () => {
    try {
      return await getBitacoraScope({ allComplejos: true, limit: 40 });
    } catch {
      return [] as Awaited<ReturnType<typeof getBitacoraScope>>;
    }
  })(),
  2000,
  []
);

const incidentes = await withTimeout(
  (async () => {
    const svc = getSupabaseServiceClient();
    const { data } = await svc
      .from("incidentes")
      .select("id, created_at, estado, descripcion, severidad, visitante_nombre")
      .order("created_at", { ascending: false })
      .limit(20);
    return data ?? [];
  })(),
  2000,
  [] as any[]
);

let movements: SuperAdminMovementRow[] = [];
let lotKpis: LoteKpiRow[] = [];
let lotesCatalog: LoteCatalogRow[] = [];
let complejos: { id: string; nombre: string }[] = [];
let solicitantes: { id: string; full_name: string | null; lot_number: string | null; complejo_id: string | null }[] = [];

try {
  const [act, lotes, comp, sol] = await Promise.all([
    getSuperAdminActivityEnriched(180),
    getLotesWithResponsables(),
    getComplejosList(),
    getSolicitantesForSelect()
  ]);
  movements = act.movements;
  lotKpis = act.lotKpis;
  lotesCatalog = lotes;
  complejos = comp;
  solicitantes = sol;
} catch {
  /* esquema o red */
}

const supabase = getSupabaseServiceClient();
const { data: profiles } = await supabase
  .from("profiles")
  .select("id, full_name, lot_number, complejo_id, role, onboarding_status, ine_storage_path, photo_storage_path, created_at")
  .order("created_at", { ascending: false })
  .limit(40);

const maxLoteCount = Math.max(...lotKpis.map((k) => k.count24h), 1);

function tipoMovimientoLabel(t: string | null | undefined) {
  const v = (t ?? "").toLowerCase();
  if (v === "entrada") return "Entrada";
  if (v === "salida") return "Salida";
  if (v === "validacion") return "Validación QR";
  if (v === "incidente") return "Incidente";
  return v ? v.toUpperCase() : "Movimiento";
}
---

<AppLayout
  wide
  title="Dashboard Admin - Nauka Nayarit"
  topBar={{ title: "Nauka Nayarit", leftIcon: "shield", leftHref: "#", rightIcon: "logout", rightHref: "/api/auth/logout" }}
  navItems={adminNav}
  bodyClass="bg-[#F9F8F6] text-[#213138]"
  shellCanvasClass="nauka-soul-canvas"
>
  <header class="mb-10 md:mb-12 lg:max-w-[94%]">
    <h1 class="font-display text-[clamp(2.85rem,7.5vw,4.85rem)] leading-[1.02] tracking-[-0.02em] text-[#213138]">Bienvenido a Nauka</h1>
    <p class="nauka-ui-display mt-5 max-w-3xl text-[0.95rem] font-medium leading-relaxed text-[#5c6569] md:text-lg">
      Panel único de administración — métricas y bitácora en <span class="text-[#213138]">vista global</span> (todos los complejos), altas de personal y lotes, y seguimiento de movimientos en caseta.
    </p>
    <nav id="registro-personal" class="mt-6 flex flex-wrap gap-3">
      <a
        href="#alta-solicitante"
        class="nauka-ui-display inline-flex h-11 items-center justify-center rounded-2xl bg-[#213138] px-5 text-sm font-semibold text-[#F9F8F6] transition duration-[400ms] ease-in-out hover:opacity-92"
      >
        Registrar solicitante
      </a>
      <a
        href="#alta-personal"
        class="nauka-ui-display inline-flex h-11 items-center justify-center rounded-2xl border border-[#213138]/15 bg-white/70 px-5 text-sm font-semibold text-[#213138] backdrop-blur-md transition duration-[400ms] ease-in-out hover:bg-white"
      >
        Invitar guardia o admin
      </a>
      <a
        href="#alta-lote"
        class="nauka-ui-display inline-flex h-11 items-center justify-center rounded-2xl border border-[#213138]/15 bg-white/70 px-5 text-sm font-semibold text-[#213138] backdrop-blur-md transition duration-[400ms] ease-in-out hover:bg-white"
      >
        Registrar lote
      </a>
      <a
        href="/admin/bitacora"
        class="nauka-ui-display inline-flex h-11 items-center justify-center rounded-2xl px-5 text-sm font-semibold text-[#3d5c4a] underline decoration-[#3d5c4a]/25 underline-offset-4 transition hover:text-[#213138]"
      >
        Bitácora completa
      </a>
    </nav>
  </header>

  <section class="flex flex-col gap-10 lg:flex-row lg:items-end lg:gap-12 xl:gap-20">
    <div class="shrink-0 lg:w-[min(42%,20rem)] xl:w-[min(38%,22rem)]">
      <p class="text-[0.6rem] font-semibold uppercase tracking-[0.22em] text-[#5c6569]">Movimientos · 24 h</p>
      <p
        class="nauka-ui-display mt-2 text-[clamp(3.75rem,14vw,7.25rem)] font-medium leading-[0.9] tracking-[-0.035em] text-[#213138]"
      >
        {metrics.totalMovimientos}
      </p>
    </div>

    <div class="grid min-w-0 flex-1 grid-cols-1 gap-4 sm:grid-cols-3 sm:gap-3 md:gap-4">
      <article class="nauka-glass-editorial px-5 py-6 md:px-6 md:py-7">
        <p class="text-[0.6rem] font-semibold uppercase tracking-[0.2em] text-[#5c6569]">Autorizados</p>
        <p class="nauka-ui-display mt-3 text-[clamp(2rem,5vw,2.75rem)] font-medium leading-none tracking-[-0.03em] text-[#3d5c4a]">
          {metrics.totalAutorizados}
        </p>
      </article>
      <article class="nauka-glass-editorial px-5 py-6 md:px-6 md:py-7">
        <p class="text-[0.6rem] font-semibold uppercase tracking-[0.2em] text-[#5c6569]">Rechazados</p>
        <p class="nauka-ui-display mt-3 text-[clamp(2rem,5vw,2.75rem)] font-medium leading-none tracking-[-0.03em] text-[#9a6b5c]">
          {metrics.totalRechazados}
        </p>
      </article>
      <article class="nauka-glass-editorial px-5 py-6 md:px-6 md:py-7">
        <p class="text-[0.6rem] font-semibold uppercase tracking-[0.2em] text-[#5c6569]">Incidentes abiertos</p>
        <p class="nauka-ui-display mt-3 text-[clamp(2rem,5vw,2.75rem)] font-medium leading-none tracking-[-0.03em] text-[#213138]">
          {metrics.incidentesAbiertos}
        </p>
      </article>
    </div>
  </section>

  <section class="mt-12 md:mt-16">
    <AdminFlowChart
      movimientos={metrics.totalMovimientos}
      autorizados={metrics.totalAutorizados}
      rechazados={metrics.totalRechazados}
      incidentes={metrics.incidentesAbiertos}
    />
  </section>

  <section id="panel-vivo" class="mt-12 md:mt-16">
    <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 class="font-display text-xl tracking-[-0.02em] text-[#213138] md:text-2xl">Actividad en vivo y lotes</h2>
        <p class="nauka-ui-display text-xs font-medium text-[#5c6569] md:text-sm">
          Detalle de acciones (24 h). <span id="live-updated-label" class="text-[#3d5c4a]"></span>
        </p>
      </div>
      <button
        type="button"
        id="live-refresh-btn"
        class="nauka-ui-display h-9 shrink-0 rounded-full border border-[#213138]/12 bg-white/80 px-4 text-xs font-semibold text-[#213138] backdrop-blur-md"
      >
        Actualizar ahora
      </button>
    </div>

    <div class="grid grid-cols-1 gap-8 xl:grid-cols-5 xl:gap-10">
      <div class="xl:col-span-3">
        <div class="nauka-glass-editorial overflow-hidden">
          <div class="max-h-[min(70vh,520px)] overflow-auto">
            <table class="nauka-ui-display w-full min-w-[860px] border-collapse text-left text-xs">
              <thead class="sticky top-0 z-[1] bg-white/90 backdrop-blur-md">
                <tr class="border-b border-[#213138]/[0.08] text-[0.6rem] font-semibold uppercase tracking-[0.12em] text-[#5c6569]">
                  <th class="whitespace-nowrap px-3 py-3">Cuándo</th>
                  <th class="px-3 py-3">Complejo</th>
                  <th class="px-3 py-3">Evento</th>
                  <th class="px-3 py-3">Visitante</th>
                  <th class="px-3 py-3">Lote</th>
                  <th class="px-3 py-3">Resultado</th>
                  <th class="px-3 py-3">Solicitante</th>
                  <th class="px-3 py-3">Guardia</th>
                  <th class="min-w-[8rem] px-3 py-3">Motivo / notas</th>
                  <th class="min-w-[7rem] px-3 py-3">Detalle</th>
                </tr>
              </thead>
              <tbody id="live-feed-body" class="divide-y divide-[#213138]/[0.06] text-[#213138]">
                {
                  movements.length === 0 ? (
                    <tr>
                      <td colspan="10" class="px-3 py-8 text-center text-sm text-[#5c6569]">
                        Sin movimientos en las últimas 24 h.
                      </td>
                    </tr>
                  ) : (
                    movements.map((row) => (
                      <tr class="align-top transition hover:bg-[#213138]/[0.02]">
                        <td class="whitespace-nowrap px-3 py-2.5 text-[#5c6569]">{new Date(row.created_at).toLocaleString("es-MX")}</td>
                        <td class="px-3 py-2.5">{row.complejo_id}</td>
                        <td class="px-3 py-2.5">{tipoMovimientoLabel(row.tipo_evento)}</td>
                        <td class="px-3 py-2.5 font-medium">{row.visitante_nombre ?? "—"}</td>
                        <td class="px-3 py-2.5">{row.lote_number ?? "—"}</td>
                        <td class="px-3 py-2.5">{row.resultado}</td>
                        <td class="px-3 py-2.5">{row.solicitante_nombre ?? "—"}</td>
                        <td class="px-3 py-2.5">{row.guardia_nombre ?? "—"}</td>
                        <td class="max-w-[14rem] px-3 py-2.5 text-[#5c6569]">
                          {(row.motivo ?? row.notas ?? row.razon ?? "—") as string}
                        </td>
                        <td class="px-3 py-2.5">
                          <a
                            href={`/admin/detalle-movimiento?id=${encodeURIComponent(row.id)}`}
                            class="font-semibold text-[#3d5c4a] underline decoration-[#3d5c4a]/30 underline-offset-2"
                          >
                            Ver
                          </a>
                        </td>
                      </tr>
                    ))
                  )
                }
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div id="kpi-lotes" class="xl:col-span-2">
        <h3 class="nauka-ui-display text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-[#5c6569]">Por lote · 24 h</h3>
        <p class="nauka-ui-display mt-1 text-xs text-[#5c6569]">Intensidad en bitácora y última acción por lote catalogado.</p>
        <ul id="lote-kpi-list" class="mt-4 space-y-4">
          {
            lotesCatalog.length === 0 && lotKpis.length === 0 ? (
              <li class="nauka-ui-display nauka-glass-editorial p-4 text-sm text-[#5c6569]">Aún no hay lotes registrados ni actividad reciente.</li>
            ) : (
              <>
                {lotesCatalog.map((lot) => {
                  const k = lotKpis.find((x) => x.complejo_id === lot.complejo_id && (x.lot_number ?? "") === lot.lot_number);
                  const count = k?.count24h ?? 0;
                  const pct = Math.round((count / maxLoteCount) * 100);
                  return (
                    <li class="nauka-glass-editorial px-4 py-4">
                      <div class="flex items-start justify-between gap-2">
                        <div>
                          <p class="nauka-ui-display text-sm font-semibold text-[#213138]">
                            Lote {lot.lot_number}
                            <span class="font-normal text-[#5c6569]"> · {lot.complejo_id}</span>
                          </p>
                          {lot.owner_name && <p class="nauka-ui-display text-xs text-[#5c6569]">Titular: {lot.owner_name}</p>}
                          <p class="nauka-ui-display text-xs text-[#3d5c4a]">Responsable: {lot.responsable_nombre ?? "Sin asignar"}</p>
                        </div>
                        <span class="nauka-ui-display tabular-nums text-lg font-semibold text-[#213138]">{count}</span>
                      </div>
                      <div class="mt-3 h-2 overflow-hidden rounded-full bg-[#213138]/[0.06]">
                        <div
                          class="h-full rounded-full bg-gradient-to-r from-[#3d5c4a]/35 to-[#3d5c4a]/70 transition-all duration-[400ms] ease-out"
                          style={`width: ${pct}%`}
                        />
                      </div>
                      {k && (
                        <p class="nauka-ui-display mt-2 text-[0.7rem] leading-snug text-[#5c6569]">
                          Último: {new Date(k.lastAt).toLocaleString("es-MX")} — {k.lastSummary}
                        </p>
                      )}
                    </li>
                  );
                })}
                {lotKpis
                  .filter((k) => !lotesCatalog.some((l) => l.complejo_id === k.complejo_id && l.lot_number === (k.lot_number ?? "")))
                  .map((k) => {
                    const pct = Math.round((k.count24h / maxLoteCount) * 100);
                    return (
                      <li class="nauka-glass-editorial border border-dashed border-[#213138]/10 px-4 py-4">
                        <div class="flex items-start justify-between gap-2">
                          <p class="nauka-ui-display text-sm font-semibold text-[#213138]">
                            {k.lot_number ?? "Sin lote"} <span class="font-normal text-[#5c6569]">· {k.complejo_id}</span>
                            <span class="ml-1 text-[0.65rem] font-normal uppercase tracking-wider text-[#9a6b5c]">No catalogado</span>
                          </p>
                          <span class="nauka-ui-display tabular-nums text-lg font-semibold">{k.count24h}</span>
                        </div>
                        <div class="mt-3 h-2 overflow-hidden rounded-full bg-[#213138]/[0.06]">
                          <div class="h-full rounded-full bg-gradient-to-r from-[#9a6b5c]/25 to-[#9a6b5c]/55" style={`width: ${pct}%`} />
                        </div>
                        <p class="nauka-ui-display mt-2 text-[0.7rem] text-[#5c6569]">
                          Último: {new Date(k.lastAt).toLocaleString("es-MX")} — {k.lastSummary}
                        </p>
                      </li>
                    );
                  })}
              </>
            )
          }
        </ul>
      </div>
    </div>
  </section>

  <section id="alta-lote" class="nauka-glass-editorial mt-12 p-5 md:mt-16 md:p-7">
    <h2 class="font-display text-xl text-[#213138]">Registrar o actualizar lote</h2>
    <p class="nauka-ui-display mt-2 text-sm text-[#5c6569]">
      Catálogo y responsable (solicitante). Si el lote existe, se actualiza titular y responsable.
    </p>
    <form id="lote-form" class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2">
      <label class="block md:col-span-2">
        <span class="nauka-label-lux">Complejo</span>
        <select name="complejo_id" class="nauka-input-lux text-sm" required>
          {complejos.map((c) => (
            <option value={c.id}>
              {c.nombre} ({c.id})
            </option>
          ))}
        </select>
      </label>
      <label class="block">
        <span class="nauka-label-lux">Número de lote</span>
        <input name="lot_number" type="text" required class="nauka-input-lux text-sm" placeholder="Ej. A-22" />
      </label>
      <label class="block">
        <span class="nauka-label-lux">Titular (opcional)</span>
        <input name="owner_name" type="text" class="nauka-input-lux text-sm" placeholder="Nombre en expediente" />
      </label>
      <label class="block md:col-span-2">
        <span class="nauka-label-lux">Responsable (solicitante)</span>
        <select name="responsable_profile_id" class="nauka-input-lux text-sm">
          <option value="">— Sin asignar —</option>
          {solicitantes.map((s) => (
            <option value={s.id}>
              {(s.full_name ?? s.id).slice(0, 48)}
              {s.lot_number ? ` · lote ${s.lot_number}` : ""} · {s.complejo_id}
            </option>
          ))}
        </select>
      </label>
      <div class="md:col-span-2">
        <button type="submit" class="nauka-btn-primary h-11 rounded-2xl px-6 text-sm font-semibold">Guardar lote</button>
        <p id="lote-form-msg" class="nauka-ui-display mt-3 hidden text-sm text-[#3d5c4a]"></p>
      </div>
    </form>
  </section>

  <section class="mt-14 md:mt-20">
    <div class="max-w-xl">
      <h2 class="font-display text-2xl tracking-[-0.02em] text-[#213138] md:text-3xl">Pases recientes</h2>
      <p class="nauka-ui-display mt-2 text-sm font-medium leading-relaxed text-[#5c6569]">Altas de visita — vista global.</p>
    </div>

    {
      pasesRecientes.length === 0 ? (
        <p class="nauka-ui-display mt-8 rounded-3xl border border-dashed border-[#213138]/12 bg-[#F9F8F6]/80 py-8 text-center text-sm text-[#5c6569]">
          Sin pases recientes.
        </p>
      ) : (
        <div class="relative mt-10 md:mt-12">
          <div class="absolute bottom-0 left-[15px] top-2 w-px bg-[#213138]/10 md:left-[19px]" aria-hidden="true" />
          <ul class="space-y-0">
            {pasesRecientes.map((p, i) => {
              const isLead = i === 0;
              const isWarm = i < 3;
              const nameCls = isLead
                ? "text-[1.35rem] font-semibold leading-snug text-[#213138] md:text-[1.6rem]"
                : isWarm
                  ? "text-lg font-semibold text-[#213138]"
                  : "text-base font-semibold text-[#213138]/90";
              const padCls = isLead ? "p-6 md:p-8" : isWarm ? "p-5 md:p-6" : "p-4 md:p-5";
              const widthCls = isLead ? "max-w-2xl" : isWarm ? "max-w-xl" : "max-w-lg";
              return (
                <li class:list={["relative pl-10 md:pl-12", i < pasesRecientes.length - 1 ? "pb-12 md:pb-14" : "pb-2"]}>
                  <span
                    class:list={[
                      "absolute rounded-full border border-[#213138]/20 bg-[#F9F8F6] ring-4 ring-[#F9F8F6]/90",
                      isLead ? "left-[9px] top-3 size-3 md:left-[13px]" : "left-[10px] top-2.5 size-2.5 md:left-[14px]"
                    ]}
                    aria-hidden="true"
                  />
                  <article class:list={["nauka-glass-editorial nauka-ui-display transition duration-[400ms] ease-in-out", padCls, widthCls, !isLead && "opacity-[0.94]"]}>
                    <p class:list={[nameCls]}>{p.visitante_nombre}</p>
                    <p class="mt-2 text-sm font-medium text-[#5c6569]">
                      {p.motivo ?? "—"} · {p.estado}
                      {p.complejo_id ? ` · ${p.complejo_id}` : ""}
                    </p>
                    <p class="mt-2 text-xs font-medium tracking-wide text-[#5c6569]/90">
                      {p.solicitante_nombre ?? "—"} · {new Date(p.created_at).toLocaleString("es-MX")}
                    </p>
                  </article>
                </li>
              );
            })}
          </ul>
        </div>
      )
    }
  </section>

  <section class="mt-14 md:mt-20">
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-xl">
        <h2 class="font-display text-2xl tracking-[-0.02em] text-[#213138] md:text-3xl">Actividad en caseta</h2>
        <p class="nauka-ui-display mt-2 text-sm font-medium text-[#5c6569]">Últimos registros en bitácora (todos los complejos).</p>
      </div>
      <a href="/admin/bitacora" class="nauka-btn-primary inline-flex h-11 shrink-0 items-center justify-center rounded-2xl px-6 text-sm font-semibold">
        Ver bitácora completa
      </a>
    </div>

    {
      movimientos.length === 0 ? (
        <p class="nauka-ui-display nauka-glass-editorial p-6 text-sm leading-relaxed text-[#5c6569]">
          Aún no hay registros recientes. Cuando un guardia valide un QR o registre movimiento, aparecerán aquí.
        </p>
      ) : (
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          {movimientos.map((row) => (
            <a
              href={`/admin/detalle-movimiento?id=${encodeURIComponent(row.id)}`}
              class:list={[
                "nauka-glass-editorial nauka-ui-display flex flex-col p-5 transition duration-[400ms] ease-in-out hover:-translate-y-0.5",
                row.resultado === "rechazado" ? "bg-[rgba(255,255,255,0.72)]" : ""
              ]}
            >
              <div class="flex items-start justify-between gap-2">
                <span class="text-[0.6rem] font-semibold uppercase tracking-[0.18em] text-[#5c6569]">{tipoMovimientoLabel(row.tipo_evento)}</span>
                <span class="text-xs font-medium text-[#5c6569]">{new Date(row.created_at).toLocaleString("es-MX")}</span>
              </div>
              {row.complejo_id && <p class="mt-1 text-xs font-medium text-[#213138]/70">Complejo: {row.complejo_id}</p>}
              <p class="mt-3 text-lg font-semibold text-[#213138]">{row.visitante_nombre ?? "Sin nombre"}</p>
              <p class="mt-1 text-sm font-medium text-[#5c6569]">
                {row.resultado === "rechazado" ? "Rechazado" : "Autorizado"}
                {row.lote_number ? ` · Lote ${row.lote_number}` : ""}
                {row.razon ? ` · ${row.razon}` : ""}
              </p>
              <p class="mt-2 text-xs text-[#5c6569]">
                Solicitante: {row.solicitante_nombre ?? "—"} · Motivo: {row.motivo ?? "—"}
              </p>
            </a>
          ))}
        </div>
      )
    }
  </section>

  <section id="incidentes" class="mt-16 space-y-6 md:mt-20">
    <h2 class="font-display text-2xl tracking-[-0.02em] text-[#213138] md:text-3xl">Incidentes</h2>
    {(incidentes ?? []).length === 0 && (
      <p class="nauka-ui-display nauka-glass-editorial p-5 text-sm text-[#5c6569]">Sin incidentes registrados.</p>
    )}
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {(incidentes ?? []).map((item) => (
        <article class="nauka-glass-editorial nauka-ui-display p-6">
          <div class="flex items-center justify-between gap-2">
            <p class="text-[0.6rem] font-semibold uppercase tracking-[0.18em] text-[#5c6569]">{item.severidad}</p>
            <p class="text-xs font-medium text-[#5c6569]">{new Date(item.created_at).toLocaleString("es-MX")}</p>
          </div>
          <p class="mt-3 text-base font-semibold text-[#213138]">{item.descripcion}</p>
          <p class="mt-2 text-sm font-medium text-[#5c6569]">
            Visitante: {item.visitante_nombre ?? "N/A"} · Estado: {item.estado}
          </p>
        </article>
      ))}
    </div>
  </section>

  <section id="alta-solicitante" class="nauka-glass-editorial mt-12 p-5 md:p-7">
    <h2 class="font-display text-xl text-[#213138]">Crear solicitante</h2>
    <p class="nauka-ui-display mt-2 text-sm leading-relaxed text-[#5c6569]">Foto e INE obligatorios.</p>
    <form id="solicitante-form" class="mt-4 space-y-4" enctype="multipart/form-data">
      <input type="hidden" name="role" value="solicitante" />
      <input name="email" type="email" required placeholder="Correo" class="nauka-input-lux text-sm" />
      <input name="full_name" type="text" required placeholder="Nombre completo" class="nauka-input-lux text-sm" />
      <input name="lot_number" type="text" required placeholder="Lote" class="nauka-input-lux text-sm" />
      <input name="complejo_id" type="text" value="complejo-1" class="nauka-input-lux text-sm" />
      <label class="block text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-[#5c6569]">
        Foto (obligatorio)
        <input name="photo" type="file" accept="image/jpeg,image/png" required class="mt-2 w-full text-sm font-normal normal-case tracking-normal" />
      </label>
      <label class="block text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-[#5c6569]">
        INE (obligatorio)
        <input name="ine" type="file" accept="image/jpeg,image/png" required class="mt-2 w-full text-sm font-normal normal-case tracking-normal" />
      </label>
      <button type="submit" class="nauka-btn-primary h-12 w-full rounded-2xl text-sm font-semibold">Crear solicitante</button>
    </form>
    <pre id="solicitante-result" class="mt-3 hidden whitespace-pre-wrap rounded-2xl border border-[#213138]/[0.06] bg-[#213138]/[0.03] p-3 text-xs"></pre>
  </section>

  <section id="alta-personal" class="nauka-glass-editorial mt-8 p-5 md:p-7">
    <h2 class="font-display text-xl text-[#213138]">Invitar guardia o administrador</h2>
    <p class="nauka-ui-display mt-2 text-sm text-[#5c6569]">INE opcional.</p>
    <form id="staff-invite-form" class="mt-4 space-y-4" enctype="multipart/form-data">
      <input name="email" type="email" required placeholder="correo@ejemplo.com" class="nauka-input-lux text-sm" />
      <input name="full_name" type="text" required placeholder="Nombre completo" class="nauka-input-lux text-sm" />
      <input name="lot_number" type="text" required placeholder="Lote o identificador" class="nauka-input-lux text-sm" />
      <input name="complejo_id" type="text" value="complejo-1" class="nauka-input-lux text-sm" />
      <select name="role" class="nauka-input-lux text-sm" required>
        <option value="guardia">Guardia</option>
        <option value="admin">Administrador</option>
      </select>
      <label class="block text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-[#5c6569]">
        INE (opcional)
        <input name="ine" type="file" accept="image/jpeg,image/png" class="mt-2 w-full text-sm font-normal normal-case tracking-normal" />
      </label>
      <button type="submit" class="nauka-btn-primary h-12 w-full rounded-2xl text-sm font-semibold">Crear usuario</button>
    </form>
    <pre id="staff-invite-result" class="mt-3 hidden whitespace-pre-wrap rounded-2xl border border-[#213138]/[0.06] bg-[#213138]/[0.03] p-3 text-xs"></pre>
  </section>

  <section class="mt-10 space-y-2">
    <h2 class="font-display text-xl text-[#213138]">Perfiles recientes</h2>
    {(profiles ?? []).map((p) => (
      <div class="nauka-glass-editorial flex flex-wrap items-center justify-between gap-2 p-3 text-sm">
        <div>
          <p class="font-semibold text-[#213138]">{p.full_name ?? p.id}</p>
          <p class="text-[#5c6569]">
            {p.role} · {p.complejo_id} · lote {p.lot_number ?? "—"} · {p.onboarding_status}
          </p>
          {p.role === "solicitante" && (
            <p class="mt-1 text-xs text-[#5c6569]">
              Expediente: foto {p.photo_storage_path ? "✓" : "—"} · INE {p.ine_storage_path ? "✓" : "—"}
            </p>
          )}
        </div>
        {p.onboarding_status !== "activo" && (
          <button
            type="button"
            data-approve-id={p.id}
            class="approve-btn rounded-full border border-[#3d5c4a]/20 bg-[rgba(61,92,74,0.1)] px-3 py-2 text-xs font-semibold text-[#3d5c4a] transition duration-[400ms] ease-in-out hover:bg-[rgba(61,92,74,0.16)]"
          >
            Marcar activo
          </button>
        )}
      </div>
    ))}
  </section>
</AppLayout>

<script is:inline>
  const bindInviteForm = (formId, resultId) => {
    const form = document.getElementById(formId);
    const result = document.getElementById(resultId);
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!(form instanceof HTMLFormElement)) return;
      const fd = new FormData(form);
      const res = await fetch("/api/super-admin/invite", { method: "POST", body: fd });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        alert(data.error ?? "Error al crear usuario");
        if (data.partial && data.userId && result) {
          result.classList.remove("hidden");
          result.textContent = JSON.stringify(data, null, 2);
        }
        return;
      }
      if (result) {
        result.classList.remove("hidden");
        result.textContent = JSON.stringify(data, null, 2);
      }
      alert("Usuario creado. Copia la contraseña temporal del recuadro.");
    });
  };
  bindInviteForm("solicitante-form", "solicitante-result");
  bindInviteForm("staff-invite-form", "staff-invite-result");

  document.querySelectorAll(".approve-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = btn.getAttribute("data-approve-id");
      if (!id) return;
      const res = await fetch("/api/super-admin/approve", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ userId: id })
      });
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        alert(data.error ?? "No se pudo aprobar");
        return;
      }
      window.location.reload();
    });
  });

  function esc(s) {
    if (s == null || s === undefined) return "";
    return String(s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function tipoLabel(t) {
    const v = String(t ?? "").toLowerCase();
    if (v === "entrada") return "Entrada";
    if (v === "salida") return "Salida";
    if (v === "validacion") return "Validación QR";
    if (v === "incidente") return "Incidente";
    return v ? v.toUpperCase() : "—";
  }

  function renderMovements(rows) {
    const tb = document.getElementById("live-feed-body");
    if (!tb) return;
    if (!rows.length) {
      tb.innerHTML = `<tr><td colspan="10" class="px-3 py-8 text-center text-sm text-[#5c6569]">Sin movimientos en las últimas 24 h.</td></tr>`;
      return;
    }
    tb.innerHTML = rows
      .map(
        (row) => `<tr class="align-top transition hover:bg-[#213138]/[0.02]">
        <td class="whitespace-nowrap px-3 py-2.5 text-[#5c6569]">${esc(new Date(row.created_at).toLocaleString("es-MX"))}</td>
        <td class="px-3 py-2.5">${esc(row.complejo_id)}</td>
        <td class="px-3 py-2.5">${esc(tipoLabel(row.tipo_evento))}</td>
        <td class="px-3 py-2.5 font-medium">${esc(row.visitante_nombre ?? "—")}</td>
        <td class="px-3 py-2.5">${esc(row.lote_number ?? "—")}</td>
        <td class="px-3 py-2.5">${esc(row.resultado)}</td>
        <td class="px-3 py-2.5">${esc(row.solicitante_nombre ?? "—")}</td>
        <td class="px-3 py-2.5">${esc(row.guardia_nombre ?? "—")}</td>
        <td class="max-w-[14rem] px-3 py-2.5 text-[#5c6569]">${esc(row.motivo ?? row.notas ?? row.razon ?? "—")}</td>
        <td class="px-3 py-2.5"><a href="/admin/detalle-movimiento?id=${encodeURIComponent(row.id)}" class="font-semibold text-[#3d5c4a] underline decoration-[#3d5c4a]/30 underline-offset-2">Ver</a></td>
      </tr>`
      )
      .join("");
  }

  function renderLoteKpis(lotKpis, lotesCatalog) {
    const ul = document.getElementById("lote-kpi-list");
    if (!ul) return;
    const maxC = Math.max(...lotKpis.map((k) => k.count24h), 1);
    const blocks = [];
    const findK = (cid, lotNum) => lotKpis.find((x) => x.complejo_id === cid && (x.lot_number ?? "") === lotNum);
    for (const lot of lotesCatalog) {
      const k = findK(lot.complejo_id, lot.lot_number);
      const count = k ? k.count24h : 0;
      const pct = Math.round((count / maxC) * 100);
      const last = k
        ? `<p class="nauka-ui-display mt-2 text-[0.7rem] leading-snug text-[#5c6569]">Último: ${esc(new Date(k.lastAt).toLocaleString("es-MX"))} — ${esc(k.lastSummary)}</p>`
        : "";
      blocks.push(`<li class="nauka-glass-editorial px-4 py-4">
        <div class="flex items-start justify-between gap-2">
          <div>
            <p class="nauka-ui-display text-sm font-semibold text-[#213138]">Lote ${esc(lot.lot_number)} <span class="font-normal text-[#5c6569]"> · ${esc(lot.complejo_id)}</span></p>
            ${lot.owner_name ? `<p class="nauka-ui-display text-xs text-[#5c6569]">Titular: ${esc(lot.owner_name)}</p>` : ""}
            <p class="nauka-ui-display text-xs text-[#3d5c4a]">Responsable: ${esc(lot.responsable_nombre ?? "Sin asignar")}</p>
          </div>
          <span class="nauka-ui-display tabular-nums text-lg font-semibold text-[#213138]">${count}</span>
        </div>
        <div class="mt-3 h-2 overflow-hidden rounded-full bg-[#213138]/[0.06]">
          <div class="h-full rounded-full bg-gradient-to-r from-[#3d5c4a]/35 to-[#3d5c4a]/70" style="width:${pct}%"></div>
        </div>
        ${last}
      </li>`);
    }
    const catalogKeys = new Set(lotesCatalog.map((l) => `${l.complejo_id}::${l.lot_number}`));
    for (const k of lotKpis) {
      const key = `${k.complejo_id}::${k.lot_number ?? ""}`;
      if (catalogKeys.has(key)) continue;
      const pct = Math.round((k.count24h / maxC) * 100);
      blocks.push(`<li class="nauka-glass-editorial border border-dashed border-[#213138]/10 px-4 py-4">
        <div class="flex items-start justify-between gap-2">
          <p class="nauka-ui-display text-sm font-semibold text-[#213138]">${esc(k.lot_number ?? "Sin lote")} <span class="font-normal text-[#5c6569]">· ${esc(k.complejo_id)}</span>
            <span class="ml-1 text-[0.65rem] font-normal uppercase tracking-wider text-[#9a6b5c]">No catalogado</span></p>
          <span class="nauka-ui-display tabular-nums text-lg font-semibold">${k.count24h}</span>
        </div>
        <div class="mt-3 h-2 overflow-hidden rounded-full bg-[#213138]/[0.06]">
          <div class="h-full rounded-full bg-gradient-to-r from-[#9a6b5c]/25 to-[#9a6b5c]/55" style="width:${pct}%"></div>
        </div>
        <p class="nauka-ui-display mt-2 text-[0.7rem] text-[#5c6569]">Último: ${esc(new Date(k.lastAt).toLocaleString("es-MX"))} — ${esc(k.lastSummary)}</p>
      </li>`);
    }
    if (!blocks.length) {
      ul.innerHTML = `<li class="nauka-ui-display nauka-glass-editorial p-4 text-sm text-[#5c6569]">Aún no hay lotes registrados ni actividad reciente.</li>`;
    } else {
      ul.innerHTML = blocks.join("");
    }
  }

  async function refreshLive() {
    const res = await fetch("/api/super-admin/live");
    const label = document.getElementById("live-updated-label");
    if (!res.ok) {
      if (label) label.textContent = "No se pudo sincronizar.";
      return;
    }
    const data = await res.json();
    renderMovements(data.movements ?? []);
    renderLoteKpis(data.lotKpis ?? [], data.lotesCatalog ?? []);
    if (label && data.generatedAt) {
      const t = new Date(data.generatedAt).toLocaleTimeString("es-MX", { hour: "2-digit", minute: "2-digit", second: "2-digit" });
      label.textContent = `Sincronizado ${t}`;
    }
  }

  document.getElementById("live-refresh-btn")?.addEventListener("click", () => refreshLive());
  refreshLive();
  setInterval(refreshLive, 28000);

  document.getElementById("lote-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const form = e.target;
    if (!(form instanceof HTMLFormElement)) return;
    const msg = document.getElementById("lote-form-msg");
    const fd = new FormData(form);
    const body = {
      complejo_id: fd.get("complejo_id"),
      lot_number: fd.get("lot_number"),
      owner_name: fd.get("owner_name") || null,
      responsable_profile_id: fd.get("responsable_profile_id") || null
    };
    const res = await fetch("/api/super-admin/lotes", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body)
    });
    const data = await res.json().catch(() => ({}));
    if (!res.ok) {
      alert(data.error ?? "No se pudo guardar el lote");
      return;
    }
    if (msg) {
      msg.classList.remove("hidden");
      msg.textContent = "Lote guardado. Actualizando panel…";
    }
    await refreshLive();
    window.location.reload();
  });
</script>
