---
import AppLayout from "../../layouts/AppLayout.astro";
import AdminFlowChart from "../../components/AdminFlowChart.astro";
import { adminNav } from "../../lib/nav";
import { getAdminMetrics, getBitacoraByComplejo, getBitacoraScope, getRecentPassesForComplejo } from "../../lib/access";
import { getSupabaseServiceClient } from "../../lib/supabase";

const accessToken = Astro.locals.accessToken as string;
const profile = Astro.locals.profile;
const user = Astro.locals.user;
const complejoId = profile?.complejo_id ?? "complejo-1";
const isSuper = profile?.role === "super_admin";

const defaultMetrics = {
  totalMovimientos: 0,
  totalAutorizados: 0,
  totalRechazados: 0,
  incidentesAbiertos: 0
};

async function withTimeout<T>(promise: Promise<T>, ms: number, fallback: T): Promise<T> {
  let timeoutId: ReturnType<typeof setTimeout> | undefined;
  const timeoutPromise = new Promise<T>((resolve) => {
    timeoutId = setTimeout(() => resolve(fallback), ms);
  });
  const result = await Promise.race([promise, timeoutPromise]);
  if (timeoutId) clearTimeout(timeoutId);
  return result;
}

const metrics = await withTimeout(
  getAdminMetrics({
    accessToken,
    userId: user!.id,
    role: isSuper ? "super_admin" : "admin",
    complejoId,
    lotNumber: profile?.lot_number
  }),
  1200,
  defaultMetrics
);

const pasesRecientes = await withTimeout(
  (async () => {
    try {
      return await getRecentPassesForComplejo(isSuper ? null : complejoId, 12);
    } catch {
      return [] as Awaited<ReturnType<typeof getRecentPassesForComplejo>>;
    }
  })(),
  2000,
  []
);

const movimientos = await withTimeout(
  (async () => {
    try {
      if (isSuper) {
        return await getBitacoraScope({ allComplejos: true, limit: 40 });
      }
      return await getBitacoraByComplejo(complejoId, undefined, undefined, 40);
    } catch {
      return [] as Awaited<ReturnType<typeof getBitacoraByComplejo>>;
    }
  })(),
  2000,
  []
);

const incidentes = await withTimeout(
  (async () => {
    const svc = getSupabaseServiceClient();
    let q = svc
      .from("incidentes")
      .select("id, created_at, estado, descripcion, severidad, visitante_nombre")
      .order("created_at", { ascending: false })
      .limit(20);
    if (!isSuper) {
      q = q.eq("complejo_id", complejoId);
    }
    const { data } = await q;
    return data ?? [];
  })(),
  2000,
  [] as any[]
);

function tipoMovimientoLabel(t: string | null | undefined) {
  const v = (t ?? "").toLowerCase();
  if (v === "entrada") return "Entrada";
  if (v === "salida") return "Salida";
  if (v === "validacion") return "Validación QR";
  return v ? v.toUpperCase() : "Movimiento";
}
---

<AppLayout
  wide
  title="Dashboard Admin - Nauka Nayarit"
  topBar={{ title: "Nauka Nayarit", leftIcon: "shield", leftHref: "#", rightIcon: "logout", rightHref: "/api/auth/logout" }}
  navItems={adminNav}
  pageTitle="Bienvenido a Nauka"
>
  <p class="-mt-2 mb-1 font-display text-lg italic text-[#5c6569] md:text-xl">Monitoreo central</p>
  <p class="mb-8 text-sm leading-relaxed text-[#5c6569] md:mb-10">
    Métricas de las <strong class="font-medium text-[#213138]">últimas 24 horas</strong> — validaciones, entradas y salidas en bitácora.
    {isSuper && <span class="block md:inline md:pl-1">Vista global de complejos.</span>}
  </p>

  <section class="grid grid-cols-1 gap-3 lg:grid-cols-3 lg:gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:col-span-2 lg:grid-cols-2">
      <article class="nauka-card-aero p-5">
        <p class="text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-[#5c6569]">Movimientos · 24 h</p>
        <p class="mt-2 font-display text-3xl text-[#213138] md:text-4xl">{metrics.totalMovimientos}</p>
      </article>
      <article class="nauka-card-aero p-5">
        <p class="text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-[#5c6569]">Autorizados</p>
        <p class="mt-2 font-display text-3xl text-[#3d5c4a] md:text-4xl">{metrics.totalAutorizados}</p>
      </article>
      <article class="nauka-card-aero p-5">
        <p class="text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-[#5c6569]">Rechazados</p>
        <p class="mt-2 font-display text-3xl text-[#9a6b5c] md:text-4xl">{metrics.totalRechazados}</p>
      </article>
      <article class="nauka-card-aero p-5">
        <p class="text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-[#5c6569]">Incidentes abiertos</p>
        <p class="mt-2 font-display text-3xl text-[#213138] md:text-4xl">{metrics.incidentesAbiertos}</p>
      </article>
    </div>
    <div class="min-h-[200px] lg:col-span-1">
      <AdminFlowChart
        movimientos={metrics.totalMovimientos}
        autorizados={metrics.totalAutorizados}
        rechazados={metrics.totalRechazados}
        incidentes={metrics.incidentesAbiertos}
      />
    </div>
  </section>

  <section class="mt-10 md:mt-14">
    <h2 class="font-display text-xl text-[#213138] md:text-2xl">Pases creados por solicitantes</h2>
    <p class="mt-1 text-sm text-[#5c6569]">Alta de visitas en el sistema (no es la bitácora de caseta).</p>
    {pasesRecientes.length === 0 ? (
      <p class="mt-4 rounded-[20px] border border-dashed border-[#213138]/15 bg-[#FCFBF9] p-5 text-sm text-[#5c6569]">Sin pases recientes.</p>
    ) : (
      <ul class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-2 lg:grid-cols-3">
        {pasesRecientes.map((p) => (
          <li class="nauka-card-aero p-4 text-sm">
            <p class="font-semibold text-[#213138]">{p.visitante_nombre}</p>
            <p class="text-[#5f6368]">
              {p.motivo ?? "—"} · {p.estado}
              {isSuper && p.complejo_id ? ` · ${p.complejo_id}` : ""}
            </p>
            <p class="mt-1 text-xs text-[#5c6569]">
              Por: {p.solicitante_nombre ?? "—"} · {new Date(p.created_at).toLocaleString("es-MX")}
            </p>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="mt-10 md:mt-14">
    <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 class="font-display text-xl text-[#213138] md:text-2xl">Actividad reciente</h2>
        <p class="text-sm text-[#5c6569]">Escaneos del guardia, entradas y salidas en caseta.</p>
      </div>
      <a
        href="/admin/bitacora"
        class="nauka-btn-primary inline-flex h-11 shrink-0 items-center justify-center rounded-2xl px-5 text-sm font-semibold"
      >
        Ver bitácora completa
      </a>
    </div>

    {movimientos.length === 0 ? (
      <p class="rounded-[20px] border border-dashed border-[#213138]/15 bg-[#FCFBF9] p-6 text-sm leading-relaxed text-[#5c6569]">
        Aún no hay registros en bitácora para este periodo. Cuando un guardia valide un QR o registre entrada/salida, aparecerán aquí. Comprueba que el guardia tenga el mismo <strong>complejo</strong> en su perfil que los pases (
        {complejoId}).
      </p>
    ) : (
      <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
        {movimientos.map((row) => (
          <a
            href={`/admin/detalle-movimiento?id=${row.id}`}
            class:list={[
              "nauka-card-aero flex flex-col p-4 transition duration-[400ms] ease-in-out hover:-translate-y-0.5",
              row.resultado === "rechazado" ? "border-[#9a6b5c]/15 bg-gradient-to-br from-[#fdfaf9] to-[#f7f0ec]" : ""
            ]}
          >
            <div class="flex items-start justify-between gap-2">
              <span class="text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-[#5c6569]">{tipoMovimientoLabel(row.tipo_evento)}</span>
              <span class="text-xs text-[#5c6569]">{new Date(row.created_at).toLocaleString("es-MX")}</span>
            </div>
            {isSuper && row.complejo_id && <p class="mt-1 text-xs font-medium text-[#213138]/75">Complejo: {row.complejo_id}</p>}
            <p class="mt-2 text-lg font-medium text-[#213138]">{row.visitante_nombre ?? "Sin nombre"}</p>
            <p class="text-sm text-[#5c6569]">
              {row.resultado === "rechazado" ? "Rechazado" : "Autorizado"}
              {row.lote_number ? ` · Lote ${row.lote_number}` : ""}
              {row.razon ? ` · ${row.razon}` : ""}
            </p>
            <p class="mt-1 text-xs text-[#5c6569]">
              Solicitante: {row.solicitante_nombre ?? "—"} · Motivo: {row.motivo ?? "—"}
            </p>
          </a>
        ))}
      </div>
    )}
  </section>

  <section id="incidentes" class="mt-12 space-y-4 md:mt-16">
    <h2 class="font-display text-xl text-[#213138] md:text-2xl">Gestión de incidentes</h2>
    {(incidentes ?? []).length === 0 && <p class="nauka-card-aero p-4 text-sm text-[#5c6569]">Sin incidentes registrados.</p>}
    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      {(incidentes ?? []).map((item) => (
        <article class="nauka-card-aero p-5">
          <div class="flex items-center justify-between gap-2">
            <p class="text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-[#5c6569]">{item.severidad}</p>
            <p class="text-xs text-[#5c6569]">{new Date(item.created_at).toLocaleString("es-MX")}</p>
          </div>
          <p class="mt-2 text-base font-medium text-[#213138]">{item.descripcion}</p>
          <p class="mt-1 text-sm text-[#5c6569]">Visitante: {item.visitante_nombre ?? "N/A"} · Estado: {item.estado}</p>
        </article>
      ))}
    </div>
  </section>
</AppLayout>
