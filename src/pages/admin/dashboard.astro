---
import AppLayout from "../../layouts/AppLayout.astro";
import { adminNav } from "../../lib/nav";
import { getAdminMetrics, getBitacoraByComplejo, getBitacoraScope, getRecentPassesForComplejo } from "../../lib/access";
import { getSupabaseServiceClient } from "../../lib/supabase";

const accessToken = Astro.locals.accessToken as string;
const profile = Astro.locals.profile;
const user = Astro.locals.user;
const complejoId = profile?.complejo_id ?? "complejo-1";
const isSuper = profile?.role === "super_admin";

const defaultMetrics = {
  totalMovimientos: 0,
  totalAutorizados: 0,
  totalRechazados: 0,
  incidentesAbiertos: 0
};

async function withTimeout<T>(promise: Promise<T>, ms: number, fallback: T): Promise<T> {
  let timeoutId: ReturnType<typeof setTimeout> | undefined;
  const timeoutPromise = new Promise<T>((resolve) => {
    timeoutId = setTimeout(() => resolve(fallback), ms);
  });
  const result = await Promise.race([promise, timeoutPromise]);
  if (timeoutId) clearTimeout(timeoutId);
  return result;
}

const metrics = await withTimeout(
  getAdminMetrics({
    accessToken,
    userId: user!.id,
    role: isSuper ? "super_admin" : "admin",
    complejoId,
    lotNumber: profile?.lot_number
  }),
  1200,
  defaultMetrics
);

const pasesRecientes = await withTimeout(
  (async () => {
    try {
      return await getRecentPassesForComplejo(isSuper ? null : complejoId, 12);
    } catch {
      return [] as Awaited<ReturnType<typeof getRecentPassesForComplejo>>;
    }
  })(),
  2000,
  []
);

const movimientos = await withTimeout(
  (async () => {
    try {
      if (isSuper) {
        return await getBitacoraScope({ allComplejos: true, limit: 40 });
      }
      return await getBitacoraByComplejo(complejoId, undefined, undefined, 40);
    } catch {
      return [] as Awaited<ReturnType<typeof getBitacoraByComplejo>>;
    }
  })(),
  2000,
  []
);

const incidentes = await withTimeout(
  (async () => {
    const svc = getSupabaseServiceClient();
    let q = svc
      .from("incidentes")
      .select("id, created_at, estado, descripcion, severidad, visitante_nombre")
      .order("created_at", { ascending: false })
      .limit(20);
    if (!isSuper) {
      q = q.eq("complejo_id", complejoId);
    }
    const { data } = await q;
    return data ?? [];
  })(),
  2000,
  [] as any[]
);

function tipoMovimientoLabel(t: string | null | undefined) {
  const v = (t ?? "").toLowerCase();
  if (v === "entrada") return "Entrada";
  if (v === "salida") return "Salida";
  if (v === "validacion") return "Validación QR";
  return v ? v.toUpperCase() : "Movimiento";
}
---

<AppLayout
  wide
  title="Dashboard Admin - Nauka Nayarit"
  topBar={{ title: "Nauka Nayarit", leftIcon: "shield", leftHref: "#", rightIcon: "logout", rightHref: "/api/auth/logout" }}
  navItems={adminNav}
  pageTitle="Monitoreo central"
>
  <p class="-mt-4 mb-6 text-sm text-[#5f6368] md:-mt-2">
    Métricas de las <strong>últimas 24 horas</strong> (validaciones, entradas y salidas registradas en bitácora).
    {isSuper && <span class="block md:inline md:pl-1">Vista global de todos los complejos.</span>}
  </p>

  <section class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
    <article class="rounded-xl bg-white p-4 shadow-[0_6px_18px_rgba(26,28,28,0.04)]">
      <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#64748b]">Movimientos (24 h)</p>
      <p class="mt-2 text-3xl font-extrabold text-[#213138] md:text-4xl">{metrics.totalMovimientos}</p>
    </article>
    <article class="rounded-xl bg-white p-4 shadow-[0_6px_18px_rgba(26,28,28,0.04)]">
      <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#64748b]">Autorizados</p>
      <p class="mt-2 text-3xl font-extrabold text-[#006d36] md:text-4xl">{metrics.totalAutorizados}</p>
    </article>
    <article class="rounded-xl bg-white p-4 shadow-[0_6px_18px_rgba(26,28,28,0.04)]">
      <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#64748b]">Rechazados</p>
      <p class="mt-2 text-3xl font-extrabold text-[#93000a] md:text-4xl">{metrics.totalRechazados}</p>
    </article>
    <article class="rounded-xl bg-white p-4 shadow-[0_6px_18px_rgba(26,28,28,0.04)]">
      <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#64748b]">Incidentes abiertos</p>
      <p class="mt-2 text-3xl font-extrabold text-[#213138] md:text-4xl">{metrics.incidentesAbiertos}</p>
    </article>
  </section>

  <section class="mt-8 md:mt-10">
    <h2 class="text-xl font-bold text-[#213138] md:text-2xl">Pases creados por solicitantes</h2>
    <p class="mt-1 text-sm text-[#5f6368]">Alta de visitas en el sistema (no es la bitácora de caseta).</p>
    {pasesRecientes.length === 0 ? (
      <p class="mt-3 rounded-xl border border-dashed border-[#cfd4d9] bg-white/80 p-4 text-sm text-[#5f6368]">Sin pases recientes.</p>
    ) : (
      <ul class="mt-3 grid grid-cols-1 gap-2 md:grid-cols-2 lg:grid-cols-3">
        {pasesRecientes.map((p) => (
          <li class="rounded-xl bg-white p-4 text-sm shadow-[0_6px_18px_rgba(26,28,28,0.04)]">
            <p class="font-semibold text-[#213138]">{p.visitante_nombre}</p>
            <p class="text-[#5f6368]">
              {p.motivo ?? "—"} · {p.estado}
              {isSuper && p.complejo_id ? ` · ${p.complejo_id}` : ""}
            </p>
            <p class="mt-1 text-xs text-[#64748b]">
              Por: {p.solicitante_nombre ?? "—"} · {new Date(p.created_at).toLocaleString("es-MX")}
            </p>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="mt-8 md:mt-10">
    <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 class="text-xl font-bold text-[#213138] md:text-2xl">Actividad reciente</h2>
        <p class="text-sm text-[#5f6368]">Escaneos del guardia, entradas/salidas en caseta y validaciones.</p>
      </div>
      <a
        href="/admin/bitacora"
        class="inline-flex h-10 shrink-0 items-center justify-center rounded-xl bg-[#213138] px-4 text-sm font-semibold text-white md:h-11"
      >
        Ver bitácora completa
      </a>
    </div>

    {movimientos.length === 0 ? (
      <p class="rounded-xl border border-dashed border-[#cfd4d9] bg-white/80 p-6 text-sm text-[#5f6368]">
        Aún no hay registros en bitácora para este periodo. Cuando un guardia valide un QR o registre entrada/salida, aparecerán aquí. Comprueba que el guardia tenga el mismo <strong>complejo</strong> en su perfil que los pases (
        {complejoId}).
      </p>
    ) : (
      <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
        {movimientos.map((row) => (
          <a
            href={`/admin/detalle-movimiento?id=${row.id}`}
            class:list={[
              "flex flex-col rounded-xl border border-transparent p-4 shadow-[0_6px_18px_rgba(26,28,28,0.06)] transition hover:border-[#213138]/15",
              row.resultado === "rechazado" ? "bg-[#ffdad6]/30" : "bg-white"
            ]}
          >
            <div class="flex items-start justify-between gap-2">
              <span class="text-xs font-bold uppercase tracking-[0.08em] text-[#64748b]">{tipoMovimientoLabel(row.tipo_evento)}</span>
              <span class="text-xs text-[#64748b]">{new Date(row.created_at).toLocaleString("es-MX")}</span>
            </div>
            {isSuper && row.complejo_id && <p class="mt-1 text-xs font-semibold text-[#213138]/80">Complejo: {row.complejo_id}</p>}
            <p class="mt-2 text-lg font-semibold text-[#213138]">{row.visitante_nombre ?? "Sin nombre"}</p>
            <p class="text-sm text-[#5f6368]">
              {row.resultado === "rechazado" ? "Rechazado" : "Autorizado"}
              {row.lote_number ? ` · Lote ${row.lote_number}` : ""}
              {row.razon ? ` · ${row.razon}` : ""}
            </p>
            <p class="mt-1 text-xs text-[#5f6368]">
              Solicitante: {row.solicitante_nombre ?? "—"} · Motivo: {row.motivo ?? "—"}
            </p>
          </a>
        ))}
      </div>
    )}
  </section>

  <section id="incidentes" class="mt-10 space-y-3 md:mt-12">
    <h2 class="text-xl font-bold text-[#213138] md:text-2xl">Gestión de incidentes</h2>
    {(incidentes ?? []).length === 0 && <p class="rounded-xl bg-white p-4 text-sm text-[#64748b]">Sin incidentes registrados.</p>}
    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      {(incidentes ?? []).map((item) => (
        <article class="rounded-xl bg-white p-4 shadow-[0_6px_18px_rgba(26,28,28,0.04)]">
          <div class="flex items-center justify-between gap-2">
            <p class="text-sm font-semibold uppercase tracking-[0.08em] text-[#64748b]">{item.severidad}</p>
            <p class="text-xs text-[#64748b]">{new Date(item.created_at).toLocaleString("es-MX")}</p>
          </div>
          <p class="mt-2 text-base font-semibold text-[#213138]">{item.descripcion}</p>
          <p class="mt-1 text-sm text-[#64748b]">Visitante: {item.visitante_nombre ?? "N/A"} · Estado: {item.estado}</p>
        </article>
      ))}
    </div>
  </section>
</AppLayout>
