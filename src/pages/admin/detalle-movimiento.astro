---
import AppLayout from "../../layouts/AppLayout.astro";
import { getSupabaseServiceClient } from "../../lib/supabase";
const id = Astro.url.searchParams.get("id");
const supabase = getSupabaseServiceClient();
const { data: row } = id
  ? await supabase
      .from("bitacora_accesos")
      .select("id, created_at, visitante_nombre, resultado, tipo_evento, razon, lote_number, origen, token_qr, pase_id, guardia_id")
      .eq("id", id)
      .maybeSingle()
  : { data: null };
const { data: pass } = row?.pase_id
  ? await supabase.from("pases_acceso").select("id, creado_por, motivo, notas, created_at").eq("id", row.pase_id).maybeSingle()
  : { data: null };
const { data: residenteProfile } = pass?.creado_por
  ? await supabase.from("profiles").select("id, full_name, lot_number").eq("id", pass.creado_por).maybeSingle()
  : { data: null };
const { data: guardiaProfile } = row?.guardia_id
  ? await supabase.from("profiles").select("id, full_name").eq("id", row.guardia_id).maybeSingle()
  : { data: null };
---

<AppLayout
  title="Detalle de Movimiento - Nauka Nayarit"
  topBar={{ title: "Nauka Nayarit", leftIcon: "arrow_back", leftHref: "/admin/bitacora", rightIcon: "more_vert", rightHref: "#" }}
>
  <div class={`mb-5 flex items-center gap-2 ${row?.resultado === "rechazado" ? "text-[#93000a]" : "text-[#006d36]"}`}>
    <span class="material-symbols-outlined">check_circle</span>
    <span class="text-xs font-bold uppercase tracking-[0.08em]">{row?.resultado === "rechazado" ? "Acceso rechazado" : "Acceso completado"}</span>
  </div>
  <h1 class="text-6xl font-extrabold tracking-[-0.02em] text-[#213138]">{row?.visitante_nombre ?? "Registro"}</h1>
  <p class="mt-2 text-3xl text-[#43474a]">{(row?.tipo_evento ?? "movimiento").toUpperCase()} · {row?.lote_number ?? "Sin lote"}</p>

  <section class="mt-6 space-y-4">
    <article class="rounded-[14px] bg-white p-5 shadow-[0_8px_24px_rgba(26,28,28,0.05)]">
      <h2 class="mb-4 text-3xl font-semibold text-[#213138]">Registro de Tiempo</h2>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Hora de Entrada</p>
          <p class="mt-1 text-5xl font-bold text-[#213138]">
            {row ? new Date(row.created_at).toLocaleTimeString("es-MX", { hour: "2-digit", minute: "2-digit" }) : "--:--"}
          </p>
          <p class="text-sm text-[#5f6368]">{row?.origen ?? "Caseta"}</p>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Hora de Salida</p>
          <p class="mt-1 text-5xl font-bold text-[#213138]">--:--</p>
          <p class="text-sm text-[#5f6368]">Pendiente</p>
        </div>
      </div>
      <div class="mt-4 flex items-center justify-between border-t border-[#eeeeee] pt-4">
        <p class="text-sm text-[#5f6368]">Duracion total de estancia</p>
        <p class="text-sm font-semibold text-[#213138]">{row?.resultado ?? "N/A"}</p>
      </div>
    </article>

    <article class="rounded-[14px] bg-white p-5 shadow-[0_8px_24px_rgba(26,28,28,0.05)]">
      <h2 class="mb-4 text-3xl font-semibold text-[#213138]">Autorizacion</h2>
      <div class="flex items-center gap-3">
        <div class="grid h-12 w-12 place-items-center rounded-full bg-[#eeeeee] text-[#5f6368]">
          <span class="material-symbols-outlined">person</span>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Autorizado por</p>
          <p class="text-2xl font-semibold text-[#213138]">{residenteProfile?.full_name ?? "Sistema Nauka"}</p>
          <p class="text-sm text-[#5f6368]">Lote {residenteProfile?.lot_number ?? row?.lote_number ?? "N/A"}</p>
        </div>
      </div>
      <div class="mt-4 rounded-xl bg-[#f3f3f4] p-3">
        <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Metodo de verificacion</p>
        <p class="mt-1 text-base font-semibold text-[#213138]">{row?.token_qr ? `QR ${row.token_qr.slice(0, 8)}...` : "Codigo QR unico"}</p>
      </div>
      <div class="mt-4 rounded-xl bg-[#f3f3f4] p-3">
        <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Guardia que validó</p>
        <p class="mt-1 text-base font-semibold text-[#213138]">{guardiaProfile?.full_name ?? "No identificado"}</p>
      </div>
    </article>

    <article class="rounded-[14px] bg-white p-5 shadow-[0_8px_24px_rgba(26,28,28,0.05)]">
      <h2 class="mb-4 text-3xl font-semibold text-[#213138]">Detalles de Identificacion</h2>
      <div class="space-y-3">
        <p><span class="block text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Resultado</span><span class="text-lg font-semibold text-[#213138]">{row?.resultado ?? "N/A"}</span></p>
        <p><span class="block text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Razon</span><span class="text-lg font-semibold text-[#213138]">{row?.razon ?? "Sin observaciones"}</span></p>
        <p><span class="block text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Motivo del pase</span><span class="text-lg font-semibold text-[#213138]">{pass?.motivo ?? "N/A"}</span></p>
        <p><span class="block text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Notas del residente</span><span class="text-lg font-semibold text-[#213138]">{pass?.notas ?? "Sin notas"}</span></p>
        <p><span class="block text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Pase creado</span><span class="text-lg font-semibold text-[#213138]">{pass?.created_at ? new Date(pass.created_at).toLocaleString("es-MX") : "N/A"}</span></p>
        <p><span class="block text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Registro</span><span class="text-lg font-semibold text-[#213138]">{row?.id ?? "N/A"}</span></p>
      </div>
    </article>
  </section>

  <div class="mt-6 space-y-3">
    <button class="h-12 w-full rounded-xl bg-[#e8e8e8] text-lg font-semibold text-[#213138]">Imprimir Registro</button>
    <button class="h-12 w-full rounded-xl bg-gradient-to-b from-[#213138] to-[#37474f] text-lg font-semibold text-white">Reportar Incidencia</button>
  </div>
</AppLayout>
