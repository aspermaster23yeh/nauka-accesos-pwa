---
import AppLayout from "../../layouts/AppLayout.astro";
import { adminNav } from "../../lib/nav";
import { getSalidasConEvidenciaAdmin } from "../../lib/access";
import { getSupabaseServiceClient } from "../../lib/supabase";

const rows = await getSalidasConEvidenciaAdmin(150).catch(() => []);
const supabase = getSupabaseServiceClient();
const guardIds = [...new Set(rows.map((r) => r.guardia_id).filter(Boolean))] as string[];
const { data: guards } =
  guardIds.length > 0 ? await supabase.from("profiles").select("id, full_name").in("id", guardIds) : { data: [] as { id: string; full_name: string | null }[] };
const guardById = new Map((guards ?? []).map((g) => [g.id, g.full_name]));

async function signEvidencia(path: string | null | undefined) {
  const p = path?.trim();
  if (!p) return null;
  const { data } = await supabase.storage.from("evidencias_salida").createSignedUrl(p, 3600);
  return data?.signedUrl ?? null;
}

const rowsWithUrls = await Promise.all(
  rows.map(async (r) => {
    const u1 = await signEvidencia(r.evidencia_storage_path);
    const u2 = await signEvidencia(r.evidencia_storage_path_2);
    const u3 = await signEvidencia(r.evidencia_storage_path_3);
    const urls = [u1, u2, u3].filter(Boolean) as string[];
    return {
      row: r,
      urls,
      guardName: r.guardia_id ? (guardById.get(r.guardia_id) ?? null) : null
    };
  })
);
---

<AppLayout
  wide
  title="Evidencias de salida - Nauka Nayarit"
  topBar={{ title: "Evidencias salida", leftIcon: "arrow_back", leftHref: "/admin/dashboard", rightIcon: "notifications", rightHref: "#" }}
  navItems={adminNav}
  activeNav="evidencias"
  pageTitle="Check-out con fotos"
>
  <p class="-mt-5 mb-6 max-w-2xl text-sm text-[#5c6569]">
    Registros de <strong class="text-[#213138]">salida</strong> en caseta con al menos una evidencia en el bucket. Hasta 3 fotos por movimiento (1 obligatoria en caseta).
  </p>

  <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
    {
      rowsWithUrls.length === 0 ? (
        <p class="col-span-full rounded-xl border border-dashed border-[#cfd4d9] bg-white/80 p-8 text-center text-sm text-[#5f6368]">
          No hay salidas con evidencia aún, o la base no tiene las columnas nuevas (aplica migraciones).
        </p>
      ) : (
        rowsWithUrls.map(({ row, urls, guardName }) => (
          <article class="rounded-2xl border border-[#213138]/[0.08] bg-white p-4 shadow-[0_6px_18px_rgba(26,28,28,0.04)]">
            <div class="flex flex-wrap items-start justify-between gap-2">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.1em] text-[#5c6569]">{row.complejo_id}</p>
                <p class="font-display text-xl text-[#213138]">{row.visitante_nombre ?? "Sin nombre"}</p>
                <p class="text-sm text-[#5f6368]">
                  {new Date(row.created_at).toLocaleString("es-MX", { dateStyle: "medium", timeStyle: "short" })} · Lote {row.lote_number ?? "—"}
                </p>
                <p class="mt-1 text-xs text-[#5f6368]">
                  Guardia: <span class="font-semibold text-[#213138]">{guardName ?? "—"}</span> · {urls.length} foto(s)
                </p>
              </div>
              <a
                href={`/admin/detalle-movimiento?id=${row.id}`}
                class="shrink-0 rounded-xl border border-[#213138]/12 px-3 py-2 text-xs font-semibold text-[#213138] transition hover:bg-[#213138]/[0.04]"
              >
                Ver detalle
              </a>
            </div>
            <div class="mt-4 grid grid-cols-3 gap-2">
              {urls.map((url, i) => (
                <a href={url} target="_blank" rel="noopener noreferrer" class="block overflow-hidden rounded-lg border border-[#ececec] bg-[#fafafa]">
                  <img src={url} alt={`Evidencia ${i + 1}`} class="aspect-square w-full object-cover" loading="lazy" />
                </a>
              ))}
            </div>
          </article>
        ))
      )
    }
  </div>
</AppLayout>
