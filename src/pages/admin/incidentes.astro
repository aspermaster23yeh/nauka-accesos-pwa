---
import AppLayout from "../../layouts/AppLayout.astro";
import { adminNav } from "../../lib/nav";
import { getSupabaseServiceClient } from "../../lib/supabase";

const supabase = getSupabaseServiceClient();
const { data: incidentes } = await supabase
  .from("incidentes")
  .select("id, created_at, estado, descripcion, severidad, visitante_nombre")
  .order("created_at", { ascending: false })
  .limit(80);
---

<AppLayout
  wide
  title="Incidentes - Nauka Nayarit"
  topBar={{ title: "Incidentes", leftIcon: "arrow_back", leftHref: "/admin/dashboard", rightIcon: "menu", rightHref: "#" }}
  navItems={adminNav}
  activeNav="incidentes"
  pageTitle="Incidentes"
  bodyClass="bg-[#F9F8F6] text-[#213138]"
  shellCanvasClass="nauka-soul-canvas"
>
  <p class="-mt-3 mb-8 text-sm text-[#5c6569]">Seguimiento global. Desde aquí puedes coordinar respuesta en campo.</p>
  {(incidentes ?? []).length === 0 && (
    <p class="rounded-2xl border border-dashed border-[#213138]/12 bg-white/80 p-8 text-center text-sm text-[#5c6569]">Sin incidentes registrados.</p>
  )}
  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    {(incidentes ?? []).map((item) => (
      <article class="rounded-2xl border border-[#213138]/[0.06] bg-white p-6 shadow-[0_8px_24px_rgba(26,28,28,0.04)]">
        <div class="flex items-center justify-between gap-2">
          <p class="text-[0.6rem] font-semibold uppercase tracking-[0.18em] text-[#5c6569]">{item.severidad}</p>
          <p class="text-xs font-medium text-[#5c6569]">{new Date(item.created_at).toLocaleString("es-MX")}</p>
        </div>
        <p class="mt-3 text-base font-semibold text-[#213138]">{item.descripcion}</p>
        <p class="mt-2 text-sm text-[#5c6569]">
          Visitante: {item.visitante_nombre ?? "N/A"} · Estado: {item.estado}
        </p>
      </article>
    ))}
  </div>
  <a href="/admin/dashboard" class="mt-10 inline-flex items-center gap-2 text-sm font-semibold text-[#3d5c4a] underline decoration-[#3d5c4a]/30 underline-offset-4">
    ← Volver al resumen
  </a>
</AppLayout>
