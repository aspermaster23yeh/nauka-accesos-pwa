---
import AppLayout from "../../layouts/AppLayout.astro";
import loginBackground from "../../../491461670_17919450432084004_8291959886084544470_n.jpg";

const statusParam = Astro.url.searchParams.get("status");
const isSuccess = statusParam === "success";
const title = Astro.url.searchParams.get("title") ?? (isSuccess ? "Acceso registrado" : "Acceso no registrado");
const message = Astro.url.searchParams.get("message") ?? Astro.url.searchParams.get("reason") ?? "No se pudo completar la operación.";
const next = Astro.url.searchParams.get("next") ?? (isSuccess ? "/" : "/registro");
---

<AppLayout title="Resultado de Registro - Nauka Nayarit" bodyClass="bg-[#0f1f2a] text-[#1a1c1c]">
  <section class="fixed inset-0 z-0">
    <img src={loginBackground.src} alt="fondo" class="h-full w-full object-cover blur-md brightness-50" />
    <div class={`absolute inset-0 ${isSuccess ? "bg-[#006d36]/20" : "bg-[#ba1a1a]/20"}`}></div>
  </section>

  <div class="relative z-10 flex min-h-[82vh] items-center">
    <section
      class={`w-full rounded-[14px] border-2 bg-white p-6 text-center shadow-[0_0_40px_rgba(26,28,28,0.16)] ${
        isSuccess ? "border-[#006d36]/20" : "border-[#ba1a1a]/20"
      }`}
    >
      <div class={`mx-auto mb-5 grid h-24 w-24 place-items-center rounded-full ${isSuccess ? "bg-[#83fba5]/25 text-[#006d36]" : "bg-[#ffdad6] text-[#93000a]"}`}>
        <span class="material-symbols-outlined text-5xl">{isSuccess ? "check_circle" : "warning"}</span>
      </div>
      <h1 class={`text-5xl font-extrabold uppercase tracking-tight ${isSuccess ? "text-[#006d36]" : "text-[#ba1a1a]"}`}>{title}</h1>
      <p class="mt-3 text-base font-semibold text-[#5f6368]">{message}</p>
      <div class="mt-6 space-y-3">
        <a
          href={next}
          class={`flex h-14 w-full items-center justify-center rounded-xl text-2xl font-semibold text-white ${
            isSuccess ? "bg-gradient-to-b from-[#006d36] to-[#005227]" : "bg-gradient-to-b from-[#213138] to-[#37474f]"
          }`}
        >
          {isSuccess ? "Continuar" : "Reintentar registro"}
        </a>
        <a href="/" class="block text-sm font-semibold text-[#213138] underline">Ir a iniciar sesión</a>
      </div>
    </section>
  </div>
</AppLayout>
