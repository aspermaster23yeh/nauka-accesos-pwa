---
import AppLayout from "../../layouts/AppLayout.astro";
import { guardNav } from "../../lib/nav";
import loginBackground from "../../../491461670_17919450432084004_8291959886084544470_n.jpg";
const complejoId = Astro.locals.profile?.complejo_id ?? "complejo-1";
---

<AppLayout
  title="Escaner Guardia - Nauka Nayarit"
  topBar={{ title: "Nauka Nayarit", leftIcon: "person", leftHref: "#", rightIcon: "notifications", rightHref: "#" }}
  navItems={guardNav}
>
  <section class="nauka-card-aero mb-4 p-3 md:p-4" data-complejo-id={complejoId}>
    <div class="mb-3 rounded-2xl border border-[#213138]/[0.06] bg-[#FCFBF9]/60 p-3">
      <button
        id="camera-permission"
        class="nauka-btn-primary h-10 w-full rounded-2xl text-sm font-semibold"
      >
        Activar cámara
      </button>
      <p id="camera-status" class="mt-2 text-center text-xs font-medium text-[#5c6569]">Cámara no iniciada</p>
    </div>
    <div class="grid grid-cols-2 gap-2">
      <button data-access-type="entrada" class="access-toggle h-11 rounded-2xl text-base font-semibold">Entrada</button>
      <button data-access-type="salida" class="access-toggle h-11 rounded-2xl text-base font-semibold">Salida</button>
    </div>
    <div class="mt-3 flex gap-2">
      <input
        id="manual-token"
        type="text"
        placeholder="Token o enlace del pase"
        class="nauka-input-lux h-11 flex-1 text-sm"
      />
      <button id="validate-token" class="nauka-btn-primary h-11 shrink-0 rounded-2xl px-4 text-sm font-semibold">Validar</button>
    </div>
    <label id="evidence-wrap" class="mt-4 hidden flex-col gap-2 text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-[#5c6569]">
      Evidencia de salida
      <input id="evidence-input" type="file" accept="image/*" capture="environment" class="text-sm font-normal normal-case tracking-normal" />
    </label>
  </section>

  <section class="relative -mx-4 -mt-6 mb-6 h-[45vh] overflow-hidden bg-[#2f3131]">
    <video id="camera-video" class="absolute inset-0 hidden h-full w-full object-cover" autoplay playsinline muted></video>
    <img id="camera-fallback" src={loginBackground.src} alt="camera bg" class="h-full w-full object-cover blur-sm brightness-75" />
    <div class="absolute inset-0 grid place-items-center">
      <div class="relative h-64 w-64">
        <div class="absolute left-0 top-0 h-12 w-12 rounded-tl-lg border-l-4 border-t-4 border-white/85"></div>
        <div class="absolute right-0 top-0 h-12 w-12 rounded-tr-lg border-r-4 border-t-4 border-white/85"></div>
        <div class="absolute bottom-0 left-0 h-12 w-12 rounded-bl-lg border-b-4 border-l-4 border-white/85"></div>
        <div class="absolute bottom-0 right-0 h-12 w-12 rounded-br-lg border-b-4 border-r-4 border-white/85"></div>
        <div class="absolute left-0 top-1/2 h-px w-full bg-[#3d5c4a]/35 shadow-[0_0_20px_rgba(61,92,74,0.25)]"></div>
      </div>
    </div>
  </section>

  <section id="nauka-invitation" class="nauka-invitation" data-state="idle">
    <div class="nauka-invitation-inner">
      <p class="nauka-invitation-ribbon">Nauka Nayarit · Acceso</p>
      <div id="status-chip" class="nauka-chip-neutral mb-4 inline-flex items-center gap-2 rounded-full px-3 py-2">
        <span class="material-symbols-outlined text-[20px]">qr_code_scanner</span>
        <span id="status-chip-label" class="text-xs font-semibold tracking-wide">En espera</span>
      </div>
      <h2 id="status-title" class="font-display text-[1.75rem] leading-tight text-[#213138] md:text-[2.125rem]">Listo para escanear</h2>
      <div class="my-5 h-px w-full bg-gradient-to-r from-transparent via-[#213138]/12 to-transparent"></div>
      <p class="text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-[#5c6569]">Visitante</p>
      <p id="visitor-name" class="mt-1 text-2xl font-medium text-[#213138] md:text-3xl">Sin lectura</p>
      <p class="mt-5 text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-[#5c6569]">Destino</p>
      <p id="lot-number" class="font-display mt-1 text-3xl text-[#213138] md:text-4xl">—</p>
      <p id="validation-reason" class="mt-4 text-sm leading-relaxed text-[#5c6569]">Escanea un código o pega el enlace del pase.</p>
      <a
        id="access-action"
        href="#"
        class="mt-8 flex h-14 w-full items-center justify-center gap-2 rounded-2xl border border-[#213138]/10 bg-[#213138]/[0.04] text-lg font-semibold text-[#213138] transition duration-[400ms] ease-in-out"
      >
        <span class="material-symbols-outlined">login</span>
        <span id="action-label">Esperando código válido</span>
      </a>
      <a
        id="review-link"
        href="/admin/bitacora"
        class="mt-3 flex h-12 w-full items-center justify-center rounded-2xl border border-[#213138]/[0.08] text-sm font-semibold text-[#213138] transition hover:bg-[#213138]/[0.04]"
      >
        Ver bitácora
      </a>
    </div>
  </section>
</AppLayout>

<script is:inline>
  const scannerRoot = document.querySelector("[data-complejo-id]");
  const accessButtons = Array.from(document.querySelectorAll(".access-toggle"));
  const actionLabel = document.getElementById("action-label");
  const statusTitle = document.getElementById("status-title");
  const statusChip = document.getElementById("status-chip");
  const accessAction = document.getElementById("access-action");
  const reviewLink = document.getElementById("review-link");
  const reasonNode = document.getElementById("validation-reason");
  const cameraPermission = document.getElementById("camera-permission");
  const cameraStatus = document.getElementById("camera-status");
  const cameraVideo = document.getElementById("camera-video");
  const cameraFallback = document.getElementById("camera-fallback");
  const manualTokenInput = document.getElementById("manual-token");
  const validateTokenButton = document.getElementById("validate-token");
  const visitorNameNode = document.getElementById("visitor-name");
  const lotNode = document.getElementById("lot-number");
  const evidenceWrap = document.getElementById("evidence-wrap");
  const evidenceInput = document.getElementById("evidence-input");
  const resolvedComplejoId = scannerRoot?.getAttribute("data-complejo-id") ?? "complejo-1";

  let accessType = "entrada";
  let qrState = "invalido";
  let currentToken = "";
  let scanIntervalId = 0;
  let hasValidated = false;
  const invitationEl = document.getElementById("nauka-invitation");
  const chipLabel = document.getElementById("status-chip-label");

  const normalizeType = (value) => (value === "salida" ? "salida" : "entrada");
  const extractToken = (rawValue) => {
    if (!rawValue) return "";
    const trimmed = String(rawValue).trim();
    if (!trimmed) return "";
    if (!trimmed.includes("http://") && !trimmed.includes("https://")) return trimmed;
    try {
      const parsed = new URL(trimmed);
      const queryCode = parsed.searchParams.get("code");
      if (queryCode) return queryCode;
      const parts = parsed.pathname.split("/").filter(Boolean);
      if (parts.length >= 2 && parts[0] === "pase") return decodeURIComponent(parts[1]);
      return "";
    } catch {
      return "";
    }
  };

  const readStateFromUrl = () => {
    const params = new URLSearchParams(window.location.search);
    accessType = normalizeType(params.get("type"));
    const urlToken = extractToken(params.get("code") ?? window.location.href);
    if (urlToken) {
      currentToken = urlToken;
      if (manualTokenInput instanceof HTMLInputElement) manualTokenInput.value = urlToken;
    }
  };

  const syncUrlFromState = () => {
    const params = new URLSearchParams(window.location.search);
    params.set("type", accessType);
    if (currentToken) params.set("code", currentToken);
    const next = `${window.location.pathname}?${params.toString()}`;
    window.history.replaceState(null, "", next);
  };

  const setCameraStatus = (message, isError = false) => {
    if (!cameraStatus) return;
    cameraStatus.textContent = message;
    cameraStatus.className = `mt-2 text-center text-xs font-medium ${isError ? "text-[#9a6b5c]" : "text-[#5c6569]"}`;
  };

  const validateTokenOnServer = async (token) => {
    const response = await fetch("/api/validar-qr", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ token, complejoId: resolvedComplejoId })
    });
    if (!response.ok) throw new Error("No se pudo validar el token.");
    return response.json();
  };

  const processToken = async (token) => {
    const normalizedToken = extractToken(token);
    if (!normalizedToken) return;
    currentToken = normalizedToken;
    try {
      const result = await validateTokenOnServer(normalizedToken);
      hasValidated = true;
      qrState = result.status === "authorized" ? "valido" : "invalido";
      if (visitorNameNode && result.visitanteNombre) visitorNameNode.textContent = result.visitanteNombre;
      if (lotNode && result.lote) lotNode.textContent = `Lote ${result.lote}`;
      if (result.status !== "authorized") {
        if (visitorNameNode) visitorNameNode.textContent = result.visitanteNombre ?? "Sin autorización";
        if (lotNode) lotNode.textContent = result.lote ? `Lote ${result.lote}` : "—";
      }
      if (reasonNode) {
        reasonNode.textContent =
          result.status === "authorized" ? "Invitación verificada. Puede registrar el movimiento en caseta." : `Motivo: ${result.razon ?? "Token no encontrado o inválido"}`;
      }
      setCameraStatus(result.status === "authorized" ? "Código válido." : "Código no válido.", result.status !== "authorized");
    } catch {
      hasValidated = true;
      qrState = "invalido";
      if (reasonNode) reasonNode.textContent = "Error de validación. Intenta de nuevo.";
      setCameraStatus("No se pudo validar.", true);
    }
    render();
  };

  const startRealtimeScanner = () => {
    if (!(cameraVideo instanceof HTMLVideoElement)) return;
    if (!("BarcodeDetector" in window)) {
      setCameraStatus("Scanner automático no disponible, usa validación manual.");
      return;
    }
    const detector = new window.BarcodeDetector({ formats: ["qr_code"] });
    if (scanIntervalId) window.clearInterval(scanIntervalId);
    scanIntervalId = window.setInterval(async () => {
      try {
        const codes = await detector.detect(cameraVideo);
        if (codes.length > 0 && codes[0].rawValue) {
          window.clearInterval(scanIntervalId);
          await processToken(codes[0].rawValue);
        }
      } catch {
        // keep polling
      }
    }, 700);
  };

  const requestCamera = async () => {
    if (!(cameraVideo instanceof HTMLVideoElement)) return;
    if (!navigator.mediaDevices?.getUserMedia) {
      setCameraStatus("Tu navegador no soporta cámara.", true);
      return;
    }
    try {
      const stream = await navigator.mediaDevices.getUserMedia({
        video: {
          facingMode: { ideal: "environment" }
        },
        audio: false
      });
      cameraVideo.srcObject = stream;
      cameraVideo.classList.remove("hidden");
      if (cameraFallback instanceof HTMLImageElement) {
        cameraFallback.classList.add("hidden");
      }
      setCameraStatus("Cámara activa (modo escáner).");
      if (cameraPermission) {
        cameraPermission.textContent = "Cámara activa";
        cameraPermission.className = "nauka-btn-primary h-10 w-full rounded-2xl text-sm font-semibold";
      }
      startRealtimeScanner();
    } catch {
      setCameraStatus("Permiso denegado o cámara no disponible.", true);
    }
  };

  const registerMovement = async () => {
    if (!currentToken || qrState !== "valido") {
      const reason = encodeURIComponent(reasonNode?.textContent ?? "Token invalido");
      window.location.href = `/guardia/acceso-denegado?reason=${reason}`;
      return;
    }
    let evidenciaPath = "";
    if (accessType === "salida") {
      const fileInput = evidenceInput instanceof HTMLInputElement ? evidenceInput : null;
      const file = fileInput?.files?.[0];
      if (!file) {
        alert("La salida requiere una foto de evidencia.");
        return;
      }
      const fd = new FormData();
      fd.append("file", file);
      const uploadRes = await fetch("/api/guardia/subir-evidencia", { method: "POST", body: fd });
      if (!uploadRes.ok) {
        const payload = await uploadRes.json().catch(() => ({}));
        alert(payload.error ?? "No se pudo subir la evidencia.");
        return;
      }
      const uploadPayload = await uploadRes.json().catch(() => ({}));
      evidenciaPath = typeof uploadPayload.path === "string" ? uploadPayload.path : "";
      if (!evidenciaPath) {
        alert("No se recibió la ruta de evidencia.");
        return;
      }
    }
    const response = await fetch("/api/guardia/registrar-movimiento", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        token: currentToken,
        tipoEvento: accessType,
        evidenciaStoragePath: evidenciaPath || undefined
      })
    });
    if (!response.ok) {
      const payload = await response.json().catch(() => ({}));
      alert(payload.error ?? "No se pudo registrar movimiento.");
      return;
    }
    window.location.href = "/admin/bitacora?q=autorizado";
  };

  const render = () => {
    accessButtons.forEach((button) => {
      const active = button.getAttribute("data-access-type") === accessType;
      button.className = `access-toggle h-11 rounded-2xl text-base font-semibold transition duration-[400ms] ease-in-out ${
        active ? "nauka-btn-primary text-[#FCFBF9]" : "border border-[#213138]/[0.08] bg-[#FCFBF9]/80 text-[#213138] hover:bg-white"
      }`;
    });

    if (!actionLabel || !statusTitle || !statusChip || !accessAction) return;
    if (evidenceWrap) {
      evidenceWrap.classList.toggle("hidden", accessType !== "salida");
      evidenceWrap.classList.toggle("flex", accessType === "salida");
    }
    const state = !hasValidated ? "idle" : qrState === "valido" ? "authorized" : "denied";
    invitationEl?.setAttribute("data-state", state);

    if (visitorNameNode) {
      visitorNameNode.className =
        qrState === "valido" && hasValidated
          ? "font-display mt-1 text-3xl leading-tight text-[#213138] md:text-[2.25rem]"
          : "mt-1 text-2xl font-medium text-[#213138] md:text-3xl";
    }

    if (chipLabel) {
      chipLabel.textContent = !hasValidated ? "En espera" : qrState === "valido" ? "Invitación válida" : "No autorizado";
    }

    const chipIcon = statusChip.querySelector(".material-symbols-outlined");
    if (chipIcon) {
      chipIcon.textContent = state === "authorized" ? "verified" : state === "denied" ? "gpp_maybe" : "qr_code_scanner";
      chipIcon.className = "material-symbols-outlined text-[20px]";
    }

    if (qrState === "valido" && hasValidated) {
      actionLabel.textContent = accessType === "entrada" ? "Registrar entrada" : "Registrar salida";
      statusTitle.textContent = "Visitante autorizado";
      statusChip.className = "nauka-chip-ok mb-4 inline-flex items-center gap-2 rounded-full px-3 py-2";
      accessAction.className =
        "nauka-btn-primary mt-8 flex h-14 w-full items-center justify-center gap-2 rounded-2xl text-lg font-semibold transition duration-[400ms] ease-in-out";
      if (reviewLink instanceof HTMLAnchorElement) {
        reviewLink.href = "/admin/bitacora?q=autorizado";
        reviewLink.textContent = "Ir a revisión de aceptados";
      }
    } else if (hasValidated) {
      actionLabel.textContent = "Ver motivo en caseta";
      statusTitle.textContent = "Acceso no autorizado";
      statusChip.className = "nauka-chip-warn mb-4 inline-flex items-center gap-2 rounded-full px-3 py-2";
      accessAction.className =
        "mt-8 flex h-14 w-full items-center justify-center gap-2 rounded-2xl border border-[#9a6b5c]/25 bg-[#9a6b5c]/[0.08] text-lg font-semibold text-[#6b4f45] transition duration-[400ms] ease-in-out";
      if (reviewLink instanceof HTMLAnchorElement) {
        reviewLink.href = "/admin/bitacora?q=rechazado";
        reviewLink.textContent = "Ir a revisión de rechazados";
      }
    } else {
      actionLabel.textContent = "Esperando código válido";
      statusTitle.textContent = "Listo para escanear";
      statusChip.className = "nauka-chip-neutral mb-4 inline-flex items-center gap-2 rounded-full px-3 py-2";
      accessAction.className =
        "mt-8 flex h-14 w-full items-center justify-center gap-2 rounded-2xl border border-[#213138]/10 bg-[#213138]/[0.04] text-lg font-semibold text-[#213138] transition duration-[400ms] ease-in-out";
      if (reviewLink instanceof HTMLAnchorElement) {
        reviewLink.href = "/admin/bitacora";
        reviewLink.textContent = "Ver bitácora";
      }
    }
    syncUrlFromState();
  };

  accessButtons.forEach((button) => {
    button.addEventListener("click", () => {
      accessType = button.getAttribute("data-access-type") ?? "entrada";
      render();
    });
  });

  accessAction?.addEventListener("click", (event) => {
    event.preventDefault();
    registerMovement();
  });

  cameraPermission?.addEventListener("click", () => {
    requestCamera();
  });

  validateTokenButton?.addEventListener("click", () => {
    const token = manualTokenInput instanceof HTMLInputElement ? manualTokenInput.value.trim() : "";
    processToken(token);
  });

  readStateFromUrl();
  if (currentToken) {
    processToken(currentToken);
  }
  render();
</script>
