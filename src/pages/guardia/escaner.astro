---
import AppLayout from "../../layouts/AppLayout.astro";
import { guardNav } from "../../lib/nav";
import loginBackground from "../../../491461670_17919450432084004_8291959886084544470_n.jpg";
const complejoId = Astro.locals.profile?.complejo_id ?? "complejo-1";
---

<AppLayout
  title="Escaner Guardia - Nauka Nayarit"
  topBar={{ title: "Nauka Nayarit", leftIcon: "person", leftHref: "#", rightIcon: "notifications", rightHref: "#" }}
  navItems={guardNav}
>
  <section class="nauka-card-aero mb-4 p-3 md:p-4" data-complejo-id={complejoId}>
    <div class="mb-3 rounded-2xl border border-[#213138]/[0.06] bg-[#FCFBF9]/60 p-3">
      <button
        id="camera-permission"
        class="nauka-btn-primary h-10 w-full rounded-2xl text-sm font-semibold"
      >
        Activar cámara
      </button>
      <p id="camera-status" class="mt-2 text-center text-xs font-medium text-[#5c6569]">Cámara no iniciada</p>
    </div>
    <div class="grid grid-cols-2 gap-2">
      <button data-access-type="entrada" class="access-toggle h-11 rounded-2xl text-base font-semibold">Entrada</button>
      <button data-access-type="salida" class="access-toggle h-11 rounded-2xl text-base font-semibold">Salida</button>
    </div>
    <div class="mt-3 flex gap-2">
      <input
        id="manual-token"
        type="text"
        placeholder="Token o enlace del pase"
        class="nauka-input-lux h-11 flex-1 text-sm"
      />
      <button id="validate-token" class="nauka-btn-primary h-11 shrink-0 rounded-2xl px-4 text-sm font-semibold">Validar</button>
    </div>
    <div id="guard-queue-bar" class="mt-3 hidden rounded-2xl border border-[#213138]/10 bg-[#FCFBF9]/95 p-3">
      <p id="guard-queue-text" class="text-center text-sm font-semibold text-[#213138]"></p>
      <button type="button" id="guard-sync-now" class="nauka-btn-primary mt-2 h-10 w-full rounded-xl text-sm font-semibold">
        Sincronizar ahora
      </button>
    </div>
    <div
      id="scanner-network-banner"
      class="mt-3 hidden rounded-2xl border border-[#9a6b5c]/30 bg-[rgba(154,107,92,0.1)] p-3 text-center"
      role="alert"
    >
      <p class="text-sm font-semibold text-[#213138]">Sin conexión o sin respuesta del servidor</p>
      <p class="mt-1 text-xs text-[#5c6569]">Comprueba datos móviles o Wi‑Fi e inténtalo de nuevo.</p>
    </div>
    <label id="evidence-wrap" class="mt-4 hidden flex-col gap-2 text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-[#5c6569]">
      Evidencia de salida
      <input id="evidence-input" type="file" accept="image/*" capture="environment" class="text-sm font-normal normal-case tracking-normal" />
    </label>
  </section>

  <section class="relative -mx-4 -mt-6 mb-6 h-[45vh] overflow-hidden bg-[#2f3131]">
    <video id="camera-video" class="absolute inset-0 hidden h-full w-full object-cover" autoplay playsinline muted></video>
    <img id="camera-fallback" src={loginBackground.src} alt="camera bg" class="h-full w-full object-cover blur-sm brightness-75" />
    <div class="absolute inset-0 grid place-items-center">
      <div class="relative h-64 w-64">
        <div class="absolute left-0 top-0 h-12 w-12 rounded-tl-lg border-l-4 border-t-4 border-white/85"></div>
        <div class="absolute right-0 top-0 h-12 w-12 rounded-tr-lg border-r-4 border-t-4 border-white/85"></div>
        <div class="absolute bottom-0 left-0 h-12 w-12 rounded-bl-lg border-b-4 border-l-4 border-white/85"></div>
        <div class="absolute bottom-0 right-0 h-12 w-12 rounded-br-lg border-b-4 border-r-4 border-white/85"></div>
        <div class="absolute left-0 top-1/2 h-px w-full bg-[#3d5c4a]/35 shadow-[0_0_20px_rgba(61,92,74,0.25)]"></div>
      </div>
    </div>
  </section>

  <section id="nauka-invitation" class="nauka-invitation" data-state="idle">
    <div class="nauka-invitation-inner">
      <p class="nauka-invitation-ribbon">Nauka Nayarit · Acceso</p>
      <div id="status-chip" class="nauka-chip-neutral mb-4 inline-flex items-center gap-2 rounded-full px-3 py-2">
        <span class="material-symbols-outlined text-[20px]">qr_code_scanner</span>
        <span id="status-chip-label" class="text-xs font-semibold tracking-wide">En espera</span>
      </div>
      <h2 id="status-title" class="font-display text-[1.75rem] leading-tight text-[#213138] md:text-[2.125rem]">Listo para escanear</h2>
      <div class="my-5 h-px w-full bg-gradient-to-r from-transparent via-[#213138]/12 to-transparent"></div>
      <p class="text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-[#5c6569]">Visitante</p>
      <p id="visitor-name" class="mt-1 text-2xl font-medium text-[#213138] md:text-3xl">Sin lectura</p>
      <p class="mt-5 text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-[#5c6569]">Destino</p>
      <p id="lot-number" class="font-display mt-1 text-3xl text-[#213138] md:text-4xl">—</p>
      <p id="validation-reason" class="mt-4 text-sm leading-relaxed text-[#5c6569]">Escanea un código o pega el enlace del pase.</p>

      <div id="pass-detail-panel" class="mt-6 hidden w-full space-y-4 border-t border-[#213138]/10 pt-6 text-left">
        <div class="rounded-2xl border border-[#213138]/[0.08] bg-[#FCFBF9]/95 p-4 shadow-[0_4px_20px_rgba(33,49,56,0.04)]">
          <p class="text-[0.6rem] font-bold uppercase tracking-[0.14em] text-[#5c6569]">Autorizado por</p>
          <div class="mt-3 flex gap-3">
            <img
              id="pass-solicitante-photo"
              alt=""
              class="hidden h-14 w-14 shrink-0 rounded-full object-cover ring-2 ring-[#213138]/10"
            />
            <div
              id="pass-solicitante-photo-ph"
              class="grid h-14 w-14 shrink-0 place-items-center rounded-full bg-[#213138]/[0.06] text-[#5c6569]"
            >
              <span class="material-symbols-outlined text-2xl">person</span>
            </div>
            <div class="min-w-0">
              <p id="pass-solicitante-name" class="truncate font-semibold text-[#213138]"></p>
              <p id="pass-solicitante-lote" class="text-sm text-[#5c6569]"></p>
            </div>
          </div>
          <img id="pass-solicitante-ine" alt="INE solicitante" class="mt-3 hidden max-h-36 w-full rounded-xl border border-[#213138]/10 object-contain" />
        </div>

        <div class="rounded-2xl border border-[#213138]/[0.08] bg-white/95 p-4 shadow-[0_4px_20px_rgba(33,49,56,0.04)]">
          <p class="text-[0.6rem] font-bold uppercase tracking-[0.12em] text-[#5c6569]">Permiso solicitado</p>
          <p id="pass-motivo" class="mt-1 text-base font-semibold text-[#213138]">—</p>
          <p class="mt-4 text-[0.6rem] font-bold uppercase tracking-[0.12em] text-[#5c6569]">Instrucciones para caseta</p>
          <p id="pass-notas" class="mt-1 text-sm leading-relaxed text-[#213138]">—</p>
          <p class="mt-4 text-[0.6rem] font-bold uppercase tracking-[0.12em] text-[#5c6569]">Vigencia del pase</p>
          <p id="pass-vence" class="mt-1 text-sm font-semibold text-[#3d5c4a]">—</p>
        </div>

        <div>
          <p class="text-[0.6rem] font-bold uppercase tracking-[0.12em] text-[#5c6569]">Identidad del visitante (revisar antes de confirmar)</p>
          <div class="mt-2 grid grid-cols-2 gap-2">
            <button
              type="button"
              id="pass-visitor-face-wrap"
              class="overflow-hidden rounded-xl border border-[#213138]/10 bg-[#213138]/[0.03] text-left transition active:scale-[0.99]"
            >
              <p class="bg-[#213138]/[0.04] px-2 py-1 text-[0.55rem] font-bold uppercase tracking-wider text-[#5c6569]">Rostro</p>
              <img id="pass-visitor-face" alt="Rostro visitante" class="hidden aspect-square w-full object-cover" />
              <p id="pass-visitor-face-ph" class="px-2 py-6 text-center text-[0.7rem] text-[#5c6569]">Sin foto</p>
            </button>
            <button
              type="button"
              id="pass-visitor-ine-wrap"
              class="overflow-hidden rounded-xl border border-[#213138]/10 bg-[#213138]/[0.03] text-left transition active:scale-[0.99]"
            >
              <p class="bg-[#213138]/[0.04] px-2 py-1 text-[0.55rem] font-bold uppercase tracking-wider text-[#5c6569]">INE</p>
              <img id="pass-visitor-ine" alt="INE visitante" class="hidden max-h-36 w-full object-contain" />
              <p id="pass-visitor-ine-ph" class="px-2 py-6 text-center text-[0.7rem] text-[#5c6569]">Sin imagen</p>
            </button>
          </div>
          <p class="mt-3 text-center text-xs leading-relaxed text-[#5c6569]">
            Toca una foto para verla en grande. Luego confirma <strong id="pass-confirm-mode-label">la entrada o la salida</strong> con el botón inferior.
          </p>
        </div>
      </div>

      <a
        id="access-action"
        href="#"
        class="mt-8 flex h-14 w-full items-center justify-center gap-2 rounded-2xl border border-[#213138]/10 bg-[#213138]/[0.04] text-lg font-semibold text-[#213138] transition duration-[400ms] ease-in-out"
      >
        <span class="material-symbols-outlined">login</span>
        <span id="action-label">Esperando código válido</span>
      </a>
      <a
        id="review-link"
        href="/guardia/escaner"
        class="mt-3 flex h-12 w-full items-center justify-center rounded-2xl border border-[#213138]/[0.08] text-sm font-semibold text-[#213138] transition hover:bg-[#213138]/[0.04]"
      >
        Volver al escáner
      </a>
      <div
        id="post-movimiento-exito"
        class="mt-4 hidden rounded-2xl border border-[#3d5c4a]/25 bg-[rgba(61,92,74,0.1)] p-4 text-center"
      >
        <p class="text-sm font-semibold text-[#213138]">Movimiento registrado en bitácora.</p>
        <a href="/guardia/escaner" class="nauka-btn-primary mt-3 flex h-11 w-full items-center justify-center rounded-2xl text-sm font-semibold">
          Nueva lectura en caseta
        </a>
        <a
          href="/"
          class="mt-2 flex h-10 w-full items-center justify-center rounded-2xl text-xs font-semibold text-[#5c6569] underline underline-offset-2"
        >
          Ir a la portada
        </a>
      </div>
    </div>
  </section>
</AppLayout>

<script>
  import { BrowserMultiFormatReader } from "@zxing/browser";
  import type { IScannerControls } from "@zxing/browser";
  import { countPendingGuardMovements, enqueueGuardMovement, flushGuardMovementQueue } from "../../lib/guard-queue";

  const scannerRoot = document.querySelector("[data-complejo-id]");
  const accessButtons = Array.from(document.querySelectorAll(".access-toggle"));
  const actionLabel = document.getElementById("action-label");
  const statusTitle = document.getElementById("status-title");
  const statusChip = document.getElementById("status-chip");
  const accessAction = document.getElementById("access-action");
  const reviewLink = document.getElementById("review-link");
  const reasonNode = document.getElementById("validation-reason");
  const cameraPermission = document.getElementById("camera-permission");
  const cameraStatus = document.getElementById("camera-status");
  const cameraVideo = document.getElementById("camera-video");
  const cameraFallback = document.getElementById("camera-fallback");
  const manualTokenInput = document.getElementById("manual-token");
  const validateTokenButton = document.getElementById("validate-token");
  const visitorNameNode = document.getElementById("visitor-name");
  const lotNode = document.getElementById("lot-number");
  const evidenceWrap = document.getElementById("evidence-wrap");
  const evidenceInput = document.getElementById("evidence-input");
  const resolvedComplejoId = scannerRoot?.getAttribute("data-complejo-id") ?? "complejo-1";

  let accessType = "entrada";
  let qrState = "invalido";
  let currentToken = "";
  let networkError = false;
  let scanIntervalId = 0;
  let zxingControls: IScannerControls | null = null;
  let zxingScanConsumed = false;
  let hasValidated = false;
  const invitationEl = document.getElementById("nauka-invitation");
  const chipLabel = document.getElementById("status-chip-label");

  type PassDetail = {
    solicitanteNombre?: string;
    solicitanteLote?: string | null;
    solicitanteFotoUrl?: string | null;
    solicitanteIneUrl?: string | null;
    motivo?: string | null;
    notas?: string | null;
    vencimiento?: string;
    visitanteFotoUrl?: string | null;
    visitanteIneUrl?: string | null;
  };
  let passDetail: PassDetail | null = null;

  function setOptionalImage(
    img: HTMLImageElement | null,
    placeholder: HTMLElement | null,
    url: string | null | undefined,
    openImageOnClick = true
  ) {
    if (!img || !placeholder) return;
    if (url) {
      img.src = url;
      img.classList.remove("hidden");
      placeholder.classList.add("hidden");
      img.onclick = openImageOnClick ? () => window.open(url, "_blank", "noopener,noreferrer") : null;
    } else {
      img.removeAttribute("src");
      img.classList.add("hidden");
      placeholder.classList.remove("hidden");
      img.onclick = null;
    }
  }

  function updatePassDetailPanel() {
    const panel = document.getElementById("pass-detail-panel");
    if (!panel) return;
    if (!hasValidated || qrState !== "valido" || !passDetail) {
      panel.classList.add("hidden");
      return;
    }
    panel.classList.remove("hidden");

    const nameEl = document.getElementById("pass-solicitante-name");
    const loteEl = document.getElementById("pass-solicitante-lote");
    if (nameEl) nameEl.textContent = passDetail.solicitanteNombre ?? "Solicitante";
    if (loteEl) loteEl.textContent = `Solicitante · Lote ${passDetail.solicitanteLote ?? "—"}`;

    const sImg = document.getElementById("pass-solicitante-photo");
    const sPh = document.getElementById("pass-solicitante-photo-ph");
    if (sImg instanceof HTMLImageElement && sPh) {
      setOptionalImage(sImg, sPh, passDetail.solicitanteFotoUrl);
    }

    const sIne = document.getElementById("pass-solicitante-ine");
    const solicitanteIneUrl = passDetail.solicitanteIneUrl;
    if (sIne instanceof HTMLImageElement) {
      if (solicitanteIneUrl) {
        sIne.src = solicitanteIneUrl;
        sIne.classList.remove("hidden");
        sIne.onclick = () => window.open(solicitanteIneUrl, "_blank", "noopener,noreferrer");
      } else {
        sIne.classList.add("hidden");
        sIne.removeAttribute("src");
        sIne.onclick = null;
      }
    }

    const motivoEl = document.getElementById("pass-motivo");
    const notasEl = document.getElementById("pass-notas");
    const venceEl = document.getElementById("pass-vence");
    if (motivoEl) motivoEl.textContent = passDetail.motivo?.trim() || "—";
    if (notasEl) notasEl.textContent = passDetail.notas?.trim() || "Sin notas para caseta.";
    if (venceEl) {
      venceEl.textContent = passDetail.vencimiento
        ? new Date(passDetail.vencimiento).toLocaleString("es-MX", { dateStyle: "medium", timeStyle: "short" })
        : "—";
    }

    const vFace = document.getElementById("pass-visitor-face");
    const vFacePh = document.getElementById("pass-visitor-face-ph");
    const vIne = document.getElementById("pass-visitor-ine");
    const vInePh = document.getElementById("pass-visitor-ine-ph");
    if (vFace instanceof HTMLImageElement && vFacePh) {
      setOptionalImage(vFace, vFacePh, passDetail.visitanteFotoUrl, false);
    }
    if (vIne instanceof HTMLImageElement && vInePh) {
      setOptionalImage(vIne, vInePh, passDetail.visitanteIneUrl, false);
    }

    const wrapFace = document.getElementById("pass-visitor-face-wrap");
    const wrapIne = document.getElementById("pass-visitor-ine-wrap");
    if (wrapFace instanceof HTMLButtonElement) {
      const u = passDetail.visitanteFotoUrl;
      wrapFace.disabled = !u;
      wrapFace.onclick = u ? () => window.open(u, "_blank", "noopener,noreferrer") : null;
    }
    if (wrapIne instanceof HTMLButtonElement) {
      const u = passDetail.visitanteIneUrl;
      wrapIne.disabled = !u;
      wrapIne.onclick = u ? () => window.open(u, "_blank", "noopener,noreferrer") : null;
    }

    const modeLab = document.getElementById("pass-confirm-mode-label");
    if (modeLab) modeLab.textContent = accessType === "salida" ? "la salida" : "la entrada";
  }

  const normalizeType = (value: string | null) => (value === "salida" ? "salida" : "entrada");
  const extractToken = (rawValue: string) => {
    if (!rawValue) return "";
    const trimmed = String(rawValue).trim();
    if (!trimmed) return "";
    if (!trimmed.includes("http://") && !trimmed.includes("https://")) return trimmed;
    try {
      const parsed = new URL(trimmed);
      const queryCode = parsed.searchParams.get("code");
      if (queryCode) return queryCode;
      const parts = parsed.pathname.split("/").filter(Boolean);
      if (parts.length >= 2 && parts[0] === "pase") return decodeURIComponent(parts[1]);
      return "";
    } catch {
      return "";
    }
  };

  const readStateFromUrl = () => {
    const params = new URLSearchParams(window.location.search);
    accessType = normalizeType(params.get("type"));
    const urlToken = extractToken(params.get("code") ?? window.location.href);
    if (urlToken) {
      currentToken = urlToken;
      if (manualTokenInput instanceof HTMLInputElement) manualTokenInput.value = urlToken;
    }
  };

  const syncUrlFromState = () => {
    const params = new URLSearchParams(window.location.search);
    params.set("type", accessType);
    if (currentToken) params.set("code", currentToken);
    const next = `${window.location.pathname}?${params.toString()}`;
    window.history.replaceState(null, "", next);
  };

  const setCameraStatus = (message: string, isError = false) => {
    if (!cameraStatus) return;
    cameraStatus.textContent = message;
    cameraStatus.className = `mt-2 text-center text-xs font-medium ${isError ? "text-[#9a6b5c]" : "text-[#5c6569]"}`;
  };

  const validateTokenOnServer = async (token: string) => {
    let response: Response;
    try {
      response = await fetch("/api/validar-qr", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ token, complejoId: resolvedComplejoId })
      });
    } catch {
      throw new Error("__network__");
    }
    if (!response.ok) throw new Error("__server__");
    return response.json();
  };

  const processToken = async (token: string) => {
    const normalizedToken = extractToken(token);
    if (!normalizedToken) return;
    currentToken = normalizedToken;
    passDetail = null;
    networkError = false;
    try {
      const result = (await validateTokenOnServer(normalizedToken)) as PassDetail & {
        status: string;
        visitanteNombre?: string;
        lote?: string;
        razon?: string;
      };
      hasValidated = true;
      qrState = result.status === "authorized" ? "valido" : "invalido";
      if (result.status === "authorized") {
        passDetail = {
          solicitanteNombre: result.solicitanteNombre,
          solicitanteLote: result.solicitanteLote ?? null,
          solicitanteFotoUrl: result.solicitanteFotoUrl ?? null,
          solicitanteIneUrl: result.solicitanteIneUrl ?? null,
          motivo: result.motivo ?? null,
          notas: result.notas ?? null,
          vencimiento: result.vencimiento,
          visitanteFotoUrl: result.visitanteFotoUrl ?? null,
          visitanteIneUrl: result.visitanteIneUrl ?? null
        };
      }
      if (visitorNameNode && result.visitanteNombre) visitorNameNode.textContent = result.visitanteNombre;
      if (lotNode && result.lote) lotNode.textContent = `Lote ${result.lote}`;
      if (result.status !== "authorized") {
        if (visitorNameNode) visitorNameNode.textContent = result.visitanteNombre ?? "Sin autorización";
        if (lotNode) lotNode.textContent = result.lote ? `Lote ${result.lote}` : "—";
      }
      if (reasonNode) {
        reasonNode.textContent =
          result.status === "authorized"
            ? "Invitación verificada. Revisa fotos y permiso, elige entrada o salida y confirma en caseta."
            : `Motivo: ${result.razon ?? "Token no encontrado o inválido"}`;
      }
      setCameraStatus(result.status === "authorized" ? "Código válido." : "Código no válido.", result.status !== "authorized");
    } catch (err) {
      hasValidated = true;
      qrState = "invalido";
      passDetail = null;
      networkError = err instanceof Error && err.message === "__network__";
      if (visitorNameNode) visitorNameNode.textContent = "Sin lectura";
      if (lotNode) lotNode.textContent = "—";
      if (reasonNode) {
        reasonNode.textContent = networkError
          ? "Sin conexión. Revisa la red o inténtalo de nuevo."
          : "No se pudo validar el código. Intenta otra vez.";
      }
      setCameraStatus(networkError ? "Sin conexión." : "Error de validación.", true);
    }
    render();
  };

  const stopAllScanning = () => {
    if (scanIntervalId) {
      window.clearInterval(scanIntervalId);
      scanIntervalId = 0;
    }
    if (zxingControls) {
      zxingControls.stop();
      zxingControls = null;
    }
    zxingScanConsumed = false;
  };

  const startRealtimeScanner = () => {
    if (!(cameraVideo instanceof HTMLVideoElement)) return;
    stopAllScanning();

    if ("BarcodeDetector" in window) {
      const BarcodeDetectorCtor = (window as unknown as { BarcodeDetector: new (opts: { formats: string[] }) => { detect: (v: HTMLVideoElement) => Promise<{ rawValue?: string }[]> } }).BarcodeDetector;
      const detector = new BarcodeDetectorCtor({ formats: ["qr_code"] });
      scanIntervalId = window.setInterval(async () => {
        try {
          const codes = await detector.detect(cameraVideo);
          if (codes.length > 0 && codes[0].rawValue) {
            window.clearInterval(scanIntervalId);
            scanIntervalId = 0;
            await processToken(codes[0].rawValue);
          }
        } catch {
          // seguir sondeando
        }
      }, 700);
      setCameraStatus("Cámara activa (escaneo automático).");
      return;
    }

    const stream = cameraVideo.srcObject;
    if (!(stream instanceof MediaStream)) {
      setCameraStatus("No hay transmisión de cámara para leer el QR.", true);
      return;
    }

    const reader = new BrowserMultiFormatReader();
    reader
      .decodeFromStream(stream, cameraVideo, async (result, err) => {
        if (zxingScanConsumed) return;
        if (err) return;
        const text = result?.getText();
        if (!text) return;
        zxingScanConsumed = true;
        zxingControls?.stop();
        zxingControls = null;
        await processToken(text);
      })
      .then((controls) => {
        zxingControls = controls;
        setCameraStatus("Cámara activa — apunta el QR al recuadro (Safari y Firefox).");
      })
      .catch(() => {
        setCameraStatus("No se pudo iniciar el lector QR. Usa validación manual con el token.", true);
      });
  };

  const requestCamera = async () => {
    if (!(cameraVideo instanceof HTMLVideoElement)) return;
    if (!navigator.mediaDevices?.getUserMedia) {
      setCameraStatus("Tu navegador no soporta cámara.", true);
      return;
    }
    try {
      const stream = await navigator.mediaDevices.getUserMedia({
        video: {
          facingMode: { ideal: "environment" }
        },
        audio: false
      });
      cameraVideo.srcObject = stream;
      cameraVideo.classList.remove("hidden");
      if (cameraFallback instanceof HTMLImageElement) {
        cameraFallback.classList.add("hidden");
      }
      setCameraStatus("Cámara activa (modo escáner).");
      if (cameraPermission) {
        cameraPermission.textContent = "Cámara activa";
        cameraPermission.className = "nauka-btn-primary h-10 w-full rounded-2xl text-sm font-semibold";
      }
      startRealtimeScanner();
    } catch {
      setCameraStatus("Permiso denegado o cámara no disponible.", true);
    }
  };

  const updateQueueUi = async () => {
    const n = await countPendingGuardMovements();
    const bar = document.getElementById("guard-queue-bar");
    const text = document.getElementById("guard-queue-text");
    if (bar && text) {
      if (n > 0) {
        bar.classList.remove("hidden");
        text.textContent = `Pendientes de sincronizar: ${n}`;
      } else {
        bar.classList.add("hidden");
      }
    }
  };

  const registerMovement = async () => {
    if (!currentToken || qrState !== "valido") {
      const reason = encodeURIComponent(reasonNode?.textContent ?? "Token invalido");
      window.location.href = `/guardia/acceso-denegado?reason=${reason}`;
      return;
    }
    let evidenciaPath = "";
    if (accessType === "salida") {
      const fileInput = evidenceInput instanceof HTMLInputElement ? evidenceInput : null;
      const file = fileInput?.files?.[0];
      if (!file) {
        alert("La salida requiere una foto de evidencia.");
        return;
      }
      const fd = new FormData();
      fd.append("file", file);
      let uploadRes: Response;
      try {
        uploadRes = await fetch("/api/guardia/subir-evidencia", { method: "POST", body: fd });
      } catch {
        alert("Sin conexión. No se pudo subir la evidencia. Intenta cuando haya red.");
        return;
      }
      if (!uploadRes.ok) {
        const payload = await uploadRes.json().catch(() => ({}));
        alert(payload.error ?? "No se pudo subir la evidencia.");
        return;
      }
      const uploadPayload = await uploadRes.json().catch(() => ({}));
      evidenciaPath = typeof uploadPayload.path === "string" ? uploadPayload.path : "";
      if (!evidenciaPath) {
        alert("No se recibió la ruta de evidencia.");
        return;
      }
    }
    let response: Response;
    try {
      response = await fetch("/api/guardia/registrar-movimiento", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          token: currentToken,
          tipoEvento: accessType,
          evidenciaStoragePath: evidenciaPath || undefined
        })
      });
    } catch {
      await enqueueGuardMovement({
        token: currentToken,
        tipoEvento: accessType === "salida" ? "salida" : "entrada",
        evidenciaStoragePath: evidenciaPath || null
      });
      setCameraStatus("Movimiento en cola local. Sincroniza cuando haya red.");
      void updateQueueUi();
      return;
    }
    if (!response.ok) {
      const payload = await response.json().catch(() => ({}));
      if (response.status === 400) {
        alert(typeof payload.error === "string" ? payload.error : "No se pudo registrar movimiento.");
        return;
      }
      await enqueueGuardMovement({
        token: currentToken,
        tipoEvento: accessType === "salida" ? "salida" : "entrada",
        evidenciaStoragePath: evidenciaPath || null
      });
      setCameraStatus("Movimiento en cola local. Sincroniza cuando haya red.");
      void updateQueueUi();
      return;
    }
    setCameraStatus("Registrado. El administrador recibió la notificación de " + (accessType === "salida" ? "salida" : "entrada") + ".");
    window.setTimeout(() => {
      window.location.href = "/guardia/escaner?ok=1";
    }, 900);
  };

  const render = () => {
    accessButtons.forEach((button) => {
      const active = button.getAttribute("data-access-type") === accessType;
      button.className = `access-toggle h-11 rounded-2xl text-base font-semibold transition duration-[400ms] ease-in-out ${
        active ? "nauka-btn-primary text-[#FCFBF9]" : "border border-[#213138]/[0.08] bg-[#FCFBF9]/80 text-[#213138] hover:bg-white"
      }`;
    });

    if (!actionLabel || !statusTitle || !statusChip || !accessAction) return;
    const netBanner = document.getElementById("scanner-network-banner");
    if (netBanner) {
      netBanner.classList.toggle("hidden", !(networkError && hasValidated));
    }
    if (evidenceWrap) {
      evidenceWrap.classList.toggle("hidden", accessType !== "salida");
      evidenceWrap.classList.toggle("flex", accessType === "salida");
    }
    const state = !hasValidated ? "idle" : qrState === "valido" ? "authorized" : "denied";
    invitationEl?.setAttribute("data-state", state);

    if (visitorNameNode) {
      visitorNameNode.className =
        qrState === "valido" && hasValidated
          ? "font-display mt-1 text-3xl leading-tight text-[#213138] md:text-[2.25rem]"
          : "mt-1 text-2xl font-medium text-[#213138] md:text-3xl";
    }

    if (chipLabel) {
      chipLabel.textContent = !hasValidated
        ? "En espera"
        : networkError
          ? "Sin red"
          : qrState === "valido"
            ? "Invitación válida"
            : "No autorizado";
    }

    const chipIcon = statusChip.querySelector(".material-symbols-outlined");
    if (chipIcon) {
      const icon = !hasValidated ? "qr_code_scanner" : networkError ? "wifi_off" : qrState === "valido" ? "verified" : "gpp_maybe";
      chipIcon.textContent = icon;
      chipIcon.className = "material-symbols-outlined text-[20px]";
    }

    if (qrState === "valido" && hasValidated) {
      actionLabel.textContent = accessType === "entrada" ? "Confirmar entrada en caseta" : "Confirmar salida en caseta";
      statusTitle.textContent = "Visitante autorizado";
      statusChip.className = "nauka-chip-ok mb-4 inline-flex items-center gap-2 rounded-full px-3 py-2";
      accessAction.className =
        "nauka-btn-primary mt-8 flex h-14 w-full items-center justify-center gap-2 rounded-2xl text-lg font-semibold transition duration-[400ms] ease-in-out";
      if (reviewLink instanceof HTMLAnchorElement) {
        reviewLink.href = "/guardia/escaner";
        reviewLink.textContent = "Escanear otro código";
      }
    } else if (networkError && hasValidated) {
      actionLabel.textContent = "Reintentar validación";
      statusTitle.textContent = "Sin conexión";
      statusChip.className = "nauka-chip-warn mb-4 inline-flex items-center gap-2 rounded-full px-3 py-2";
      accessAction.className =
        "nauka-btn-primary mt-8 flex h-14 w-full items-center justify-center gap-2 rounded-2xl text-lg font-semibold transition duration-[400ms] ease-in-out";
      if (reviewLink instanceof HTMLAnchorElement) {
        reviewLink.href = "/guardia/escaner";
        reviewLink.textContent = "Limpiar pantalla";
      }
    } else if (hasValidated) {
      actionLabel.textContent = "Ver motivo en caseta";
      statusTitle.textContent = "Acceso no autorizado";
      statusChip.className = "nauka-chip-warn mb-4 inline-flex items-center gap-2 rounded-full px-3 py-2";
      accessAction.className =
        "mt-8 flex h-14 w-full items-center justify-center gap-2 rounded-2xl border border-[#9a6b5c]/25 bg-[#9a6b5c]/[0.08] text-lg font-semibold text-[#6b4f45] transition duration-[400ms] ease-in-out";
      if (reviewLink instanceof HTMLAnchorElement) {
        reviewLink.href = "/guardia/escaner";
        reviewLink.textContent = "Intentar de nuevo";
      }
    } else {
      actionLabel.textContent = "Esperando código válido";
      statusTitle.textContent = "Listo para escanear";
      statusChip.className = "nauka-chip-neutral mb-4 inline-flex items-center gap-2 rounded-full px-3 py-2";
      accessAction.className =
        "mt-8 flex h-14 w-full items-center justify-center gap-2 rounded-2xl border border-[#213138]/10 bg-[#213138]/[0.04] text-lg font-semibold text-[#213138] transition duration-[400ms] ease-in-out";
      if (reviewLink instanceof HTMLAnchorElement) {
        reviewLink.href = "/guardia/escaner";
        reviewLink.textContent = "Volver al escáner";
      }
    }
    syncUrlFromState();
    updatePassDetailPanel();
  };

  accessButtons.forEach((button) => {
    button.addEventListener("click", () => {
      accessType = button.getAttribute("data-access-type") ?? "entrada";
      render();
    });
  });

  accessAction?.addEventListener("click", (event) => {
    event.preventDefault();
    if (networkError && currentToken) {
      void processToken(currentToken);
      return;
    }
    registerMovement();
  });

  cameraPermission?.addEventListener("click", () => {
    requestCamera();
  });

  validateTokenButton?.addEventListener("click", () => {
    const token = manualTokenInput instanceof HTMLInputElement ? manualTokenInput.value.trim() : "";
    processToken(token);
  });

  readStateFromUrl();
  void updateQueueUi();
  void flushGuardMovementQueue(() => {}).then(() => updateQueueUi());

  document.getElementById("guard-sync-now")?.addEventListener("click", () => {
    void flushGuardMovementQueue(() => {}).then(() => updateQueueUi());
  });

  const okParam = new URLSearchParams(window.location.search).get("ok");
  if (okParam === "1") {
    setCameraStatus("Último movimiento enviado al panel del administrador.");
    document.getElementById("post-movimiento-exito")?.classList.remove("hidden");
    const u = new URL(window.location.href);
    u.searchParams.delete("ok");
    window.history.replaceState(null, "", u.pathname + (u.search || ""));
  }
  if (currentToken) {
    processToken(currentToken);
  }
  render();
</script>
