---
import "../styles/global.css";
import loginBackground from "../../491461670_17919450432084004_8291959886084544470_n.jpg";

const error = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#FCFBF9" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600&display=swap"
      rel="stylesheet"
    />
    <title>Iniciar sesión - Nauka Nayarit</title>
  </head>
  <body class="min-h-screen bg-[#213138] text-[#FCFBF9] antialiased">
    <main class="relative mx-auto flex min-h-[100dvh] w-full max-w-[430px] items-center justify-center overflow-hidden p-5">
      <div
        class="absolute inset-0 bg-cover bg-center bg-no-repeat"
        style={`background-image: url(${loginBackground.src});`}
      ></div>
      <div class="absolute inset-0 bg-[#213138]/55 backdrop-blur-[3px]"></div>

      <section class="nauka-hero-glass relative z-10 w-full space-y-8 rounded-[32px] px-6 py-8 shadow-[0_28px_64px_rgba(15,28,34,0.35)]">
        <header class="text-center">
          <p class="font-display text-[1.65rem] tracking-[0.18em] text-[#FCFBF9]">Nauka Nayarit</p>
          <p class="mt-2 text-sm font-medium tracking-[0.12em] text-[#FCFBF9]/85">Acceso solicitantes y operación</p>
        </header>

        <form class="nauka-login-card space-y-6 px-5 py-7 text-[#213138]" method="post" action="/api/auth/login">
          <h1 class="font-display text-3xl">Iniciar sesión</h1>
          {error && <p class="rounded-2xl border border-[#9a6b5c]/25 bg-[#9a6b5c]/[0.1] px-3 py-2 text-sm font-medium text-[#6b4f45]">{error}</p>}
          {success && <p class="nauka-chip-ok rounded-2xl px-3 py-2 text-sm font-medium">{success}</p>}

          <div>
            <label class="nauka-label-lux" for="email">Correo</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              placeholder="tu@correo.com"
              class="nauka-input-lux text-base"
            />
          </div>

          <div>
            <div class="flex items-center justify-between gap-3">
              <label class="nauka-label-lux mb-0" for="password">Contraseña</label>
              <a href="#" class="text-xs font-semibold text-[#5c6569] transition duration-[400ms] ease-in-out hover:text-[#213138]">Olvidé mi contraseña</a>
            </div>
            <input
              id="password"
              name="password"
              type="password"
              autocomplete="current-password"
              placeholder="••••••••"
              class="nauka-input-lux text-base"
            />
          </div>

          <button type="submit" class="nauka-btn-primary mt-2 flex h-14 w-full items-center justify-center rounded-2xl text-base font-semibold">
            Ingresar
          </button>

          <p class="pt-2 text-center text-sm text-[#5c6569]">
            ¿No tienes acceso?
            <a href="/registro" class="font-semibold text-[#3d5c4a] transition duration-[400ms] ease-in-out hover:text-[#213138]">Cómo darte de alta</a>
          </p>
        </form>

        <p class="text-center text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-[#FCFBF9]/65">Portal de acceso seguro</p>
      </section>
    </main>
  </body>
</html>
