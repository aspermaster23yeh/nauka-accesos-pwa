---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Cuenta suspendida">
  <div class="rounded-2xl bg-red-50 p-6 text-red-950">
    <p class="text-lg font-semibold">Acceso suspendido</p>
    <p class="mt-2 text-sm leading-relaxed">Tu cuenta no puede operar en este momento. Contacta a administración de Nauka.</p>
    <a href="/" class="mt-6 flex h-12 w-full items-center justify-center rounded-2xl bg-red-900 text-sm font-semibold text-white transition hover:opacity-95">
      Ir a la página principal
    </a>
    <form method="post" action="/api/auth/logout" class="mt-4">
      <button type="submit" class="text-sm font-semibold text-red-900 underline">Cerrar sesión</button>
    </form>
  </div>
</MainLayout>
