---
import AppLayout from "../../layouts/AppLayout.astro";
import { getRoleHome } from "../../lib/role-home";

const token = Astro.params.token ?? "";
const tipo = Astro.url.searchParams.get("type") === "salida" ? "salida" : "entrada";
const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=520x520&data=${encodeURIComponent(token)}`;
const profile = Astro.locals.profile;
const roleHome = getRoleHome(profile?.role);
const loggedIn = Boolean(profile);
const isSolicitante = profile?.role === "solicitante";
---

<AppLayout
  title="Pase de Acceso - Nauka Nayarit"
  topBar={{ title: "Pase de Acceso", leftIcon: "arrow_back", leftHref: loggedIn ? roleHome : "/" }}
>
  <section
    id="pase-publico-root"
    class="rounded-[14px] bg-white p-5 shadow-[0_8px_24px_rgba(26,28,28,0.06)] text-center"
    data-token={token}
    data-tipo={tipo}
  >
    <h1 class="text-3xl font-extrabold tracking-tight text-[#213138]">Pase para visitante</h1>
    <p class="mt-2 text-sm text-[#5f6368]">Muestra este QR en caseta para validar tu acceso.</p>
    <div class="mt-5 rounded-xl bg-[#eeeeee] p-5">
      <img src={qrUrl} alt="QR de acceso" class="mx-auto h-60 w-60 rounded-xl bg-white p-2 shadow-sm" />
      <p class="mt-3 text-xs font-semibold uppercase tracking-[0.08em] text-[#64748b]">Tipo: {tipo}</p>
      <p class="mt-1 break-all text-xs font-semibold text-[#37474f]">{token}</p>
    </div>

    <div class="mt-6 space-y-3 text-left">
      <p class="text-center text-xs text-[#5f6368]">
        Comparte el QR por WhatsApp como imagen o PDF. En el celular suele abrirse el menú de compartir; si no, se descarga el archivo y se abre el chat.
      </p>
      <button
        id="share-pase-qr-image"
        type="button"
        class="h-14 w-full rounded-2xl border border-[#3d5c4a]/20 bg-[rgba(61,92,74,0.1)] text-base font-semibold text-[#2d4a3a] transition duration-[400ms] ease-in-out hover:bg-[rgba(61,92,74,0.16)] disabled:cursor-wait disabled:opacity-60"
      >
        WhatsApp · imagen del QR
      </button>
      <button
        id="share-pase-pdf"
        type="button"
        class="flex h-14 w-full items-center justify-center rounded-2xl border border-[#213138]/12 bg-[#FCFBF9] text-base font-semibold text-[#213138] transition hover:bg-white disabled:cursor-wait disabled:opacity-60"
      >
        WhatsApp · PDF del pase
      </button>
    </div>

    <div class="mt-8 space-y-3 text-left">
      {
        loggedIn ? (
          <>
            <a
              href={roleHome}
              class="nauka-btn-primary flex h-14 w-full items-center justify-center rounded-2xl text-base font-semibold"
            >
              Ir a mi panel
            </a>
            {isSolicitante && (
              <a
                href="/solicitante/nuevo-pase"
                class="flex h-12 w-full items-center justify-center rounded-2xl border border-[#213138]/12 bg-[#FCFBF9] text-sm font-semibold text-[#213138] transition hover:bg-white"
              >
                Crear otro pase
              </a>
            )}
          </>
        ) : (
          <a href="/" class="nauka-btn-primary flex h-14 w-full items-center justify-center rounded-2xl text-base font-semibold">
            Ir a iniciar sesión
          </a>
        )
      }
    </div>
  </section>
</AppLayout>

<script>
  import { initPasePublicoShare } from "../../scripts/pase-publico-share";
  initPasePublicoShare();
</script>
