---
import "../styles/global.css";
import loginBackground from "../../491461670_17919450432084004_8291959886084544470_n.jpg";
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0f1f2a" />
    <title>Alta de solicitantes - Nauka Nayarit</title>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100">
    <main class="relative mx-auto flex min-h-[100dvh] w-full max-w-[430px] items-center justify-center overflow-hidden p-5">
      <div
        class="absolute inset-0 bg-cover bg-center bg-no-repeat"
        style={`background-image: url(${loginBackground.src});`}
      ></div>
      <div class="absolute inset-0 bg-slate-950/45 backdrop-blur-[2px]"></div>

      <section class="relative z-10 w-full rounded-[28px] border border-white/20 bg-white/10 px-4 py-5 shadow-[0_28px_56px_rgba(2,8,20,0.48)] backdrop-blur-sm">
        <div class="space-y-5 rounded-[22px] bg-white px-6 py-7 text-slate-800 shadow-xl">
          <header class="space-y-2">
            <h1 class="text-4xl font-semibold tracking-tight">Alta controlada</h1>
            <p class="text-lg leading-relaxed text-slate-600">
              Las cuentas de solicitante, guardia y administrador de complejo las da de alta el equipo Nauka (super administrador), con validación de identificación (INE) cuando aplique.
            </p>
          </header>
          <p class="text-base leading-relaxed text-slate-600">
            Si necesitas acceso, escribe a administración con tu nombre, lote y correo.
          </p>
          <a
            href="/"
            class="mt-2 flex h-14 w-full items-center justify-center rounded-2xl bg-gradient-to-b from-slate-700 to-slate-900 text-lg font-bold text-white transition hover:brightness-110"
          >
            Volver al inicio de sesión
          </a>
        </div>
      </section>
    </main>
  </body>
</html>
