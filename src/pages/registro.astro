---
import "../styles/global.css";
import loginBackground from "../../491461670_17919450432084004_8291959886084544470_n.jpg";
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#FCFBF9" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600&display=swap"
      rel="stylesheet"
    />
    <title>Alta de solicitantes - Nauka Nayarit</title>
  </head>
  <body class="min-h-screen bg-[#213138] text-[#FCFBF9] antialiased">
    <main class="relative mx-auto flex min-h-[100dvh] w-full max-w-[430px] items-center justify-center overflow-hidden p-5">
      <div
        class="absolute inset-0 bg-cover bg-center bg-no-repeat"
        style={`background-image: url(${loginBackground.src});`}
      ></div>
      <div class="absolute inset-0 bg-[#213138]/55 backdrop-blur-[3px]"></div>

      <section class="nauka-hero-glass relative z-10 w-full rounded-[28px] px-4 py-5 shadow-[0_28px_64px_rgba(15,28,34,0.35)]">
        <div class="nauka-login-card space-y-5 px-6 py-7 text-[#213138]">
          <header class="space-y-2">
            <h1 class="font-display text-3xl">Alta controlada</h1>
            <p class="text-base leading-relaxed text-[#5c6569]">
              Las cuentas de solicitante, guardia y administrador de complejo las da de alta el equipo Nauka (super administrador), con validación de identificación (INE) cuando aplique.
            </p>
          </header>
          <p class="text-sm leading-relaxed text-[#5c6569]">
            Si necesitas acceso, escribe a administración con tu nombre, lote y correo.
          </p>
          <a href="/" class="nauka-btn-primary mt-2 flex h-14 w-full items-center justify-center rounded-2xl text-base font-semibold">
            Volver al inicio de sesión
          </a>
        </div>
      </section>
    </main>
  </body>
</html>
