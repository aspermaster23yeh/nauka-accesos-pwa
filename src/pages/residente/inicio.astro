---
import AppLayout from "../../layouts/AppLayout.astro";
import { residentNav } from "../../lib/nav";
import { getActivePassesForResident } from "../../lib/access";
const activePasses = Astro.locals.user && Astro.locals.accessToken
  ? await getActivePassesForResident({
      accessToken: Astro.locals.accessToken,
      userId: Astro.locals.user.id,
      role: "residente",
      complejoId: Astro.locals.profile?.complejo_id ?? "complejo-1",
      lotNumber: Astro.locals.profile?.lot_number
    }).catch(() => [])
  : [];
const lotTitle = Astro.locals.profile?.lot_number ?? "A-22";
---

<AppLayout
  title="Inicio Residente - Nauka Nayarit"
  topBar={{ title: "Nauka Nayarit", leftIcon: "location_on", leftHref: "#", rightIcon: "person", rightHref: "#" }}
  pageTitle={`Lote ${lotTitle}`}
  navItems={residentNav}
>
  <p class="-mt-5 mb-10 text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Panel de Residente</p>

  <a
    href="/residente/nuevo-pase"
    class="mb-10 flex h-24 w-full items-center justify-center gap-3 rounded-[14px] bg-gradient-to-b from-[#213138] to-[#37474f] px-5 text-3xl font-semibold text-white shadow-[0_14px_28px_rgba(26,28,28,0.18)]"
  >
    <span class="material-symbols-outlined text-4xl">add</span>
    <span class="text-3xl">Crear Nuevo Pase de Acceso</span>
  </a>

  <section id="pases-activos" class="space-y-4">
    <h2 class="text-5xl font-bold tracking-[-0.02em] text-[#213138]">Pases Activos</h2>
    <div class="grid grid-cols-2 gap-2 rounded-xl bg-[#eeeeee] p-1">
      <button data-pass-filter="todos" class="pass-filter h-10 rounded-lg bg-[#213138] text-sm font-semibold uppercase tracking-[0.08em] text-white">Todos</button>
      <button data-pass-filter="visita" class="pass-filter h-10 rounded-lg bg-transparent text-sm font-semibold uppercase tracking-[0.08em] text-[#213138]">Solo Visitas</button>
    </div>

    {
      activePasses.length === 0 ? (
        <article class="rounded-[14px] bg-white p-5 text-center shadow-[0_8px_24px_rgba(26,28,28,0.06)]">
          <div class="mx-auto mb-3 grid h-12 w-12 place-items-center rounded-full bg-[#eeeeee] text-[#5f6368]">
            <span class="material-symbols-outlined">badge</span>
          </div>
          <p class="text-xl font-semibold text-[#213138]">Aun no tienes pases activos</p>
          <p class="mt-1 text-sm text-[#5f6368]">Crea tu primer pase para compartirlo por WhatsApp.</p>
          <a href="/residente/nuevo-pase" class="mt-4 inline-flex h-11 items-center justify-center rounded-xl bg-[#213138] px-4 text-sm font-semibold text-white">
            Crear pase
          </a>
        </article>
      ) : (
        activePasses.map((pass) => (
          <article data-pass-type={(pass.motivo ?? "visita").toLowerCase()} class="relative rounded-[14px] bg-white p-5 shadow-[0_8px_24px_rgba(26,28,28,0.06)]">
            <span class="absolute left-0 top-0 h-full w-1 rounded-l-[14px] bg-[#0a8d4f]"></span>
            <div class="flex items-start gap-4 pl-1">
              <div class="grid h-12 w-12 place-items-center rounded-full bg-[#83fba5]/25 text-[#006d36]">
                <span class="material-symbols-outlined">badge</span>
              </div>
              <div class="flex-1">
                <p class="text-4xl font-semibold text-[#213138]">{pass.visitante_nombre}</p>
                <p class="mt-1 text-xl text-[#5f6368]">
                  {new Date(pass.vence_en).toLocaleString("es-MX", { month: "short", day: "2-digit", hour: "2-digit", minute: "2-digit" })} · {(pass.motivo ?? "VISITA").toUpperCase()}
                </p>
                <div class="mt-4 flex gap-3">
                  <a href={`/residente/pase-demo?code=${encodeURIComponent(pass.token_qr)}&state=valid&type=entrada`} class="flex-1 rounded-xl bg-[#eeeeee] px-4 py-3 text-center text-2xl font-semibold text-[#213138]">
                    Ver QR
                  </a>
                  <button data-share-token={pass.token_qr} class="share-pass grid w-12 place-items-center rounded-xl bg-[#25D366]/10 text-[#075E54]">
                    <span class="material-symbols-outlined">chat</span>
                  </button>
                </div>
              </div>
            </div>
          </article>
        ))
      )
    }
  </section>
</AppLayout>

<script is:inline>
  const filterButtons = Array.from(document.querySelectorAll(".pass-filter"));
  const passCards = Array.from(document.querySelectorAll("[data-pass-type]"));
  let activeFilter = "todos";

  const renderFilter = () => {
    filterButtons.forEach((button) => {
      const selected = button.getAttribute("data-pass-filter") === activeFilter;
      button.className = `pass-filter h-10 rounded-lg text-sm font-semibold uppercase tracking-[0.08em] ${
        selected ? "bg-[#213138] text-white" : "bg-transparent text-[#213138]"
      }`;
    });

    passCards.forEach((card) => {
      const type = card.getAttribute("data-pass-type");
      const visible = activeFilter === "todos" || activeFilter === type;
      card.classList.toggle("hidden", !visible);
    });
  };

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      activeFilter = button.getAttribute("data-pass-filter") ?? "todos";
      renderFilter();
    });
  });

  renderFilter();

  Array.from(document.querySelectorAll(".share-pass")).forEach((button) => {
    button.addEventListener("click", () => {
      const token = button.getAttribute("data-share-token") ?? "";
      const url = `${window.location.origin}/pase/${encodeURIComponent(token)}`;
      const text = `Pase Nauka Nayarit%0AMuestra este pase en caseta:%0A${encodeURIComponent(url)}`;
      window.open(`https://wa.me/?text=${text}`, "_blank", "noopener,noreferrer");
    });
  });
</script>
