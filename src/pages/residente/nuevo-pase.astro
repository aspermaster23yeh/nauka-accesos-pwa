---
import AppLayout from "../../layouts/AppLayout.astro";
---

<AppLayout title="Nuevo Acceso - Nauka Nayarit" topBar={{ title: "Nuevo Acceso", leftIcon: "arrow_back", leftHref: "/residente/inicio" }}>
  <section class="rounded-[14px] bg-white p-5 shadow-[0_8px_24px_rgba(26,28,28,0.06)]">
    <form id="pass-form" class="space-y-6">
      <label class="block space-y-2">
        <span class="text-3xl font-medium text-[#213138]">Nombre del Visitante</span>
        <input id="visitor-name" class="h-14 w-full rounded-xl bg-[#f3f3f4] px-4 text-xl outline-none focus:ring-2 focus:ring-[#213138]/25" placeholder="Ej. Juan Pérez" />
      </label>

      <label class="block space-y-2">
        <span class="text-3xl font-medium text-[#213138]">Fecha de Visita</span>
        <input id="visit-date" type="date" class="h-14 w-full rounded-xl bg-[#f3f3f4] px-4 text-xl outline-none focus:ring-2 focus:ring-[#213138]/25" />
      </label>

      <label class="block space-y-2">
        <span class="text-3xl font-medium text-[#213138]">Hora Aproximada</span>
        <input id="visit-time" type="time" class="h-14 w-full rounded-xl bg-[#f3f3f4] px-4 text-xl outline-none focus:ring-2 focus:ring-[#213138]/25" />
      </label>

      <label class="block space-y-2">
        <span class="text-3xl font-medium text-[#213138]">Motivo</span>
        <select id="visit-reason" class="h-14 w-full rounded-xl bg-[#f3f3f4] px-4 text-xl outline-none focus:ring-2 focus:ring-[#213138]/25">
          <option>Seleccione un motivo</option>
          <option>Visita</option>
          <option>Proveedor</option>
          <option>Mantenimiento</option>
        </select>
      </label>

      <div class="grid grid-cols-2 gap-3">
        <label class="block space-y-2">
          <span class="text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Estado de prueba</span>
          <select id="test-state" class="h-12 w-full rounded-xl bg-[#f3f3f4] px-3 text-base outline-none focus:ring-2 focus:ring-[#213138]/25">
            <option value="valid">Valido</option>
            <option value="invalid">Invalido</option>
          </select>
        </label>
        <label class="block space-y-2">
          <span class="text-xs font-bold uppercase tracking-[0.08em] text-[#5f6368]">Tipo de acceso</span>
          <select id="test-type" class="h-12 w-full rounded-xl bg-[#f3f3f4] px-3 text-base outline-none focus:ring-2 focus:ring-[#213138]/25">
            <option value="entrada">Entrada</option>
            <option value="salida">Salida</option>
          </select>
        </label>
      </div>

      <button id="generate-pass" type="button" class="flex h-14 w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-b from-[#213138] to-[#37474f] text-2xl font-semibold text-white">
        <span class="material-symbols-outlined">qr_code_2</span>
        Generar pase
      </button>
    </form>

    <div id="generated-pass" class="mt-6 rounded-xl bg-[#eeeeee] p-6 text-center">
      <div class="mx-auto grid h-52 w-52 place-items-center rounded-xl bg-white shadow-sm">
        <span class="material-symbols-outlined text-8xl text-[#37474f]">qr_code_2</span>
      </div>
      <p id="generated-label" class="mt-4 text-sm font-bold uppercase tracking-[0.08em] text-[#5f6368]">Codigo temporal generado</p>
      <a id="preview-pass-link" href="/residente/pase-demo" class="mt-3 flex h-12 w-full items-center justify-center rounded-xl bg-[#eeeeee] text-base font-semibold text-[#213138]">
        Ver Pase (Imagen/PDF)
      </a>
      <button id="share-whatsapp" type="button" class="mt-3 h-14 w-full rounded-xl bg-[#25D366]/15 text-2xl font-semibold text-[#005227]">Compartir por WhatsApp</button>
    </div>
  </section>
</AppLayout>

<script is:inline>
  const generateButton = document.getElementById("generate-pass");
  const shareButton = document.getElementById("share-whatsapp");
  const generatedLabel = document.getElementById("generated-label");
  const generatedPass = document.getElementById("generated-pass");
  const visitorName = document.getElementById("visitor-name");
  const visitReason = document.getElementById("visit-reason");
  const testState = document.getElementById("test-state");
  const testType = document.getElementById("test-type");
  const previewPassLink = document.getElementById("preview-pass-link");
  const visitDate = document.getElementById("visit-date");
  const visitTime = document.getElementById("visit-time");

  let currentCode = "";
  let currentShareUrl = "";

  const createCode = () => {
    const seed = Math.random().toString(36).slice(2, 8).toUpperCase();
    return `NK-${seed}`;
  };

  const combineDateTime = () => {
    if (!(visitDate instanceof HTMLInputElement) || !(visitTime instanceof HTMLInputElement)) return "";
    if (!visitDate.value || !visitTime.value) return "";
    return `${visitDate.value}T${visitTime.value}:00`;
  };

  generateButton?.addEventListener("click", async () => {
    const name = visitorName instanceof HTMLInputElement ? visitorName.value.trim() : "";
    const reason = visitReason instanceof HTMLSelectElement ? visitReason.value : "Visita";
    const venceEn = combineDateTime();
    if (!name || !venceEn) {
      alert("Completa nombre, fecha y hora.");
      return;
    }
    const response = await fetch("/api/residente/pases", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        visitanteNombre: name,
        motivo: reason,
        venceEn
      })
    });
    if (!response.ok) {
      const payload = await response.json().catch(() => ({}));
      alert(payload.error ?? "No se pudo crear el pase.");
      return;
    }
    const payload = await response.json();
    currentCode = payload.pass?.tokenQr ?? createCode();
    const state = testState instanceof HTMLSelectElement ? testState.value : "valid";
    const type = testType instanceof HTMLSelectElement ? testType.value : "entrada";
    currentShareUrl = `${window.location.origin}/guardia/escaner?state=${encodeURIComponent(state)}&type=${encodeURIComponent(type)}&code=${encodeURIComponent(currentCode)}`;
    if (generatedLabel) {
      generatedLabel.textContent = `Codigo temporal generado: ${currentCode}`;
    }
    if (previewPassLink instanceof HTMLAnchorElement) {
      previewPassLink.href = `/residente/pase-demo?code=${encodeURIComponent(currentCode)}&state=${encodeURIComponent(state)}&type=${encodeURIComponent(type)}`;
    }
    window.location.href = `/residente/pase-demo?code=${encodeURIComponent(currentCode)}&state=${encodeURIComponent(state)}&type=${encodeURIComponent(type)}`;
    if (generatedPass) {
      generatedPass.classList.add("ring-2", "ring-[#213138]/15");
    }
  });

  shareButton?.addEventListener("click", () => {
    const name = visitorName instanceof HTMLInputElement ? visitorName.value || "Visitante" : "Visitante";
    const reason = visitReason instanceof HTMLSelectElement ? visitReason.value || "Visita" : "Visita";
    const code = currentCode || createCode();
    const state = testState instanceof HTMLSelectElement ? testState.value : "valid";
    const type = testType instanceof HTMLSelectElement ? testType.value : "entrada";
    const url = currentShareUrl || `${window.location.origin}/guardia/escaner?state=${encodeURIComponent(state)}&type=${encodeURIComponent(type)}&code=${encodeURIComponent(code)}`;
    const text = `Pase Nauka Nayarit%0AVisitante: ${encodeURIComponent(name)}%0AMotivo: ${encodeURIComponent(reason)}%0ACodigo: ${encodeURIComponent(code)}%0AValidar en caseta: ${encodeURIComponent(url)}`;
    window.open(`https://wa.me/?text=${text}`, "_blank", "noopener,noreferrer");
  });
</script>
