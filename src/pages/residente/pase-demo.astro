---
import AppLayout from "../../layouts/AppLayout.astro";

export const prerender = true;
---

<AppLayout title="Pase Demo - Nauka Nayarit" topBar={{ title: "Pase generado", leftIcon: "arrow_back", leftHref: "/residente/nuevo-pase" }}>
  <style is:inline>
    @media print {
      body {
        background: #ffffff !important;
      }
      header,
      nav,
      #share-image,
      #download-pdf {
        display: none !important;
      }
      #printable-pass {
        box-shadow: none !important;
        border: 1px solid #d9d9d9 !important;
      }
      #guard-link {
        color: #334155 !important;
      }
      #pass-watermark {
        opacity: 0.22 !important;
      }
    }
  </style>

  <section id="printable-pass" class="relative overflow-hidden rounded-[14px] bg-white p-5 shadow-[0_8px_24px_rgba(26,28,28,0.06)]">
    <div id="pass-watermark" class="pointer-events-none absolute right-[-34px] top-10 rotate-[28deg] rounded-lg border-2 px-7 py-2 text-lg font-extrabold uppercase tracking-[0.08em]">
      --
    </div>
    <div class="mb-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="grid h-12 w-12 place-items-center rounded-full bg-[#213138] text-white">
          <span class="material-symbols-outlined">shield</span>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#64748b]">Control de accesos</p>
          <h1 class="text-2xl font-extrabold tracking-tight text-[#213138]">Nauka Nayarit</h1>
        </div>
      </div>
      <p id="pass-folio" class="rounded-lg bg-[#eeeeee] px-3 py-2 text-xs font-bold uppercase tracking-[0.08em] text-[#213138]">Folio: --</p>
    </div>

    <h2 class="text-3xl font-extrabold tracking-tight text-[#213138]">Pase digital para caseta</h2>
    <p id="pass-meta" class="mt-1 text-sm text-[#5f6368]">Codigo: --</p>

    <div class="mt-5 rounded-xl bg-[#eeeeee] p-5 text-center">
      <img id="qr-image" alt="QR de pase" class="mx-auto h-56 w-56 rounded-xl bg-white p-2 shadow-sm" />
      <div class="mt-4 grid grid-cols-2 gap-2 text-left">
        <div class="rounded-lg bg-white p-3">
          <p class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#64748b]">Expira</p>
          <p id="pass-expiry" class="text-sm font-semibold text-[#213138]">--</p>
        </div>
        <div class="rounded-lg bg-white p-3">
          <p class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#64748b]">Firma visual</p>
          <p class="text-sm font-semibold text-[#213138]">Nauka Secure Pass</p>
        </div>
      </div>
      <p id="guard-link" class="mt-3 break-all text-xs font-semibold text-[#37474f]"></p>
    </div>

    <div class="mt-4 space-y-3">
      <button id="share-image" type="button" class="h-12 w-full rounded-xl bg-[#25D366]/15 text-base font-semibold text-[#005227]">
        Compartir imagen (WhatsApp)
      </button>
      <button id="download-pdf" type="button" class="h-12 w-full rounded-xl bg-gradient-to-b from-[#213138] to-[#37474f] text-base font-semibold text-white">
        Descargar PDF
      </button>
    </div>
  </section>
</AppLayout>

<script is:inline>
  const params = new URLSearchParams(window.location.search);
  const code = params.get("code") || "NK-DEMO01";
  const state = params.get("state") === "invalid" ? "invalid" : "valid";
  const type = params.get("type") === "salida" ? "salida" : "entrada";
  const guardUrl = `${window.location.origin}/guardia/escaner?state=${state}&type=${type}&code=${encodeURIComponent(code)}`;
  const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=520x520&data=${encodeURIComponent(guardUrl)}`;

  const qrImage = document.getElementById("qr-image");
  const passMeta = document.getElementById("pass-meta");
  const guardLink = document.getElementById("guard-link");
  const passFolio = document.getElementById("pass-folio");
  const passExpiry = document.getElementById("pass-expiry");
  const passWatermark = document.getElementById("pass-watermark");
  const shareImageButton = document.getElementById("share-image");
  const downloadPdfButton = document.getElementById("download-pdf");
  const expiryDate = new Date(Date.now() + 4 * 60 * 60 * 1000);
  const folio = `NAU-${code.replace("NK-", "")}-${new Date().getFullYear()}`;

  if (qrImage instanceof HTMLImageElement) qrImage.src = qrUrl;
  if (passMeta) passMeta.textContent = `Codigo: ${code} · Estado: ${state} · Tipo: ${type}`;
  if (guardLink) guardLink.textContent = guardUrl;
  if (passFolio) passFolio.textContent = `Folio: ${folio}`;
  if (passExpiry) passExpiry.textContent = expiryDate.toLocaleString("es-MX", { dateStyle: "medium", timeStyle: "short" });
  if (passWatermark) {
    if (state === "valid") {
      passWatermark.textContent = "VALIDO";
      passWatermark.className =
        "pointer-events-none absolute right-[-34px] top-10 rotate-[28deg] rounded-lg border-2 border-[#006d36] bg-[#83fba5]/30 px-7 py-2 text-lg font-extrabold uppercase tracking-[0.08em] text-[#006d36]";
    } else {
      passWatermark.textContent = "INVALIDO";
      passWatermark.className =
        "pointer-events-none absolute right-[-38px] top-10 rotate-[28deg] rounded-lg border-2 border-[#93000a] bg-[#ffdad6] px-7 py-2 text-lg font-extrabold uppercase tracking-[0.08em] text-[#93000a]";
    }
  }

  const fetchQrFile = async () => {
    const response = await fetch(qrUrl);
    const blob = await response.blob();
    return new File([blob], `pase-${code}.png`, { type: "image/png" });
  };

  shareImageButton?.addEventListener("click", async () => {
    try {
      const file = await fetchQrFile();
      if (navigator.share && navigator.canShare && navigator.canShare({ files: [file] })) {
        await navigator.share({
          title: "Pase Nauka Nayarit",
          text: `Pase ${code}`,
          files: [file]
        });
        return;
      }
    } catch {
      // fall through to text-only WhatsApp link
    }
    const text = `Pase Nauka Nayarit%0ACodigo: ${encodeURIComponent(code)}%0AValidar: ${encodeURIComponent(guardUrl)}`;
    window.open(`https://wa.me/?text=${text}`, "_blank", "noopener,noreferrer");
  });

  downloadPdfButton?.addEventListener("click", () => {
    window.print();
  });
</script>
