---
import AppLayout from "../../layouts/AppLayout.astro";
import { solicitanteNav } from "../../lib/nav";
import { getActivePassesForSolicitante } from "../../lib/access";

const activePasses = Astro.locals.user && Astro.locals.accessToken
  ? await getActivePassesForSolicitante({
      accessToken: Astro.locals.accessToken,
      userId: Astro.locals.user.id,
      role: "solicitante",
      complejoId: Astro.locals.profile?.complejo_id ?? "complejo-1",
      lotNumber: Astro.locals.profile?.lot_number
    }).catch(() => [])
  : [];
const lotTitle = Astro.locals.profile?.lot_number ?? "A-22";
const MS_24H = 24 * 60 * 60 * 1000;
const expiringSoon = activePasses.filter((p) => {
  const t = new Date(p.vence_en).getTime();
  return t - Date.now() < MS_24H && t > Date.now();
});
const expiringIds = new Set(expiringSoon.map((p) => p.id));
---

<AppLayout
  title="Inicio Solicitante - Nauka Nayarit"
  topBar={{ title: "Nauka Nayarit", leftIcon: "location_on", leftHref: "#", rightIcon: "person", rightHref: "#" }}
  pageTitle={`Lote ${lotTitle}`}
  navItems={solicitanteNav}
>
  <p class="-mt-5 mb-10 text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-[#5c6569]">Panel de solicitante</p>

  {expiringSoon.length > 0 && (
    <div
      class="mb-8 rounded-2xl border border-[#9a6b5c]/30 bg-[rgba(154,107,92,0.1)] p-4"
      role="status"
    >
      <p class="flex items-center gap-2 font-semibold text-[#213138]">
        <span class="material-symbols-outlined text-[#9a6b5c]">schedule</span>
        Pases por vencer (próximas 24 h)
      </p>
      <ul class="mt-3 space-y-2 text-sm text-[#5c6569]">
        {expiringSoon.map((p) => (
          <li class="flex flex-wrap items-center justify-between gap-2 rounded-xl bg-white/70 px-3 py-2">
            <span class="font-medium text-[#213138]">{p.visitante_nombre}</span>
            <span class="text-xs font-semibold text-[#9a6b5c]">
              Vence {new Date(p.vence_en).toLocaleString("es-MX", { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" })}
            </span>
            <a
              href={`/pase/${encodeURIComponent(p.token_qr)}?type=entrada`}
              class="text-xs font-semibold text-[#3d5c4a] underline underline-offset-2"
            >
              Abrir QR
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <a
    href="/solicitante/nuevo-pase"
    class="nauka-btn-primary mb-10 flex h-24 w-full items-center justify-center gap-3 rounded-3xl px-5 text-xl font-semibold sm:text-2xl"
  >
    <span class="material-symbols-outlined text-4xl">add</span>
    <span>Crear nuevo pase de acceso</span>
  </a>

  <section id="pases-activos" class="space-y-4">
    <h2 class="font-display text-4xl tracking-tight text-[#213138] md:text-[2.75rem]">Pases activos</h2>
    <div class="grid grid-cols-2 gap-2 rounded-2xl border border-[#213138]/[0.06] bg-[#FCFBF9]/80 p-1 backdrop-blur-md">
      <button data-pass-filter="todos" class="pass-filter h-10 rounded-xl text-sm font-semibold uppercase tracking-[0.08em]">Todos</button>
      <button data-pass-filter="visita" class="pass-filter h-10 rounded-xl text-sm font-semibold uppercase tracking-[0.08em]">Solo visitas</button>
    </div>

    {
      activePasses.length === 0 ? (
        <article class="nauka-card-aero p-5 text-center">
          <div class="mx-auto mb-3 grid h-12 w-12 place-items-center rounded-full bg-[#213138]/[0.06] text-[#5c6569]">
            <span class="material-symbols-outlined">badge</span>
          </div>
          <p class="font-display text-xl text-[#213138]">Aún no tienes pases activos</p>
          <p class="mt-1 text-sm text-[#5c6569]">Crea tu primer pase para compartirlo por WhatsApp.</p>
          <a href="/solicitante/nuevo-pase" class="nauka-btn-primary mt-4 inline-flex h-11 items-center justify-center rounded-2xl px-6 text-sm font-semibold">
            Crear pase
          </a>
        </article>
      ) : (
        activePasses.map((pass) => (
          <article
            data-pass-type={(pass.motivo ?? "visita").toLowerCase()}
            class:list={[
              "nauka-card-aero relative p-5",
              expiringIds.has(pass.id) && "ring-2 ring-[#9a6b5c]/40"
            ]}
          >
            <span class="absolute left-0 top-0 h-full w-1 rounded-l-[20px] bg-[#3d5c4a]/35"></span>
            <div class="flex items-start gap-4 pl-2">
              <div class="grid h-12 w-12 place-items-center rounded-full border border-[#3d5c4a]/15 bg-[rgba(61,92,74,0.1)] text-[#3d5c4a]">
                <span class="material-symbols-outlined">badge</span>
              </div>
              <div class="flex-1">
                <p class="font-display text-3xl text-[#213138] md:text-4xl">{pass.visitante_nombre}</p>
                <p class="mt-1 text-lg text-[#5c6569]">
                  {new Date(pass.vence_en).toLocaleString("es-MX", { month: "short", day: "2-digit", hour: "2-digit", minute: "2-digit" })} · {(pass.motivo ?? "VISITA").toUpperCase()}
                </p>
                <div class="mt-4 flex gap-3">
                  <a href={`/pase/${encodeURIComponent(pass.token_qr)}?type=entrada`} class="flex-1 rounded-2xl border border-[#213138]/[0.08] bg-[#FCFBF9]/90 px-4 py-3 text-center text-lg font-semibold text-[#213138] transition duration-[400ms] ease-in-out hover:bg-white">
                    Ver QR
                  </a>
                  <button data-share-token={pass.token_qr} class="share-pass grid w-12 place-items-center rounded-2xl border border-[#3d5c4a]/12 bg-[rgba(61,92,74,0.08)] text-[#2d4a3a] transition duration-[400ms] ease-in-out hover:bg-[rgba(61,92,74,0.14)]">
                    <span class="material-symbols-outlined">chat</span>
                  </button>
                </div>
              </div>
            </div>
          </article>
        ))
      )
    }
  </section>
</AppLayout>

<script is:inline>
  const filterButtons = Array.from(document.querySelectorAll(".pass-filter"));
  const passCards = Array.from(document.querySelectorAll("[data-pass-type]"));
  let activeFilter = "todos";

  const renderFilter = () => {
    filterButtons.forEach((button) => {
      const selected = button.getAttribute("data-pass-filter") === activeFilter;
      button.className = `pass-filter h-10 rounded-xl text-sm font-semibold uppercase tracking-[0.08em] transition duration-[400ms] ease-in-out ${
        selected ? "nauka-btn-primary text-[#FCFBF9]" : "bg-transparent text-[#213138] hover:bg-[#213138]/[0.04]"
      }`;
    });

    passCards.forEach((card) => {
      const type = card.getAttribute("data-pass-type");
      const visible = activeFilter === "todos" || activeFilter === type;
      card.classList.toggle("hidden", !visible);
    });
  };

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      activeFilter = button.getAttribute("data-pass-filter") ?? "todos";
      renderFilter();
    });
  });

  renderFilter();

  Array.from(document.querySelectorAll(".share-pass")).forEach((button) => {
    button.addEventListener("click", () => {
      const token = button.getAttribute("data-share-token") ?? "";
      const url = `${window.location.origin}/pase/${encodeURIComponent(token)}`;
      const text = `Pase Nauka Nayarit%0AMuestra este pase en caseta:%0A${encodeURIComponent(url)}`;
      window.open(`https://wa.me/?text=${text}`, "_blank", "noopener,noreferrer");
    });
  });
</script>
