---
import AppLayout from "../../layouts/AppLayout.astro";
---

<AppLayout title="Nuevo Acceso - Nauka Nayarit" topBar={{ title: "Nuevo Acceso", leftIcon: "arrow_back", leftHref: "/solicitante/inicio" }}>
  <section class="nauka-card-aero p-5">
    <form id="pass-form" class="space-y-8">
      <label class="block">
        <span class="nauka-label-lux">Nombre del visitante</span>
        <input id="visitor-name" class="nauka-input-lux text-xl" placeholder="Ej. Juan Pérez" />
      </label>

      <label class="block">
        <span class="nauka-label-lux">Fecha de visita</span>
        <input id="visit-date" type="date" class="nauka-input-lux text-xl" />
      </label>

      <label class="block">
        <span class="nauka-label-lux">Hora aproximada</span>
        <input id="visit-time" type="time" class="nauka-input-lux text-xl" />
      </label>

      <label class="block">
        <span class="nauka-label-lux">Motivo</span>
        <select id="visit-reason" class="nauka-input-lux text-xl">
          <option>Visita</option>
          <option>Proveedor</option>
          <option>Mantenimiento</option>
        </select>
      </label>

      <label class="block">
        <span class="nauka-label-lux">Notas para caseta</span>
        <textarea id="visit-notes" rows="3" class="nauka-input-lux min-h-[5.5rem] resize-y text-lg" placeholder="Ej. Proveedor autorizado por mantenimiento, trae 3 paquetes."></textarea>
      </label>

      <label class="block">
        <span class="nauka-label-lux">Foto del visitante (rostro)</span>
        <input
          id="visitor-face"
          name="fotoVisitante"
          type="file"
          accept="image/*"
          capture="user"
          class="nauka-input-lux py-3 text-base file:mr-3 file:rounded-xl file:border-0 file:bg-[#213138]/10 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-[#213138]"
        />
        <p class="mt-1 text-xs font-medium text-[#5c6569]">Requerido para validar identidad en caseta.</p>
      </label>

      <label class="block">
        <span class="nauka-label-lux">Foto del INE (identificación)</span>
        <input
          id="visitor-ine"
          name="fotoIne"
          type="file"
          accept="image/*"
          capture="environment"
          class="nauka-input-lux py-3 text-base file:mr-3 file:rounded-xl file:border-0 file:bg-[#213138]/10 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-[#213138]"
        />
        <p class="mt-1 text-xs font-medium text-[#5c6569]">Debe verse legible el frente del INE.</p>
      </label>

      <button id="generate-pass" type="button" class="nauka-btn-primary flex h-14 w-full items-center justify-center gap-2 rounded-2xl text-xl font-semibold">
        <span class="material-symbols-outlined">qr_code_2</span>
        Generar pase
      </button>
    </form>

    <div id="generated-pass" class="nauka-invitation mt-6 hidden text-center" data-state="authorized">
      <div class="nauka-invitation-inner">
        <div class="mx-auto grid h-52 w-52 place-items-center rounded-3xl border border-[#213138]/[0.06] bg-[#FCFBF9]/90 shadow-[0_16px_40px_rgba(33,49,56,0.06)]">
          <span class="material-symbols-outlined text-8xl text-[#3d5c4a]">qr_code_2</span>
        </div>
        <p id="generated-label" class="mt-4 text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-[#5c6569]"></p>
        <a id="preview-pass-link" href="#" class="mt-3 flex h-12 w-full items-center justify-center rounded-2xl border border-[#213138]/[0.08] bg-[#FCFBF9]/80 text-base font-semibold text-[#213138] transition duration-[400ms] ease-in-out hover:bg-white">
          Ver pase público (QR)
        </a>
        <button id="share-whatsapp" type="button" class="mt-3 h-14 w-full rounded-2xl border border-[#3d5c4a]/20 bg-[rgba(61,92,74,0.1)] text-lg font-semibold text-[#2d4a3a] transition duration-[400ms] ease-in-out hover:bg-[rgba(61,92,74,0.16)]">
          Compartir por WhatsApp
        </button>
      </div>
    </div>
  </section>
</AppLayout>

<script is:inline>
  const generateButton = document.getElementById("generate-pass");
  const shareButton = document.getElementById("share-whatsapp");
  const generatedLabel = document.getElementById("generated-label");
  const generatedPass = document.getElementById("generated-pass");
  const visitorName = document.getElementById("visitor-name");
  const visitReason = document.getElementById("visit-reason");
  const visitNotes = document.getElementById("visit-notes");
  const previewPassLink = document.getElementById("preview-pass-link");
  const visitDate = document.getElementById("visit-date");
  const visitTime = document.getElementById("visit-time");
  const visitorFace = document.getElementById("visitor-face");
  const visitorIne = document.getElementById("visitor-ine");

  let currentCode = "";
  let currentShareUrl = "";

  const combineDateTime = () => {
    if (!(visitDate instanceof HTMLInputElement) || !(visitTime instanceof HTMLInputElement)) return "";
    if (!visitDate.value || !visitTime.value) return "";
    const localDateTime = new Date(`${visitDate.value}T${visitTime.value}:00`);
    if (Number.isNaN(localDateTime.getTime())) return "";
    return localDateTime.toISOString();
  };

  generateButton?.addEventListener("click", async () => {
    const name = visitorName instanceof HTMLInputElement ? visitorName.value.trim() : "";
    const reason = visitReason instanceof HTMLSelectElement ? visitReason.value : "Visita";
    const notes = visitNotes instanceof HTMLTextAreaElement ? visitNotes.value.trim() : "";
    const venceEn = combineDateTime();
    if (!name || !venceEn) {
      alert("Completa nombre, fecha y hora.");
      return;
    }
    const faceInput = visitorFace instanceof HTMLInputElement ? visitorFace : null;
    const ineInput = visitorIne instanceof HTMLInputElement ? visitorIne : null;
    const faceFile = faceInput?.files?.[0];
    const ineFile = ineInput?.files?.[0];
    if (!faceFile || !ineFile) {
      alert("Debes adjuntar la foto del rostro del visitante y la foto del INE.");
      return;
    }
    const selected = new Date(venceEn);
    const now = new Date();
    const maxAllowed = new Date(now.getTime() + 30 * 24 * 60 * 60 * 1000);
    if (selected <= now) {
      alert("La fecha/hora del pase debe ser futura.");
      return;
    }
    if (selected > maxAllowed) {
      alert("La fecha/hora no puede superar 30 dias.");
      return;
    }
    const fd = new FormData();
    fd.append("visitanteNombre", name);
    fd.append("motivo", reason);
    fd.append("venceEn", venceEn);
    fd.append("notas", notes);
    fd.append("fotoVisitante", faceFile);
    fd.append("fotoIne", ineFile);

    const response = await fetch("/api/solicitante/pases", {
      method: "POST",
      body: fd
    });
    if (!response.ok) {
      const payload = await response.json().catch(() => ({}));
      alert(payload.error ?? "No se pudo crear el pase.");
      return;
    }
    const payload = await response.json();
    currentCode = payload.pass?.tokenQr ?? "";
    if (!currentCode) {
      alert("No se recibió el token del pase.");
      return;
    }
    currentShareUrl = `${window.location.origin}/pase/${encodeURIComponent(currentCode)}?type=entrada`;
    if (generatedLabel) {
      generatedLabel.textContent = `Pase generado · vigencia registrada en sistema`;
    }
    if (previewPassLink instanceof HTMLAnchorElement) {
      previewPassLink.href = currentShareUrl;
    }
    if (generatedPass) {
      generatedPass.classList.remove("hidden");
      generatedPass.classList.add("ring-2", "ring-[#213138]/15");
    }
    window.location.href = currentShareUrl;
  });

  shareButton?.addEventListener("click", () => {
    const name = visitorName instanceof HTMLInputElement ? visitorName.value || "Visitante" : "Visitante";
    const reason = visitReason instanceof HTMLSelectElement ? visitReason.value || "Visita" : "Visita";
    const code = currentCode;
    if (!code) {
      alert("Primero genera un pase.");
      return;
    }
    const url = currentShareUrl || `${window.location.origin}/pase/${encodeURIComponent(code)}?type=entrada`;
    const text = `Pase Nauka Nayarit%0AVisitante: ${encodeURIComponent(name)}%0AMotivo: ${encodeURIComponent(reason)}%0AMostrar en caseta: ${encodeURIComponent(url)}`;
    window.open(`https://wa.me/?text=${text}`, "_blank", "noopener,noreferrer");
  });

  if (visitDate instanceof HTMLInputElement) {
    const now = new Date();
    const max = new Date(now.getTime() + 30 * 24 * 60 * 60 * 1000);
    visitDate.min = now.toISOString().slice(0, 10);
    visitDate.max = max.toISOString().slice(0, 10);
  }
</script>
