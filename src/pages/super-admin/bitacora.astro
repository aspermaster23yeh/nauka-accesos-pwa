---
import AppLayout from "../../layouts/AppLayout.astro";
import { superAdminNav } from "../../lib/nav";
import { getBitacoraScope } from "../../lib/access";

const q = Astro.url.searchParams.get("q") ?? "";
const registros = await getBitacoraScope({ allComplejos: true, query: q });
---

<AppLayout
  wide
  title="Bitácora global - Nauka"
  topBar={{ title: "Bitácora global", leftIcon: "arrow_back", leftHref: "/super-admin/dashboard", rightIcon: "logout", rightHref: "/api/auth/logout" }}
  navItems={superAdminNav}
  pageTitle="Movimientos (todos los complejos)"
>
  <form class="nauka-card-aero mb-4 space-y-3 p-4" method="get">
    <input name="q" value={q} class="nauka-input-lux text-sm" placeholder="Buscar visitante, complejo, motivo…" />
    <button type="submit" class="nauka-btn-primary h-10 w-full rounded-2xl text-sm font-semibold">Buscar</button>
  </form>

  <div class="space-y-2">
    {registros.map((row) => (
      <a
        href={`/admin/detalle-movimiento?id=${row.id}`}
        class={`nauka-card-aero block p-4 text-sm transition duration-[400ms] ease-in-out hover:-translate-y-px ${
          row.resultado === "rechazado" ? "border-[#9a6b5c]/15 bg-gradient-to-br from-[#fdfaf9] to-[#f5ebe8]/80" : ""
        }`}
      >
        <p class="font-semibold text-[#213138]">
          {row.complejo_id} · {new Date(row.created_at).toLocaleString("es-MX")}
        </p>
        <p class="text-[#5c6569]">
          {row.visitante_nombre} · {row.tipo_evento} · {row.resultado}
        </p>
        <p class="text-xs text-[#5c6569]">
          Solicitante: {row.solicitante_nombre ?? "—"} · {row.motivo ?? ""}
        </p>
      </a>
    ))}
  </div>
</AppLayout>
