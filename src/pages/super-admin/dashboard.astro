---
import AppLayout from "../../layouts/AppLayout.astro";
import { superAdminNav } from "../../lib/nav";
import { getAdminMetrics } from "../../lib/access";
import { getSupabaseServiceClient } from "../../lib/supabase";

const accessToken = Astro.locals.accessToken as string;
const profile = Astro.locals.profile;
const user = Astro.locals.user;

const defaultMetrics = {
  totalMovimientos: 0,
  totalAutorizados: 0,
  totalRechazados: 0,
  incidentesAbiertos: 0
};

const metrics = await getAdminMetrics({
  accessToken,
  userId: user!.id,
  role: "super_admin",
  complejoId: profile?.complejo_id ?? "complejo-1"
}).catch(() => defaultMetrics);

const supabase = getSupabaseServiceClient();
const { data: profiles } = await supabase
  .from("profiles")
  .select("id, full_name, lot_number, complejo_id, role, onboarding_status, ine_storage_path, created_at")
  .order("created_at", { ascending: false })
  .limit(40);
---

<AppLayout
  wide
  title="Super Admin - Nauka"
  topBar={{ title: "Nauka Super Admin", leftIcon: "shield", leftHref: "#", rightIcon: "logout", rightHref: "/api/auth/logout" }}
  navItems={superAdminNav}
  pageTitle="Alta de personal y solicitantes"
>
  <section class="grid grid-cols-2 gap-3">
    <article class="rounded-xl bg-white p-4 shadow-[0_6px_18px_rgba(26,28,28,0.04)]">
      <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#64748b]">Movimientos (24 h, global)</p>
      <p class="mt-2 text-3xl font-extrabold text-[#213138]">{metrics.totalMovimientos}</p>
    </article>
    <article class="rounded-xl bg-white p-4 shadow-[0_6px_18px_rgba(26,28,28,0.04)]">
      <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#64748b]">Autorizados</p>
      <p class="mt-2 text-3xl font-extrabold text-[#006d36]">{metrics.totalAutorizados}</p>
    </article>
  </section>

  <section class="mt-8 rounded-[14px] bg-white p-5 shadow-[0_8px_24px_rgba(26,28,28,0.06)]">
    <h2 class="text-xl font-bold text-[#213138]">Invitar usuario</h2>
    <p class="mt-1 text-sm text-[#5f6368]">Se crea la cuenta en Auth y el perfil con rol. Opcional: INE (imagen) en Storage.</p>
    <form id="invite-form" class="mt-4 space-y-3">
      <input name="email" type="email" required placeholder="correo@ejemplo.com" class="h-12 w-full rounded-xl border border-[#ececec] px-3 text-sm" />
      <input name="full_name" type="text" required placeholder="Nombre completo" class="h-12 w-full rounded-xl border border-[#ececec] px-3 text-sm" />
      <input name="lot_number" type="text" required placeholder="Lote" class="h-12 w-full rounded-xl border border-[#ececec] px-3 text-sm" />
      <input name="complejo_id" type="text" value="complejo-1" class="h-12 w-full rounded-xl border border-[#ececec] px-3 text-sm" />
      <select name="role" class="h-12 w-full rounded-xl border border-[#ececec] px-3 text-sm">
        <option value="solicitante">Solicitante</option>
        <option value="guardia">Guardia</option>
        <option value="admin">Admin complejo</option>
      </select>
      <label class="block text-sm text-[#5f6368]">
        INE (opcional, jpg/png, máx. 6 MB)
        <input name="ine" type="file" accept="image/jpeg,image/png" class="mt-1 w-full text-sm" />
      </label>
      <button type="submit" class="h-12 w-full rounded-xl bg-[#213138] text-sm font-semibold text-white">Crear usuario</button>
    </form>
    <pre id="invite-result" class="mt-3 hidden whitespace-pre-wrap rounded-lg bg-[#f4f4f4] p-3 text-xs text-[#213138]"></pre>
  </section>

  <section class="mt-8 space-y-2">
    <h2 class="text-xl font-bold text-[#213138]">Perfiles recientes</h2>
    {(profiles ?? []).map((p) => (
      <div class="flex flex-wrap items-center justify-between gap-2 rounded-xl bg-white p-3 text-sm shadow-sm">
        <div>
          <p class="font-semibold text-[#213138]">{p.full_name ?? p.id}</p>
          <p class="text-[#5f6368]">
            {p.role} · {p.complejo_id} · lote {p.lot_number ?? "—"} · {p.onboarding_status}
          </p>
        </div>
        {p.onboarding_status !== "activo" && (
          <button type="button" data-approve-id={p.id} class="approve-btn rounded-lg bg-[#006d36] px-3 py-2 text-xs font-semibold text-white">
            Marcar activo
          </button>
        )}
      </div>
    ))}
  </section>
</AppLayout>

<script is:inline>
  const form = document.getElementById("invite-form");
  const result = document.getElementById("invite-result");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!(form instanceof HTMLFormElement)) return;
    const fd = new FormData(form);
    const res = await fetch("/api/super-admin/invite", { method: "POST", body: fd });
    const data = await res.json().catch(() => ({}));
    if (!res.ok) {
      alert(data.error ?? "Error al invitar");
      return;
    }
    if (result) {
      result.classList.remove("hidden");
      result.textContent = JSON.stringify(data, null, 2);
    }
    alert("Usuario creado. Guarda la contraseña temporal del recuadro.");
  });
  document.querySelectorAll(".approve-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = btn.getAttribute("data-approve-id");
      if (!id) return;
      const res = await fetch("/api/super-admin/approve", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ userId: id })
      });
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        alert(data.error ?? "No se pudo aprobar");
        return;
      }
      window.location.reload();
    });
  });
</script>
